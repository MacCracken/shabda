# shabda.cyr -- bundled distribution
# Version: 3.0.1
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr — shabda error codes + shared L0 constants, built on sakshi's
# packed-i64 error model.
#
# L0 base module: included FIRST by every build/test entry. Modules never
# `include` each other — the entry file (src/main.cyr / tests/*.tcyr) orders
# includes; the stdlib (incl. sakshi) auto-resolves from cyrius.cyml [deps].
#
# Ports rust-old/src/error.rs (the `ShabdaError` enum — #[non_exhaustive], 5
# variants). Rust carried a String payload per variant + a thiserror Display; the
# Cyrius port drops the payloads and builds on sakshi (साक्षी — the AGNOS
# error/tracing substrate): each error is a packed i64 `[ctx][category][code]`.
# 0 == ok, non-zero == error. Diagnostic text lives in shabda_err_name().
#
# CONVENTION: a fallible fn returns a packed shabda error (0 == ok) and writes any
# payload to an out-param, OR returns a payload pointer with 0 meaning "none" —
# disambiguate with shabda_is_err().
#
# This module also hoists the shared integer tags used across the crate
# (Language, SentenceType, TimingProfile layout, the phoneme sentinel). They live
# in the L0 base so later modules (prosody, validate, engine) reference them
# regardless of include order — mirrors how shabdakosh put SHBDK_PH_NONE in L0.
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`-prefixed (flat link
# namespace; coexists with shbdk_ / svara_ / varna / sakshi).

# ================================================================
# Error codes (was `enum ShabdaError`). One per Rust variant, in order. Stored in
# bits 0-15 of a sakshi packed error; kept above sakshi's common ErrCode block
# (0..7) and clear of shabdakosh's 0x01xx block to avoid collision.
# ================================================================
var SHABDA_ERR_INVALID_INPUT        = 0x0201;   # InvalidInput(String)
var SHABDA_ERR_UNKNOWN_WORD         = 0x0202;   # UnknownWord(String)
var SHABDA_ERR_UNSUPPORTED_LANGUAGE = 0x0203;   # UnsupportedLanguage(String)
var SHABDA_ERR_RULE_ERROR           = 0x0204;   # RuleError(String)
var SHABDA_ERR_DICT_PARSE           = 0x0205;   # DictParseError(String)

# ================================================================
# Shared L0 constants (hoisted here so every module sees ONE definition — flat
# namespace, no forward-declare needed for later includes).
# ================================================================
# "No phoneme" sentinel — a svara phoneme is an ordinal 0..N; this is Rust's
# Option::None on a phoneme lookup.
var SHABDA_PH_NONE = (0 - 1);

# Language tags (was `enum Language`, #[non_exhaustive]). Ctor/name fns in engine.cyr.
var SHABDA_LANG_ENGLISH  = 0;
var SHABDA_LANG_SPANISH  = 1;
var SHABDA_LANG_GERMAN   = 2;
var SHABDA_LANG_HINDI    = 3;
var SHABDA_LANG_ARABIC   = 4;
var SHABDA_LANG_SANSKRIT = 5;

# SentenceType tags (owned by normalize; detect fns there). Statement/Question/
# Exclamation.
var SHABDA_STYPE_STATEMENT   = 0;
var SHABDA_STYPE_QUESTION    = 1;
var SHABDA_STYPE_EXCLAMATION = 2;

# TimingProfile layout (24 bytes): three f64-bit scale factors. Ctor/accessors in
# engine.cyr; prosody reads the offsets directly.
var SHABDA_TIMING_VOWEL     = 0;    # [0]  vowel_scale     (f64 bits)
var SHABDA_TIMING_CONSONANT = 8;    # [8]  consonant_scale (f64 bits)
var SHABDA_TIMING_PAUSE     = 16;   # [16] pause_scale     (f64 bits)
var SHABDA_TIMING_SIZE      = 24;

# "No primary stress" sentinel for the syllabic stress rule (Rust's usize::MAX).
var SHABDA_NO_STRESS_IDX = (0 - 1);

# ================================================================
# Constructors — pack the shabda code + a sakshi category into an i64 error.
# ================================================================
#must_use
fn shabda_err_invalid_input(): i64 {
    return sakshi_err_new(SHABDA_ERR_INVALID_INPUT, ERR_CAT_PARSE);
}

#must_use
fn shabda_err_unknown_word(): i64 {
    return sakshi_err_new(SHABDA_ERR_UNKNOWN_WORD, ERR_CAT_RUNTIME);
}

#must_use
fn shabda_err_unsupported_language(): i64 {
    return sakshi_err_new(SHABDA_ERR_UNSUPPORTED_LANGUAGE, ERR_CAT_CONFIG);
}

#must_use
fn shabda_err_rule_error(): i64 {
    return sakshi_err_new(SHABDA_ERR_RULE_ERROR, ERR_CAT_RUNTIME);
}

#must_use
fn shabda_err_dict_parse(): i64 {
    return sakshi_err_new(SHABDA_ERR_DICT_PARSE, ERR_CAT_PARSE);
}

# From<ShabdakoshError> — Rust folds every shabdakosh error into DictParseError.
# Takes a packed shbdk error, returns a packed shabda DictParse error.
#must_use
fn shabda_from_shabdakosh_err(shbdk_err): i64 {
    return sakshi_err_new(SHABDA_ERR_DICT_PARSE, ERR_CAT_PARSE);
}

# ================================================================
# Predicates + diagnostics (thin over sakshi, prefixed for the shabda surface).
# ================================================================
# 1 if `err` is an error (non-zero), 0 otherwise.
#must_use
fn shabda_is_err(err): i64 {
    return sakshi_is_err(err);
}

# 1 if `err` is ok (zero), 0 otherwise.
#must_use
fn shabda_is_ok(err): i64 {
    return sakshi_is_ok(err);
}

# Static diagnostic text for a shabda error (was thiserror's Display, minus the
# dropped String payload). Matches on the code field; final arm is the
# #[non_exhaustive] fallback. Returns `cstring` so println/fmt print the text.
#must_use
fn shabda_err_name(err): cstring {
    var code = sakshi_err_code(err);
    if (code == SHABDA_ERR_INVALID_INPUT)        { return "invalid input"; }
    if (code == SHABDA_ERR_UNKNOWN_WORD)         { return "unknown word"; }
    if (code == SHABDA_ERR_UNSUPPORTED_LANGUAGE) { return "unsupported language"; }
    if (code == SHABDA_ERR_RULE_ERROR)           { return "rule error"; }
    if (code == SHABDA_ERR_DICT_PARSE)           { return "dictionary parse error"; }
    if (code == 0)                                { return "ok"; }
    return "unknown error";
}

# --- normalize.cyr ---

# normalize.cyr — text normalization for G2P (ports rust-old/src/normalize.rs).
#
# Leaf module: depends on stdlib only (string/str/vec/fmt/alloc). OWNS the
# SentenceType surface — the SHABDA_STYPE_* tags are hoisted in error.cyr (L0);
# the detect fn (shabda_detect_intonation) lives here.
#
# Ports: normalize, normalize_with_emphasis, expand_abbreviations,
# expand_acronyms, is_foreign_word, strip_diacritics, expand_numbers,
# detect_intonation. Plus the private helpers (match_abbreviation,
# split_trailing_punct, is_acronym, is_pronounceable_acronym, collect_number,
# expand_number_token, digits_to_words, number_to_words, hundreds/tens_to_words,
# is_latin_extended, normalize_token_into).
#
# CYRIUS STRING MODEL: strings are cstr byte pointers (NUL-terminated). Rust's
# `.chars()` scalar iteration is replaced by a UTF-8 decoder (_shabda_utf8_next,
# copied from shabdakosh detect.cyr) that walks code points. Output is built into
# a growable byte buffer (a "SB": a heap struct that owns a cstr + len + cap and
# appends bytes / cstr literals / UTF-8-encoded code points) so we never touch the
# Str<->cstr trap.
#
# SB layout (24 bytes): [0]=data ptr, [8]=len (bytes, excl NUL), [16]=cap (bytes
# of the backing alloc, incl room for NUL).
#
# tracing trace! calls in the Rust are dropped (no-op).
#
# DIVERGENCE (number parsing): Rust parses integer tokens with str::parse::<u64>()
# (range 0..=u64::MAX). Cyrius is i64-only, so _shabda_parse_u64 accepts 0..=i64::MAX
# and falls back to digit-by-digit (Rust digits_to_words) on i64 overflow. This is
# faithful for every value <= i64::MAX; values in (i64::MAX, u64::MAX] parse in Rust
# but overflow here. Rust's own number_to_words only handles up to billions, so it
# renders those huge values as garbage anyway; no ported test covers that range.
#
# Dep position: included after src/error.cyr (which hoists SHABDA_STYPE_*). Never
# includes other modules. NAMING: every top-level symbol is shabda_/SHABDA_-prefixed.

# ================================================================
# Constants — MATCH the Rust literal values in normalize.rs exactly.
# COMMA_PAUSE=",pause"  PERIOD_PAUSE=".pause"
# EMPHASIS_START="<emph>"  EMPHASIS_END="</emph>"
# ================================================================
var SHABDA_COMMA_PAUSE    = ",pause";
var SHABDA_PERIOD_PAUSE   = ".pause";
var SHABDA_EMPHASIS_START = "<emph>";
var SHABDA_EMPHASIS_END   = "</emph>";

# ================================================================
# UTF-8 code-point decoder — verbatim from shabdakosh detect.cyr. Decodes one
# code point at byte pointer p; writes the scalar to *out_cp; returns bytes
# consumed (1..4), or 0 at the NUL terminator.
# ================================================================
fn _shabda_utf8_next(p, out_cp): i64 {
    var b0 = load8(p);
    var b1 = 0;
    var b2 = 0;
    var b3 = 0;
    if (b0 == 0) { return 0; }
    if (b0 < 128) { store64(out_cp, b0); return 1; }
    if (b0 < 224) {
        b1 = load8(p + 1);
        if (b1 == 0) { store64(out_cp, b0); return 1; }
        store64(out_cp, ((b0 & 31) << 6) | (b1 & 63));
        return 2;
    }
    if (b0 < 240) {
        b1 = load8(p + 1);
        if (b1 == 0) { store64(out_cp, b0); return 1; }
        b2 = load8(p + 2);
        if (b2 == 0) { store64(out_cp, b0); return 1; }
        store64(out_cp, ((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63));
        return 3;
    }
    b1 = load8(p + 1);
    if (b1 == 0) { store64(out_cp, b0); return 1; }
    b2 = load8(p + 2);
    if (b2 == 0) { store64(out_cp, b0); return 1; }
    b3 = load8(p + 3);
    if (b3 == 0) { store64(out_cp, b0); return 1; }
    store64(out_cp, ((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63));
    return 4;
}

# ================================================================
# Growable cstr byte buffer ("SB"). Owns a NUL-terminated backing alloc.
# ================================================================
var SHABDA_SB_DATA = 0;
var SHABDA_SB_LEN  = 8;
var SHABDA_SB_CAP  = 16;
var SHABDA_SB_SIZE = 24;

fn _shabda_sb_new(): i64 {
    var sb = alloc(SHABDA_SB_SIZE);
    var buf = alloc(16);
    store8(buf, 0);
    store64(sb + SHABDA_SB_DATA, buf);
    store64(sb + SHABDA_SB_LEN, 0);
    store64(sb + SHABDA_SB_CAP, 16);
    return sb;
}

# Ensure room for `extra` more bytes plus the NUL terminator.
fn _shabda_sb_reserve(sb, extra): i64 {
    var len = load64(sb + SHABDA_SB_LEN);
    var cap = load64(sb + SHABDA_SB_CAP);
    var need = len + extra + 1;
    if (need <= cap) { return 0; }
    var newcap = cap;
    while (newcap < need) { newcap = newcap * 2; }
    var old = load64(sb + SHABDA_SB_DATA);
    var buf = alloc(newcap);
    memcpy(buf, old, len);
    store8(buf + len, 0);
    store64(sb + SHABDA_SB_DATA, buf);
    store64(sb + SHABDA_SB_CAP, newcap);
    return 0;
}

# Append one raw byte.
fn _shabda_sb_push_byte(sb, b): i64 {
    _shabda_sb_reserve(sb, 1);
    var data = load64(sb + SHABDA_SB_DATA);
    var len = load64(sb + SHABDA_SB_LEN);
    store8(data + len, b);
    store8(data + len + 1, 0);
    store64(sb + SHABDA_SB_LEN, len + 1);
    return 0;
}

# Append a NUL-terminated cstring.
fn _shabda_sb_push_cstr(sb, s): i64 {
    var n = strlen(s);
    _shabda_sb_reserve(sb, n);
    var data = load64(sb + SHABDA_SB_DATA);
    var len = load64(sb + SHABDA_SB_LEN);
    memcpy(data + len, s, n);
    store8(data + len + n, 0);
    store64(sb + SHABDA_SB_LEN, len + n);
    return 0;
}

# Append `n` bytes from a raw pointer.
fn _shabda_sb_push_bytes(sb, p, n): i64 {
    _shabda_sb_reserve(sb, n);
    var data = load64(sb + SHABDA_SB_DATA);
    var len = load64(sb + SHABDA_SB_LEN);
    memcpy(data + len, p, n);
    store8(data + len + n, 0);
    store64(sb + SHABDA_SB_LEN, len + n);
    return 0;
}

# UTF-8-encode a code point and append it.
fn _shabda_sb_push_cp(sb, cp): i64 {
    if (cp < 128) {
        _shabda_sb_push_byte(sb, cp);
        return 0;
    }
    if (cp < 2048) {
        _shabda_sb_push_byte(sb, 192 | (cp >> 6));
        _shabda_sb_push_byte(sb, 128 | (cp & 63));
        return 0;
    }
    if (cp < 65536) {
        _shabda_sb_push_byte(sb, 224 | (cp >> 12));
        _shabda_sb_push_byte(sb, 128 | ((cp >> 6) & 63));
        _shabda_sb_push_byte(sb, 128 | (cp & 63));
        return 0;
    }
    _shabda_sb_push_byte(sb, 240 | (cp >> 18));
    _shabda_sb_push_byte(sb, 128 | ((cp >> 12) & 63));
    _shabda_sb_push_byte(sb, 128 | ((cp >> 6) & 63));
    _shabda_sb_push_byte(sb, 128 | (cp & 63));
    return 0;
}

# Finalize: return the cstr pointer (NUL-terminated).
fn _shabda_sb_cstr(sb): cstring {
    return load64(sb + SHABDA_SB_DATA);
}

fn _shabda_sb_len(sb): i64 {
    return load64(sb + SHABDA_SB_LEN);
}

# Last byte of the buffer, or 0 if empty.
fn _shabda_sb_last(sb): i64 {
    var len = load64(sb + SHABDA_SB_LEN);
    if (len == 0) { return 0; }
    var data = load64(sb + SHABDA_SB_DATA);
    return load8(data + len - 1);
}

# ================================================================
# Code-point predicates (mirror Rust char methods on the paths normalize uses).
# ================================================================
# Rust char::is_alphabetic. Covers the scripts this crate feeds: ASCII letters,
# Latin-1/Extended accented letters, and — for the Hindi/Sanskrit (Devanagari) and
# Arabic G2P engines — those scripts' letters + alphabetic combining marks. Rust's
# is_alphabetic() = Lu+Ll+Lt+Lm+Lo+Nl+Other_Alphabetic, so Devanagari matras /
# anusvara / visarga and Arabic harakat / shadda (Other_Alphabetic) COUNT, while
# nukta (093C), virama (094D), Vedic tone marks (0951..0954), Arabic tatweel (0640)
# and sukun (0652) do NOT. normalize keeps exactly the alphabetic code points, so
# matching this is load-bearing for native-script convert (regression: dropping
# Devanagari/Arabic here made "नमस्ते"/"كتاب" normalize to empty -> 0 events).
fn _shabda_is_alpha(cp): i64 {
    if (cp >= 65 && cp <= 90) { return 1; }
    if (cp >= 97 && cp <= 122) { return 1; }
    if (cp >= 0x00C0 && cp <= 0x024F) {
        if (cp == 0x00D7) { return 0; }   # multiplication sign (Sm)
        if (cp == 0x00F7) { return 0; }   # division sign (Sm)
        return 1;
    }
    # Devanagari (U+0900..U+0963): letters + matras + anusvara/visarga/chandrabindu.
    if (cp >= 0x0900 && cp <= 0x0963) {
        if (cp == 0x093C) { return 0; }                  # nukta (Mn, not alphabetic)
        if (cp == 0x094D) { return 0; }                  # virama / halant (Mn)
        if (cp >= 0x0951 && cp <= 0x0954) { return 0; }  # Vedic tone/accent marks (Mn)
        return 1;
    }
    # Arabic (U+0620..U+0651): letters + harakat (fatha/kasra/damma/tanween) + shadda.
    if (cp >= 0x0620 && cp <= 0x0651) {
        if (cp == 0x0640) { return 0; }                  # tatweel / kashida (Lm join, not alphabetic)
        return 1;
    }
    # Arabic extended letters (superscript alef .. ha with small tah) — skips the
    # sukun (0652), Arabic-Indic digits (0660..0669) and punctuation in between.
    if (cp >= 0x0671 && cp <= 0x06D3) { return 1; }
    return 0;
}

fn _shabda_is_ascii_alpha(cp): i64 {
    if (cp >= 65 && cp <= 90) { return 1; }
    if (cp >= 97 && cp <= 122) { return 1; }
    return 0;
}

fn _shabda_is_ascii_upper(cp): i64 {
    if (cp >= 65 && cp <= 90) { return 1; }
    return 0;
}

fn _shabda_is_ascii_digit(cp): i64 {
    if (cp >= 48 && cp <= 57) { return 1; }
    return 0;
}

# Rust char::is_alphanumeric — for our inputs = alpha OR ascii digit.
fn _shabda_is_alnum(cp): i64 {
    if (_shabda_is_alpha(cp) == 1) { return 1; }
    if (_shabda_is_ascii_digit(cp) == 1) { return 1; }
    return 0;
}

# Rust char::is_whitespace on ASCII inputs: space/tab/nl/cr/ff/vt.
fn _shabda_is_ws(cp): i64 {
    if (cp == 32) { return 1; }
    if (cp == 9) { return 1; }
    if (cp == 10) { return 1; }
    if (cp == 13) { return 1; }
    if (cp == 12) { return 1; }
    if (cp == 11) { return 1; }
    return 0;
}

# Rust char::is_uppercase for our alpha inputs: ASCII A-Z (accented uppercase in
# the Latin block are not used by expand_acronyms's ASCII-only tokens; the ALL-CAPS
# emphasis path uses is_uppercase over alpha chars — accented uppercase counts).
fn _shabda_is_upper(cp): i64 {
    if (cp >= 65 && cp <= 90) { return 1; }
    # Latin-1 uppercase 0x00C0..0x00DE excluding 0x00D7 (multiplication sign).
    if (cp >= 0x00C0 && cp <= 0x00DE) {
        if (cp == 0x00D7) { return 0; }
        return 1;
    }
    return 0;
}

# ASCII lowercase of a code point (Rust to_lowercase().next() over the letters
# this crate handles: ASCII upper -> ASCII lower; everything else unchanged, which
# preserves accented letters as-is like the Rust default lowering keeps its scalar).
fn _shabda_to_lower_cp(cp): i64 {
    if (cp >= 65 && cp <= 90) { return cp + 32; }
    return cp;
}

# ================================================================
# ASCII-lowercase copy of a cstring (Rust str::to_lowercase for the ASCII-only
# words match_abbreviation / is_pronounceable_acronym pass it — those inputs are
# ASCII, so ASCII folding matches Rust's Unicode folding on them).
# ================================================================
fn _shabda_lower_cstr(s): cstring {
    var n = strlen(s);
    var out = alloc(n + 1);
    var i = 0;
    var c = 0;
    while (i < n) {
        c = load8(s + i);
        if (c >= 65 && c <= 90) { c = c + 32; }
        store8(out + i, c);
        i = i + 1;
    }
    store8(out + n, 0);
    return out;
}

# cstr starts_with(prefix): 1 if s begins with the bytes of prefix.
fn _shabda_starts_with(s, prefix): i64 {
    var i = 0;
    var pc = 0;
    var sc = 0;
    while (1 == 1) {
        pc = load8(prefix + i);
        if (pc == 0) { return 1; }
        sc = load8(s + i);
        if (sc != pc) { return 0; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# ONES[0..20] / TENS[0..10] number-word tables (static cstrs).
# ================================================================
fn _shabda_ones(i): cstring {
    if (i == 0)  { return "zero"; }
    if (i == 1)  { return "one"; }
    if (i == 2)  { return "two"; }
    if (i == 3)  { return "three"; }
    if (i == 4)  { return "four"; }
    if (i == 5)  { return "five"; }
    if (i == 6)  { return "six"; }
    if (i == 7)  { return "seven"; }
    if (i == 8)  { return "eight"; }
    if (i == 9)  { return "nine"; }
    if (i == 10) { return "ten"; }
    if (i == 11) { return "eleven"; }
    if (i == 12) { return "twelve"; }
    if (i == 13) { return "thirteen"; }
    if (i == 14) { return "fourteen"; }
    if (i == 15) { return "fifteen"; }
    if (i == 16) { return "sixteen"; }
    if (i == 17) { return "seventeen"; }
    if (i == 18) { return "eighteen"; }
    if (i == 19) { return "nineteen"; }
    return "";
}

fn _shabda_tens(i): cstring {
    if (i == 2) { return "twenty"; }
    if (i == 3) { return "thirty"; }
    if (i == 4) { return "forty"; }
    if (i == 5) { return "fifty"; }
    if (i == 6) { return "sixty"; }
    if (i == 7) { return "seventy"; }
    if (i == 8) { return "eighty"; }
    if (i == 9) { return "ninety"; }
    return "";
}

# ================================================================
# number_to_words / hundreds_to_words / tens_to_words — append into an SB.
# Rust builds Vec<String> + join(" "); we append directly with " " separators.
# ================================================================

# Converts 1..99 to words, appended to sb. (Rust tens_to_words)
fn _shabda_tens_to_words(sb, n): i64 {
    if (n < 20) {
        _shabda_sb_push_cstr(sb, _shabda_ones(n));
        return 0;
    }
    _shabda_sb_push_cstr(sb, _shabda_tens(n / 10));
    var one = n % 10;
    if (one > 0) {
        _shabda_sb_push_byte(sb, 32);
        _shabda_sb_push_cstr(sb, _shabda_ones(one));
    }
    return 0;
}

# Converts 1..999 to words, appended to sb. (Rust hundreds_to_words)
fn _shabda_hundreds_to_words(sb, n): i64 {
    var wrote = 0;
    if (n >= 100) {
        _shabda_sb_push_cstr(sb, _shabda_ones(n / 100));
        _shabda_sb_push_byte(sb, 32);
        _shabda_sb_push_cstr(sb, "hundred");
        wrote = 1;
    }
    var remainder = n % 100;
    if (remainder > 0) {
        if (wrote == 1) { _shabda_sb_push_byte(sb, 32); }
        _shabda_tens_to_words(sb, remainder);
    }
    return 0;
}

# Converts 0..999,999,999+ to words, appended to sb. (Rust number_to_words)
fn _shabda_number_to_words(sb, n): i64 {
    if (n == 0) {
        _shabda_sb_push_cstr(sb, "zero");
        return 0;
    }
    var wrote = 0;
    if (n >= 1000000000) {
        var billions = n / 1000000000;
        _shabda_number_to_words(sb, billions);
        _shabda_sb_push_byte(sb, 32);
        _shabda_sb_push_cstr(sb, "billion");
        wrote = 1;
    }
    var remainder = n % 1000000000;
    if (remainder >= 1000000) {
        var millions = remainder / 1000000;
        if (wrote == 1) { _shabda_sb_push_byte(sb, 32); }
        _shabda_number_to_words(sb, millions);
        _shabda_sb_push_byte(sb, 32);
        _shabda_sb_push_cstr(sb, "million");
        wrote = 1;
    }
    remainder = remainder % 1000000;
    if (remainder >= 1000) {
        var thousands = remainder / 1000;
        if (wrote == 1) { _shabda_sb_push_byte(sb, 32); }
        _shabda_number_to_words(sb, thousands);
        _shabda_sb_push_byte(sb, 32);
        _shabda_sb_push_cstr(sb, "thousand");
        wrote = 1;
    }
    remainder = remainder % 1000;
    if (remainder > 0) {
        if (wrote == 1) { _shabda_sb_push_byte(sb, 32); }
        _shabda_hundreds_to_words(sb, remainder);
    }
    return 0;
}

# ================================================================
# Number-token parsing. `token` is a cstr of digits + optional single '.'.
# ================================================================

# Parse a cstr of ASCII digits into an integer. Returns the value; sets *ok_out to
# 1 on success (all digits, non-empty, no overflow), 0 on failure -> Rust's
# digits_to_words fallback. Rust used str::parse::<u64>() (accepts up to u64::MAX);
# Cyrius is i64-only, so we accept up to i64::MAX (9223372036854775807) and treat
# genuine i64 overflow as the failure/fallback path. See the DIVERGENCE note in the
# header: values in (i64::MAX, u64::MAX] parse in Rust but overflow here — Rust
# itself renders those as garbage via its billions-only number_to_words, and no
# ported test exercises that range. Bound check: v*10+d overflows i64 when
# v > 922337203685477580, or v == 922337203685477580 && d > 7.
fn _shabda_parse_u64(s, ok_out): i64 {
    var n = strlen(s);
    if (n == 0) { store64(ok_out, 0); return 0; }
    var i = 0;
    var v = 0;
    var c = 0;
    var d = 0;
    while (i < n) {
        c = load8(s + i);
        if (c < 48 || c > 57) { store64(ok_out, 0); return 0; }
        d = c - 48;
        # i64 overflow guard (i64::MAX = 9223372036854775807).
        if (v > 922337203685477580) { store64(ok_out, 0); return 0; }
        if (v == 922337203685477580 && d > 7) { store64(ok_out, 0); return 0; }
        v = v * 10 + d;
        i = i + 1;
    }
    store64(ok_out, 1);
    return v;
}

# Reads digits one by one as fallback for very large numbers. (Rust digits_to_words)
fn _shabda_digits_to_words(sb, s): i64 {
    var n = strlen(s);
    var i = 0;
    var c = 0;
    var wrote = 0;
    while (i < n) {
        c = load8(s + i);
        if (c >= 48 && c <= 57) {
            if (wrote == 1) { _shabda_sb_push_byte(sb, 32); }
            _shabda_sb_push_cstr(sb, _shabda_ones(c - 48));
            wrote = 1;
        }
        i = i + 1;
    }
    return 0;
}

# Expands a number token cstr to words, appended to sb. (Rust expand_number_token)
fn _shabda_expand_number_token(sb, token): i64 {
    var dot = strchr(token, 46);
    if (dot >= 0) {
        # Decimal: "3.14" -> "three point one four"
        var tlen = strlen(token);
        # integer_part = token[..dot], decimal_part = token[dot+1..]
        var intbuf = alloc(dot + 1);
        memcpy(intbuf, token, dot);
        store8(intbuf + dot, 0);
        var declen = tlen - dot - 1;
        var decbuf = alloc(declen + 1);
        memcpy(decbuf, token + dot + 1, declen);
        store8(decbuf + declen, 0);

        if (strlen(intbuf) == 0) {
            _shabda_sb_push_cstr(sb, "zero");
        } else {
            var ok = alloc(8);
            var v = _shabda_parse_u64(intbuf, ok);
            if (load64(ok) == 1) {
                _shabda_number_to_words(sb, v);
            } else {
                _shabda_digits_to_words(sb, intbuf);
            }
        }
        _shabda_sb_push_cstr(sb, " point");
        var i = 0;
        var c = 0;
        while (i < declen) {
            c = load8(decbuf + i);
            if (c >= 48 && c <= 57) {
                _shabda_sb_push_byte(sb, 32);
                _shabda_sb_push_cstr(sb, _shabda_ones(c - 48));
            }
            i = i + 1;
        }
        return 0;
    }
    var ok2 = alloc(8);
    var v2 = _shabda_parse_u64(token, ok2);
    if (load64(ok2) == 1) {
        _shabda_number_to_words(sb, v2);
    } else {
        _shabda_digits_to_words(sb, token);
    }
    return 0;
}

# Collects a contiguous number token from a codepoint vec starting at index `start`.
# Digits go into sb-out buffer; commas between digits skipped; one decimal point.
# Returns bytes... actually returns count of code points consumed; the collected
# token cstr is written via out_tok (a pointer to a cstr slot).
fn _shabda_collect_number(cps, start, out_tok): i64 {
    var n = vec_len(cps);
    var sb = _shabda_sb_new();
    var i = start;
    var has_dot = 0;
    var c = 0;
    var nx = 0;
    var brk = 0;
    while (i < n && brk == 0) {
        c = vec_get(cps, i);
        if (c >= 48 && c <= 57) {
            _shabda_sb_push_byte(sb, c);
            i = i + 1;
        } elif (c == 44 && i + 1 < n) {
            nx = vec_get(cps, i + 1);
            if (nx >= 48 && nx <= 57) {
                i = i + 1;
            } else {
                brk = 1;
            }
        } elif (c == 46 && has_dot == 0 && i + 1 < n) {
            nx = vec_get(cps, i + 1);
            if (nx >= 48 && nx <= 57) {
                _shabda_sb_push_byte(sb, 46);
                has_dot = 1;
                i = i + 1;
            } else {
                brk = 1;
            }
        } else {
            brk = 1;
        }
    }
    store64(out_tok, _shabda_sb_cstr(sb));
    return i - start;
}

# ================================================================
# Decode a whole cstring into a vec of code points (Rust `text.chars().collect()`).
# ================================================================
fn _shabda_decode_cps(text): i64 {
    var cps = vec_new();
    var p = text;
    var cp = alloc(8);
    var adv = _shabda_utf8_next(p, cp);
    while (adv > 0) {
        vec_push(cps, load64(cp));
        p = p + adv;
        adv = _shabda_utf8_next(p, cp);
    }
    return cps;
}

# ================================================================
# expand_numbers — public. (Rust expand_numbers)
# ================================================================
#must_use
fn shabda_expand_numbers(text): cstring {
    var cps = _shabda_decode_cps(text);
    var n = vec_len(cps);
    var sb = _shabda_sb_new();
    var i = 0;
    var c = 0;
    var nx = 0;
    var tokslot = alloc(8);
    var consumed = 0;
    var last = 0;
    while (i < n) {
        c = vec_get(cps, i);
        # Negative number: '-' followed by a digit.
        if (c == 45 && i + 1 < n) {
            nx = vec_get(cps, i + 1);
            if (nx >= 48 && nx <= 57) {
                i = i + 1;
                consumed = _shabda_collect_number(cps, i, tokslot);
                last = _shabda_sb_last(sb);
                if (_shabda_sb_len(sb) != 0 && last != 32) {
                    _shabda_sb_push_byte(sb, 32);
                }
                _shabda_sb_push_cstr(sb, "negative ");
                _shabda_expand_number_token(sb, load64(tokslot));
                i = i + consumed;
                continue;
            }
        }
        if (c >= 48 && c <= 57) {
            consumed = _shabda_collect_number(cps, i, tokslot);
            last = _shabda_sb_last(sb);
            if (_shabda_sb_len(sb) != 0 && last != 32) {
                _shabda_sb_push_byte(sb, 32);
            }
            _shabda_expand_number_token(sb, load64(tokslot));
            i = i + consumed;
        } else {
            _shabda_sb_push_cp(sb, c);
            i = i + 1;
        }
    }
    return _shabda_sb_cstr(sb);
}

# ================================================================
# Abbreviation table + match_abbreviation. (Rust match_abbreviation)
# Ordered exactly as the Rust ABBREVIATIONS slice.
# ================================================================
fn _shabda_abbr_at(idx, out_expansion): cstring {
    # Returns the abbr cstr for index idx (or 0 past the end); writes expansion.
    if (idx == 0)  { store64(out_expansion, "approximately"); return "approx."; }
    if (idx == 1)  { store64(out_expansion, "boulevard");     return "blvd."; }
    if (idx == 2)  { store64(out_expansion, "captain");       return "capt."; }
    if (idx == 3)  { store64(out_expansion, "colonel");       return "col."; }
    if (idx == 4)  { store64(out_expansion, "corporation");   return "corp."; }
    if (idx == 5)  { store64(out_expansion, "department");    return "dept."; }
    if (idx == 6)  { store64(out_expansion, "government");     return "govt."; }
    if (idx == 7)  { store64(out_expansion, "professor");     return "prof."; }
    if (idx == 8)  { store64(out_expansion, "missus");        return "mrs."; }
    if (idx == 9)  { store64(out_expansion, "mister");        return "mr."; }
    if (idx == 10) { store64(out_expansion, "doctor");        return "dr."; }
    if (idx == 11) { store64(out_expansion, "senior");        return "sr."; }
    if (idx == 12) { store64(out_expansion, "junior");        return "jr."; }
    if (idx == 13) { store64(out_expansion, "saint");         return "st."; }
    if (idx == 14) { store64(out_expansion, "avenue");        return "ave."; }
    if (idx == 15) { store64(out_expansion, "et cetera");     return "etc."; }
    if (idx == 16) { store64(out_expansion, "versus");        return "vs."; }
    if (idx == 17) { store64(out_expansion, "incorporated");  return "inc."; }
    if (idx == 18) { store64(out_expansion, "limited");       return "ltd."; }
    if (idx == 19) { store64(out_expansion, "general");       return "gen."; }
    if (idx == 20) { store64(out_expansion, "sergeant");      return "sgt."; }
    if (idx == 21) { store64(out_expansion, "lieutenant");    return "lt."; }
    if (idx == 22) { store64(out_expansion, "point");         return "pt."; }
    if (idx == 23) { store64(out_expansion, "feet");          return "ft."; }
    if (idx == 24) { store64(out_expansion, "mount");         return "mt."; }
    store64(out_expansion, 0);
    return 0;
}

# Tries to match an abbreviation at the start of `text` (a cstr word).
# Returns bytes_consumed (>0) with *out_exp set to the expansion, or 0 = no match.
fn _shabda_match_abbreviation(text, out_exp): i64 {
    var lower = _shabda_lower_cstr(text);
    var idx = 0;
    var abbr = 0;
    var expslot = alloc(8);
    var alen = 0;
    var afterc = 0;
    abbr = _shabda_abbr_at(idx, expslot);
    while (abbr != 0) {
        if (_shabda_starts_with(lower, abbr) == 1) {
            alen = strlen(abbr);
            # after = text[abbr.len()..]; must be empty OR start with ws / non-alpha.
            afterc = load8(text + alen);
            if (afterc == 0) {
                store64(out_exp, load64(expslot));
                return alen;
            }
            # Decode the first code point after the abbreviation.
            var cpo = alloc(8);
            _shabda_utf8_next(text + alen, cpo);
            var cpa = load64(cpo);
            if (_shabda_is_ws(cpa) == 1 || _shabda_is_alpha(cpa) == 0) {
                store64(out_exp, load64(expslot));
                return alen;
            }
        }
        idx = idx + 1;
        abbr = _shabda_abbr_at(idx, expslot);
    }
    store64(out_exp, 0);
    return 0;
}

# ================================================================
# split_whitespace over a cstr -> vec of cstr words (Rust str::split_whitespace:
# collapses runs, drops leading/trailing ws, no empty tokens).
# ================================================================
fn _shabda_split_ws(text): i64 {
    var words = vec_new();
    var cps = _shabda_decode_cps(text);
    var n = vec_len(cps);
    var i = 0;
    var c = 0;
    var sb = 0;
    var inword = 0;
    while (i < n) {
        c = vec_get(cps, i);
        if (_shabda_is_ws(c) == 1) {
            if (inword == 1) {
                vec_push(words, _shabda_sb_cstr(sb));
                inword = 0;
            }
        } else {
            if (inword == 0) {
                sb = _shabda_sb_new();
                inword = 1;
            }
            _shabda_sb_push_cp(sb, c);
        }
        i = i + 1;
    }
    if (inword == 1) {
        vec_push(words, _shabda_sb_cstr(sb));
    }
    return words;
}

# ================================================================
# expand_abbreviations — public. (Rust expand_abbreviations)
# ================================================================
#must_use
fn shabda_expand_abbreviations(text): cstring {
    var words = _shabda_split_ws(text);
    var n = vec_len(words);
    var sb = _shabda_sb_new();
    var i = 0;
    var word = 0;
    var expslot = alloc(8);
    var consumed = 0;
    while (i < n) {
        if (i > 0) { _shabda_sb_push_byte(sb, 32); }
        word = vec_get(words, i);
        consumed = _shabda_match_abbreviation(word, expslot);
        if (consumed > 0) {
            _shabda_sb_push_cstr(sb, load64(expslot));
            # Append remaining bytes after the abbreviation: word[consumed..].
            _shabda_sb_push_cstr(sb, word + consumed);
        } else {
            _shabda_sb_push_cstr(sb, word);
        }
        i = i + 1;
    }
    return _shabda_sb_cstr(sb);
}

# ================================================================
# Acronyms. split_trailing_punct / is_acronym / is_pronounceable_acronym.
# ================================================================

# Splits trailing (non-alphanumeric) punctuation from a word. Writes the byte
# offset where trailing punct begins to *out_end (i.e. core = word[..end],
# trailing = word[end..]). (Rust split_trailing_punct)
fn _shabda_split_trailing_punct(word, out_end): i64 {
    # Decode into (cp, byte_offset) pairs, find the last run of non-alnum at the end.
    var cps = vec_new();
    var offs = vec_new();
    var p = word;
    var cpo = alloc(8);
    var adv = _shabda_utf8_next(p, cpo);
    var off = 0;
    while (adv > 0) {
        vec_push(cps, load64(cpo));
        vec_push(offs, off);
        off = off + adv;
        p = p + adv;
        adv = _shabda_utf8_next(p, cpo);
    }
    var total = off;
    var m = vec_len(cps);
    # Rust: char_indices().rev().take_while(!alnum).last().map(|(i,_)| i)
    #       .unwrap_or(word.len()). "end" = byte index of the FIRST char (scanning
    # from the tail) in the maximal trailing non-alnum run; if no trailing punct,
    # end = word.len().
    var end = total;
    var j = m - 1;
    var stop = 0;
    while (j >= 0 && stop == 0) {
        if (_shabda_is_alnum(vec_get(cps, j)) == 0) {
            end = vec_get(offs, j);
            j = j - 1;
        } else {
            stop = 1;
        }
    }
    store64(out_end, end);
    return 0;
}

# Returns 1 if `word` (cstr) is an acronym: 3..=5 ASCII-uppercase letters.
# NOTE: Rust checks len (byte length) in 3..=5; core is ASCII so byte==char count.
fn _shabda_is_acronym(word): i64 {
    var n = strlen(word);
    if (n < 3 || n > 5) { return 0; }
    var i = 0;
    var c = 0;
    while (i < n) {
        c = load8(word + i);
        if (c < 65 || c > 90) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _shabda_is_vowel(c): i64 {
    if (c == 97) { return 1; }
    if (c == 101) { return 1; }
    if (c == 105) { return 1; }
    if (c == 111) { return 1; }
    if (c == 117) { return 1; }
    return 0;
}

# Valid onset cluster check: is (a,b) in the Rust valid_onsets table?
fn _shabda_valid_onset(a, b): i64 {
    if (a == 98 && b == 108) { return 1; }  # bl
    if (a == 98 && b == 114) { return 1; }  # br
    if (a == 99 && b == 108) { return 1; }  # cl
    if (a == 99 && b == 114) { return 1; }  # cr
    if (a == 100 && b == 114) { return 1; } # dr
    if (a == 102 && b == 108) { return 1; } # fl
    if (a == 102 && b == 114) { return 1; } # fr
    if (a == 103 && b == 108) { return 1; } # gl
    if (a == 103 && b == 114) { return 1; } # gr
    if (a == 112 && b == 108) { return 1; } # pl
    if (a == 112 && b == 114) { return 1; } # pr
    if (a == 115 && b == 99)  { return 1; } # sc
    if (a == 115 && b == 107) { return 1; } # sk
    if (a == 115 && b == 108) { return 1; } # sl
    if (a == 115 && b == 109) { return 1; } # sm
    if (a == 115 && b == 110) { return 1; } # sn
    if (a == 115 && b == 112) { return 1; } # sp
    if (a == 115 && b == 116) { return 1; } # st
    if (a == 115 && b == 119) { return 1; } # sw
    if (a == 116 && b == 114) { return 1; } # tr
    if (a == 116 && b == 119) { return 1; } # tw
    if (a == 116 && b == 104) { return 1; } # th
    if (a == 115 && b == 104) { return 1; } # sh
    if (a == 99 && b == 104)  { return 1; } # ch
    if (a == 119 && b == 104) { return 1; } # wh
    return 0;
}

# Returns 1 if an acronym (cstr, ASCII upper) is pronounceable as a word.
# (Rust is_pronounceable_acronym) — operates on the lowercased chars.
fn _shabda_is_pronounceable_acronym(word): i64 {
    var lower = _shabda_lower_cstr(word);
    var n = strlen(lower);
    # Must have at least one vowel.
    var i = 0;
    var hasv = 0;
    while (i < n) {
        if (_shabda_is_vowel(load8(lower + i)) == 1) { hasv = 1; }
        i = i + 1;
    }
    if (hasv == 0) { return 0; }
    var c0 = 0;
    var c1 = 0;
    var c2 = 0;
    if (n >= 1) { c0 = load8(lower); }
    # Starts with vowel -> pronounceable.
    if (_shabda_is_vowel(c0) == 1) { return 1; }
    # single consonant + vowel.
    if (n >= 2) {
        c1 = load8(lower + 1);
        if (_shabda_is_vowel(c0) == 0 && _shabda_is_vowel(c1) == 1) { return 1; }
    }
    # valid onset cluster + vowel.
    if (n >= 3) {
        c1 = load8(lower + 1);
        c2 = load8(lower + 2);
        if (_shabda_is_vowel(c0) == 0 && _shabda_is_vowel(c1) == 0 && _shabda_is_vowel(c2) == 1) {
            if (_shabda_valid_onset(c0, c1) == 1) { return 1; }
        }
    }
    return 0;
}

# ================================================================
# expand_acronyms — public. (Rust expand_acronyms)
# ================================================================
#must_use
fn shabda_expand_acronyms(text): cstring {
    var words = _shabda_split_ws(text);
    var n = vec_len(words);
    var sb = _shabda_sb_new();
    var i = 0;
    var word = 0;
    var endslot = alloc(8);
    while (i < n) {
        if (i > 0) { _shabda_sb_push_byte(sb, 32); }
        word = vec_get(words, i);
        # Split trailing punct: core = word[..end], trailing = word[end..].
        _shabda_split_trailing_punct(word, endslot);
        var end = load64(endslot);
        var core = alloc(end + 1);
        memcpy(core, word, end);
        store8(core + end, 0);
        var trailing = word + end;

        if (_shabda_is_acronym(core) == 1) {
            if (_shabda_is_pronounceable_acronym(core) == 1) {
                # lowercase it as a word.
                var k = 0;
                var clen = strlen(core);
                var cc = 0;
                while (k < clen) {
                    cc = load8(core + k);
                    _shabda_sb_push_byte(sb, _shabda_to_lower_cp(cc));
                    k = k + 1;
                }
            } else {
                # spell out: "FBI" -> "f b i".
                var k2 = 0;
                var clen2 = strlen(core);
                var cc2 = 0;
                while (k2 < clen2) {
                    if (k2 > 0) { _shabda_sb_push_byte(sb, 32); }
                    cc2 = load8(core + k2);
                    _shabda_sb_push_byte(sb, _shabda_to_lower_cp(cc2));
                    k2 = k2 + 1;
                }
            }
            _shabda_sb_push_cstr(sb, trailing);
        } else {
            _shabda_sb_push_cstr(sb, word);
        }
        i = i + 1;
    }
    return _shabda_sb_cstr(sb);
}

# ================================================================
# is_foreign_word / is_latin_extended / strip_diacritics.
# ================================================================
fn _shabda_is_latin_extended(cp): i64 {
    if (cp >= 0x00C0 && cp <= 0x024F) { return 1; }
    return 0;
}

#must_use
fn shabda_is_foreign_word(word): i64 {
    var p = word;
    var cpo = alloc(8);
    var adv = _shabda_utf8_next(p, cpo);
    var cp = 0;
    while (adv > 0) {
        cp = load64(cpo);
        if (_shabda_is_alpha(cp) == 1 && _shabda_is_ascii_alpha(cp) == 0 && _shabda_is_latin_extended(cp) == 1) {
            return 1;
        }
        p = p + adv;
        adv = _shabda_utf8_next(p, cpo);
    }
    return 0;
}

# Map an accented code point to its ASCII base, or return it unchanged.
# (Rust strip_diacritics match arms.)
fn _shabda_strip_cp(cp): i64 {
    # a: á à â ä ã  = 0xE1 0xE0 0xE2 0xE4 0xE3
    if (cp == 0x00E1 || cp == 0x00E0 || cp == 0x00E2 || cp == 0x00E4 || cp == 0x00E3) { return 97; }
    # e: é è ê ë  = 0xE9 0xE8 0xEA 0xEB
    if (cp == 0x00E9 || cp == 0x00E8 || cp == 0x00EA || cp == 0x00EB) { return 101; }
    # i: í ì î ï  = 0xED 0xEC 0xEE 0xEF
    if (cp == 0x00ED || cp == 0x00EC || cp == 0x00EE || cp == 0x00EF) { return 105; }
    # o: ó ò ô ö õ = 0xF3 0xF2 0xF4 0xF6 0xF5
    if (cp == 0x00F3 || cp == 0x00F2 || cp == 0x00F4 || cp == 0x00F6 || cp == 0x00F5) { return 111; }
    # u: ú ù û ü  = 0xFA 0xF9 0xFB 0xFC
    if (cp == 0x00FA || cp == 0x00F9 || cp == 0x00FB || cp == 0x00FC) { return 117; }
    # ñ = 0xF1 -> n
    if (cp == 0x00F1) { return 110; }
    # ç = 0xE7 -> s
    if (cp == 0x00E7) { return 115; }
    return cp;
}

#must_use
fn shabda_strip_diacritics(word): cstring {
    var sb = _shabda_sb_new();
    var p = word;
    var cpo = alloc(8);
    var adv = _shabda_utf8_next(p, cpo);
    var cp = 0;
    while (adv > 0) {
        cp = load64(cpo);
        _shabda_sb_push_cp(sb, _shabda_strip_cp(cp));
        p = p + adv;
        adv = _shabda_utf8_next(p, cpo);
    }
    return _shabda_sb_cstr(sb);
}

# ================================================================
# normalize / normalize_token_into / normalize_with_emphasis.
# ================================================================

# Process a single token's code points into sb (Rust normalize_token_into).
fn _shabda_normalize_token_into(token, sb): i64 {
    var cps = _shabda_decode_cps(token);
    var n = vec_len(cps);
    var i = 0;
    var ch = 0;
    var prev_space = 0;
    var last = 0;
    while (i < n) {
        ch = vec_get(cps, i);
        if (_shabda_is_alpha(ch) == 1 || ch == 39 || ch == 45) {
            last = _shabda_sb_last(sb);
            if (prev_space == 1 && _shabda_sb_len(sb) != 0 && last != 32) {
                _shabda_sb_push_byte(sb, 32);
            }
            _shabda_sb_push_cp(sb, _shabda_to_lower_cp(ch));
            prev_space = 0;
        } elif (ch == 44) {
            _shabda_sb_push_cstr(sb, " ,pause");
            prev_space = 1;
        } elif (ch == 46 || ch == 59) {
            _shabda_sb_push_cstr(sb, " .pause");
            prev_space = 1;
        } elif (_shabda_is_ws(ch) == 1 || ch == 33 || ch == 63) {
            prev_space = 1;
        }
        i = i + 1;
    }
    return 0;
}

#must_use
fn shabda_normalize(text): cstring {
    var abbr = shabda_expand_abbreviations(text);
    var acro = shabda_expand_acronyms(abbr);
    var expanded = shabda_expand_numbers(acro);

    var cps = _shabda_decode_cps(expanded);
    var n = vec_len(cps);
    var sb = _shabda_sb_new();
    var i = 0;
    var ch = 0;
    var prev_space = 0;
    while (i < n) {
        ch = vec_get(cps, i);
        if (_shabda_is_alpha(ch) == 1 || ch == 39 || ch == 45) {
            if (prev_space == 1 && _shabda_sb_len(sb) != 0) {
                _shabda_sb_push_byte(sb, 32);
            }
            _shabda_sb_push_cp(sb, _shabda_to_lower_cp(ch));
            prev_space = 0;
        } elif (ch == 44) {
            _shabda_sb_push_cstr(sb, " ,pause");
            prev_space = 1;
        } elif (ch == 46 || ch == 59) {
            _shabda_sb_push_cstr(sb, " .pause");
            prev_space = 1;
        } elif (_shabda_is_ws(ch) == 1 || ch == 33 || ch == 63) {
            prev_space = 1;
        }
        i = i + 1;
    }
    return _shabda_sb_cstr(sb);
}

#must_use
fn shabda_normalize_with_emphasis(text): cstring {
    var abbr = shabda_expand_abbreviations(text);
    var expanded = shabda_expand_numbers(abbr);

    var tokens = _shabda_split_ws(expanded);
    var nt = vec_len(tokens);
    var sb = _shabda_sb_new();
    var i = 0;
    var token = 0;
    while (i < nt) {
        if (i > 0 && _shabda_sb_len(sb) != 0) {
            _shabda_sb_push_byte(sb, 32);
        }
        token = vec_get(tokens, i);
        var tlen = strlen(token);
        var handled = 0;

        # *asterisk-wrapped* emphasis: token.len() >= 3, starts+ends with '*'.
        if (tlen >= 3 && load8(token) == 42 && load8(token + tlen - 1) == 42) {
            # inner = token[1..len-1].
            var ilen = tlen - 2;
            var inner = alloc(ilen + 1);
            memcpy(inner, token + 1, ilen);
            store8(inner + ilen, 0);
            # inner non-empty and all chars alphabetic.
            var icps = _shabda_decode_cps(inner);
            var im = vec_len(icps);
            var allalpha = 1;
            var k = 0;
            while (k < im) {
                if (_shabda_is_alpha(vec_get(icps, k)) == 0) { allalpha = 0; }
                k = k + 1;
            }
            if (im > 0 && allalpha == 1) {
                _shabda_sb_push_cstr(sb, SHABDA_EMPHASIS_START);
                _shabda_sb_push_byte(sb, 32);
                var k2 = 0;
                while (k2 < im) {
                    _shabda_sb_push_cp(sb, _shabda_to_lower_cp(vec_get(icps, k2)));
                    k2 = k2 + 1;
                }
                _shabda_sb_push_byte(sb, 32);
                _shabda_sb_push_cstr(sb, SHABDA_EMPHASIS_END);
                handled = 1;
            }
        }

        # ALL-CAPS emphasis: >= 3 alphabetic chars, all uppercase.
        if (handled == 0) {
            var tcps = _shabda_decode_cps(token);
            var tm = vec_len(tcps);
            var alpha_count = 0;
            var all_upper = 1;
            var j = 0;
            var tc = 0;
            while (j < tm) {
                tc = vec_get(tcps, j);
                if (_shabda_is_alpha(tc) == 1) {
                    alpha_count = alpha_count + 1;
                    if (_shabda_is_upper(tc) == 0) { all_upper = 0; }
                }
                j = j + 1;
            }
            if (alpha_count >= 3 && all_upper == 1) {
                _shabda_sb_push_cstr(sb, SHABDA_EMPHASIS_START);
                _shabda_sb_push_byte(sb, 32);
                _shabda_normalize_token_into(token, sb);
                _shabda_sb_push_byte(sb, 32);
                _shabda_sb_push_cstr(sb, SHABDA_EMPHASIS_END);
                handled = 1;
            }
        }

        if (handled == 0) {
            _shabda_normalize_token_into(token, sb);
        }
        i = i + 1;
    }
    return _shabda_sb_cstr(sb);
}

# ================================================================
# detect_intonation — public. (Rust detect_intonation) Returns a SHABDA_STYPE_* tag.
# ================================================================
#must_use
fn shabda_detect_intonation(text): i64 {
    # trim_end: find last non-ws byte.
    var n = strlen(text);
    var end = n;
    var brk = 0;
    while (end > 0 && brk == 0) {
        var c = load8(text + end - 1);
        # ASCII ws only for trailing trim (Rust trim_end trims Unicode ws, but our
        # inputs use ASCII ws before the terminal '?'/'!').
        if (c == 32 || c == 9 || c == 10 || c == 13 || c == 12 || c == 11) {
            end = end - 1;
        } else {
            brk = 1;
        }
    }
    if (end == 0) { return SHABDA_STYPE_STATEMENT; }
    var lastc = load8(text + end - 1);
    if (lastc == 63) { return SHABDA_STYPE_QUESTION; }
    if (lastc == 33) { return SHABDA_STYPE_EXCLAMATION; }
    return SHABDA_STYPE_STATEMENT;
}

# ================================================================
# sentence_type alias — the spec lists shabda_sentence_type; it is the detector.
# ================================================================
#must_use
fn shabda_sentence_type(text): i64 {
    return shabda_detect_intonation(text);
}

# --- syllable.cyr ---

# syllable.cyr — syllabification of phoneme sequences (Maximal Onset Principle).
#
# Ports rust-old/src/syllable.rs. Splits a phoneme sequence into syllables using
# the Maximal Onset Principle with sonority-based constraints. Each syllable has
# an onset (consonants), a nucleus (vowel/diphthong), and a coda (consonants).
#
# DEP POSITION: svara only. The entry file includes svara.cyr (for
# svara_phoneme_class + SVARA_CLASS_VOWEL/DIPHTHONG + the SVARA_PH_* ordinals)
# and src/error.cyr ABOVE this module. Modules never include each other.
#
# Shabda Syllable layout (24 bytes):
#   [0]  onset   — vec of phoneme ordinals (i64)
#   [8]  nucleus — i64 phoneme ordinal
#   [16] coda    — vec of phoneme ordinals (i64)
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`/`Shabda`-prefixed (flat
# link namespace; coexists with shbdk_ / svara_ / varna / sakshi). Private
# helpers use a leading `_shabda_`.

var SHABDA_SYLLABLE_ONSET   = 0;
var SHABDA_SYLLABLE_NUCLEUS = 8;
var SHABDA_SYLLABLE_CODA    = 16;
var SHABDA_SYLLABLE_SIZE    = 24;

# ---- Syllable constructor / accessors ----------------------------------------
# Build a syllable from an onset vec, a nucleus ordinal, and a coda vec.
#must_use
fn shabda_syllable_new(onset, nucleus, coda): i64 {
    var s = alloc(SHABDA_SYLLABLE_SIZE);
    store64(s + SHABDA_SYLLABLE_ONSET, onset);
    store64(s + SHABDA_SYLLABLE_NUCLEUS, nucleus);
    store64(s + SHABDA_SYLLABLE_CODA, coda);
    return s;
}

#must_use
fn shabda_syllable_onset(s): i64 {
    return load64(s + SHABDA_SYLLABLE_ONSET);
}

#must_use
fn shabda_syllable_nucleus(s): i64 {
    return load64(s + SHABDA_SYLLABLE_NUCLEUS);
}

#must_use
fn shabda_syllable_coda(s): i64 {
    return load64(s + SHABDA_SYLLABLE_CODA);
}

# A syllable is "heavy" if it has a non-empty coda OR a diphthong nucleus.
# Heavy syllables attract stress in English.
#must_use
fn shabda_syllable_is_heavy(s): i64 {
    if (vec_len(load64(s + SHABDA_SYLLABLE_CODA)) > 0) { return 1; }
    if (svara_phoneme_class(load64(s + SHABDA_SYLLABLE_NUCLEUS)) == SVARA_CLASS_DIPHTHONG) {
        return 1;
    }
    return 0;
}

# All phonemes in this syllable (onset ++ [nucleus] ++ coda) as a fresh vec.
#must_use
fn shabda_syllable_phonemes(s): i64 {
    var out = vec_new();
    var onset = load64(s + SHABDA_SYLLABLE_ONSET);
    var coda = load64(s + SHABDA_SYLLABLE_CODA);
    var i = 0;
    var n = vec_len(onset);
    while (i < n) {
        vec_push(out, vec_get(onset, i));
        i = i + 1;
    }
    vec_push(out, load64(s + SHABDA_SYLLABLE_NUCLEUS));
    i = 0;
    n = vec_len(coda);
    while (i < n) {
        vec_push(out, vec_get(coda, i));
        i = i + 1;
    }
    return out;
}

# ---- Private helpers ---------------------------------------------------------
# True if a phoneme can serve as a syllable nucleus (Vowel or Diphthong).
fn _shabda_is_nucleus(ph): i64 {
    var c = svara_phoneme_class(ph);
    if (c == SVARA_CLASS_VOWEL) { return 1; }
    if (c == SVARA_CLASS_DIPHTHONG) { return 1; }
    return 0;
}

# Sonority level of a phoneme (higher = more sonorous).
#   Vowel/Diphthong = 6
#   ApproximantR/W/J = 5
#   LateralL = 4
#   NasalM/N/Ng = 3
#   FricativeF/V/S/Z/Sh/Zh/Th/Dh/H = 2
#   else (plosives, affricates, glottal stop, tap, ...) = 1
fn _shabda_sonority(ph): i64 {
    var c = svara_phoneme_class(ph);
    if (c == SVARA_CLASS_VOWEL) { return 6; }
    if (c == SVARA_CLASS_DIPHTHONG) { return 6; }
    if (ph == SVARA_PH_APPROX_R) { return 5; }
    if (ph == SVARA_PH_APPROX_W) { return 5; }
    if (ph == SVARA_PH_APPROX_J) { return 5; }
    if (ph == SVARA_PH_LATERAL_L) { return 4; }
    if (ph == SVARA_PH_NASAL_M) { return 3; }
    if (ph == SVARA_PH_NASAL_N) { return 3; }
    if (ph == SVARA_PH_NASAL_NG) { return 3; }
    if (ph == SVARA_PH_FRIC_F) { return 2; }
    if (ph == SVARA_PH_FRIC_V) { return 2; }
    if (ph == SVARA_PH_FRIC_S) { return 2; }
    if (ph == SVARA_PH_FRIC_Z) { return 2; }
    if (ph == SVARA_PH_FRIC_SH) { return 2; }
    if (ph == SVARA_PH_FRIC_ZH) { return 2; }
    if (ph == SVARA_PH_FRIC_TH) { return 2; }
    if (ph == SVARA_PH_FRIC_DH) { return 2; }
    if (ph == SVARA_PH_FRIC_H) { return 2; }
    return 1;
}

# Copy v[start..end] into a fresh vec (guarded: empty if start >= end).
fn _shabda_slice(v, start, end): i64 {
    var out = vec_new();
    var i = start;
    while (i < end) {
        vec_push(out, vec_get(v, i));
        i = i + 1;
    }
    return out;
}

# Checks if a consonant cluster (vec) is a legal English onset: sonority rises
# left-to-right. Exception: /s/ + plosive clusters (sp, st, sk, spl, spr, str,
# skr) where cluster[0] == FricativeS and sonority(next) <= 2.
fn _shabda_is_legal_onset(cluster): i64 {
    var len = vec_len(cluster);
    if (len == 0) { return 1; }
    if (len == 1) { return 1; }

    var first = vec_get(cluster, 0);
    var i = 1;
    while (i < len) {
        var son_cur = _shabda_sonority(vec_get(cluster, i));
        var son_prev = _shabda_sonority(vec_get(cluster, i - 1));
        if (son_cur <= son_prev) {
            # Exception: /s/ + plosive clusters.
            if (first == SVARA_PH_FRIC_S) {
                if (son_cur <= 2) {
                    i = i + 1;
                    continue;
                }
            }
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

# Maximum number of consonants from the END of a cluster (vec) that form a legal
# English onset (rising sonority toward the nucleus). Returns a count.
fn _shabda_max_legal_onset(cluster): i64 {
    var len = vec_len(cluster);
    if (len == 0) { return 0; }

    # Try from the full cluster down to 1 consonant.
    var start = 0;
    while (start < len) {
        var candidate = _shabda_slice(cluster, start, len);
        if (_shabda_is_legal_onset(candidate) == 1) {
            return len - start;
        }
        start = start + 1;
    }

    # Single consonant is always a legal onset.
    return 1;
}

# ---- Syllabification ---------------------------------------------------------
# Syllabify a phoneme sequence (vec of ordinals) using the Maximal Onset
# Principle. Returns a vec of Syllable*. Empty input -> empty vec; no vowels ->
# empty vec; else one syllable per nucleus.
#must_use
fn shabda_syllabify(phonemes): i64 {
    var out = vec_new();
    var n = vec_len(phonemes);
    if (n == 0) { return out; }

    # Find indices of all nuclei (vowels and diphthongs).
    var nuclei = vec_new();
    var i = 0;
    while (i < n) {
        if (_shabda_is_nucleus(vec_get(phonemes, i)) == 1) {
            vec_push(nuclei, i);
        }
        i = i + 1;
    }
    var nn = vec_len(nuclei);
    if (nn == 0) { return out; }

    var syl_idx = 0;
    while (syl_idx < nn) {
        var nucleus_idx = vec_get(nuclei, syl_idx);

        # onset_start
        var onset_start = 0;
        if (syl_idx == 0) {
            onset_start = 0;
        } else {
            var prev_nucleus = vec_get(nuclei, syl_idx - 1);
            var cluster_start = prev_nucleus + 1;
            var cluster = _shabda_slice(phonemes, cluster_start, nucleus_idx);
            var onset_len = _shabda_max_legal_onset(cluster);
            # PORT-RISK: nucleus_idx - onset_len must not go negative. The cluster
            # spans [cluster_start, nucleus_idx), so onset_len <= that span length,
            # which is <= nucleus_idx; guard anyway.
            if (nucleus_idx >= onset_len) {
                onset_start = nucleus_idx - onset_len;
            } else {
                onset_start = 0;
            }
        }

        var onset = _shabda_slice(phonemes, onset_start, nucleus_idx);
        var nucleus = vec_get(phonemes, nucleus_idx);

        # coda
        var coda = vec_new();
        if (syl_idx < nn - 1) {
            var next_nucleus = vec_get(nuclei, syl_idx + 1);
            var gap = _shabda_slice(phonemes, nucleus_idx + 1, next_nucleus);
            var next_onset_len = _shabda_max_legal_onset(gap);
            # PORT-RISK: next_nucleus - next_onset_len must not go negative. The
            # gap spans [nucleus_idx+1, next_nucleus); next_onset_len <= gap len,
            # so next_nucleus - next_onset_len >= nucleus_idx+1; guard anyway.
            var coda_end = next_nucleus;
            if (next_nucleus >= next_onset_len) {
                coda_end = next_nucleus - next_onset_len;
            } else {
                coda_end = nucleus_idx + 1;
            }
            coda = _shabda_slice(phonemes, nucleus_idx + 1, coda_end);
        } else {
            coda = _shabda_slice(phonemes, nucleus_idx + 1, n);
        }

        vec_push(out, shabda_syllable_new(onset, nucleus, coda));
        syl_idx = syl_idx + 1;
    }

    return out;
}

# --- heteronym.cyr ---

# heteronym.cyr — heteronym disambiguation via preceding-word context.
#
# Ports rust-old/src/heteronym.rs. Heteronyms are words spelled the same but
# pronounced differently by meaning/part-of-speech ("read" /riːd/ vs /rɛd/).
# Heuristic: if a trigger word appears in the last <=3 preceding words, pick the
# context (non-default) variant; else the default variant.
#
# Depends on svara (phoneme ordinals) + shabdakosh (Pronunciation = a struct
# whose phonemes are a vec of svara ordinals, read via shbdk_pronunciation_phonemes).
# Include position: after src/error.cyr, after the vendored dep chain
# (hisab/goonj/naad/svara/varna/shabdakosh). Modules never include each other.
#
# Rust `struct HeteronymRule { word:&'static str, default_variant:usize,
# context_variant:usize, triggers:&'static [&'static str] }` → an alloc'd block.
#
# HeteronymRule layout (32 bytes):
#   [0]  word            (cstr)
#   [8]  default_variant (i64 index)
#   [16] context_variant (i64 index)
#   [24] triggers        (vec of cstr)
#
# The rule table (Rust's `static HETERONYMS`) is built once via a cached
# lazy-init fn _shabda_het_rules() returning a vec of HeteronymRule*.
#
# The serde twin `HeteronymRuleOwned` (Serialize/Deserialize/PartialEq) has no
# distinct heap shape here — a HeteronymRule already owns cstr/vec fields, so the
# "owned" clone is shabda_heteronym_rule_clone (deep copy) and PartialEq is
# shabda_heteronym_rule_eq (struct-field equality). Their roundtrip lives in the
# test file.
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`/`Shabda`-prefixed.

# ================================================================
# HeteronymRule layout constants.
# ================================================================
var SHABDA_HET_WORD    = 0;
var SHABDA_HET_DEFAULT = 8;
var SHABDA_HET_CONTEXT = 16;
var SHABDA_HET_TRIGGERS = 24;
var SHABDA_HET_SIZE    = 32;

# ================================================================
# Constructor + accessors.
# ================================================================
#must_use
fn shabda_heteronym_rule_new(word, default_variant, context_variant, triggers): i64 {
    var r = alloc(SHABDA_HET_SIZE);
    store64(r + SHABDA_HET_WORD, word);
    store64(r + SHABDA_HET_DEFAULT, default_variant);
    store64(r + SHABDA_HET_CONTEXT, context_variant);
    store64(r + SHABDA_HET_TRIGGERS, triggers);
    return r;
}

#must_use
fn shabda_heteronym_rule_word(r): cstring {
    return load64(r + SHABDA_HET_WORD);
}

#must_use
fn shabda_heteronym_rule_default_variant(r): i64 {
    return load64(r + SHABDA_HET_DEFAULT);
}

#must_use
fn shabda_heteronym_rule_context_variant(r): i64 {
    return load64(r + SHABDA_HET_CONTEXT);
}

#must_use
fn shabda_heteronym_rule_triggers(r): i64 {
    return load64(r + SHABDA_HET_TRIGGERS);
}

# Small helper: build a vec of cstr from a NUL-terminated-list is awkward; instead
# each rule's trigger list is built explicitly in the table init below.

# ================================================================
# Serde twin: HeteronymRuleOwned → a deep clone + struct-field equality.
# clone: fresh block, fresh triggers vec (same cstr contents; cstrs are static).
# ================================================================
#must_use
fn shabda_heteronym_rule_clone(r): i64 {
    var trig = load64(r + SHABDA_HET_TRIGGERS);
    var out_trig = vec_new();
    var i = 0;
    var n = vec_len(trig);
    while (i < n) {
        vec_push(out_trig, vec_get(trig, i));
        i = i + 1;
    }
    return shabda_heteronym_rule_new(
        load64(r + SHABDA_HET_WORD),
        load64(r + SHABDA_HET_DEFAULT),
        load64(r + SHABDA_HET_CONTEXT),
        out_trig);
}

# PartialEq — every field equal (word cstr, both indices, trigger cstr lists).
#must_use
fn shabda_heteronym_rule_eq(a, b): i64 {
    if (streq(load64(a + SHABDA_HET_WORD), load64(b + SHABDA_HET_WORD)) == 0) { return 0; }
    if (load64(a + SHABDA_HET_DEFAULT) != load64(b + SHABDA_HET_DEFAULT)) { return 0; }
    if (load64(a + SHABDA_HET_CONTEXT) != load64(b + SHABDA_HET_CONTEXT)) { return 0; }
    var ta = load64(a + SHABDA_HET_TRIGGERS);
    var tb = load64(b + SHABDA_HET_TRIGGERS);
    if (vec_len(ta) != vec_len(tb)) { return 0; }
    var i = 0;
    var n = vec_len(ta);
    while (i < n) {
        if (streq(vec_get(ta, i), vec_get(tb, i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ================================================================
# Heteronym table — Rust's `static HETERONYMS`. Built once, cached.
#
# Convention: variant 0 = default/most-common; variant 1 = context-triggered.
# ================================================================
var _SHABDA_HET_TABLE = 0;

# Build a vec of cstr triggers from a helper; each call takes the words inline.
# (No variadic; we push in the table builder directly.)

fn _shabda_het_build(): i64 {
    var rules = vec_new();

    # read: default = past /rɛd/, triggers = present /riːd/
    var t_read = vec_new();
    vec_push(t_read, "to");     vec_push(t_read, "will");   vec_push(t_read, "can");
    vec_push(t_read, "could");  vec_push(t_read, "should"); vec_push(t_read, "would");
    vec_push(t_read, "may");    vec_push(t_read, "might");  vec_push(t_read, "must");
    vec_push(t_read, "please"); vec_push(t_read, "let's");  vec_push(t_read, "shall");
    vec_push(rules, shabda_heteronym_rule_new("read", 0, 1, t_read));

    # lead: default = metal /lɛd/, triggers = verb /liːd/
    var t_lead = vec_new();
    vec_push(t_lead, "to");     vec_push(t_lead, "will");   vec_push(t_lead, "can");
    vec_push(t_lead, "could");  vec_push(t_lead, "should"); vec_push(t_lead, "would");
    vec_push(t_lead, "may");    vec_push(t_lead, "might");  vec_push(t_lead, "must");
    vec_push(t_lead, "shall");
    vec_push(rules, shabda_heteronym_rule_new("lead", 0, 1, t_lead));

    # live: default = verb /lɪv/, triggers = adjective /laɪv/
    var t_live = vec_new();
    vec_push(t_live, "a");    vec_push(t_live, "the");  vec_push(t_live, "is");
    vec_push(t_live, "was");  vec_push(t_live, "go");   vec_push(t_live, "went");
    vec_push(t_live, "broadcast"); vec_push(t_live, "on");
    vec_push(rules, shabda_heteronym_rule_new("live", 0, 1, t_live));

    # wind: default = air /wɪnd/, triggers = verb /waɪnd/
    var t_wind = vec_new();
    vec_push(t_wind, "to");    vec_push(t_wind, "will");  vec_push(t_wind, "can");
    vec_push(t_wind, "could"); vec_push(t_wind, "should"); vec_push(t_wind, "would");
    vec_push(t_wind, "must");
    vec_push(rules, shabda_heteronym_rule_new("wind", 0, 1, t_wind));

    # tear: default = eye /tɪər/, triggers = rip /tɛər/
    var t_tear = vec_new();
    vec_push(t_tear, "to");    vec_push(t_tear, "will");  vec_push(t_tear, "can");
    vec_push(t_tear, "could"); vec_push(t_tear, "don't"); vec_push(t_tear, "didn't");
    vec_push(rules, shabda_heteronym_rule_new("tear", 0, 1, t_tear));

    # bow: default = weapon /boʊ/, triggers = bend /baʊ/
    var t_bow = vec_new();
    vec_push(t_bow, "to");   vec_push(t_bow, "will"); vec_push(t_bow, "take");
    vec_push(t_bow, "took"); vec_push(t_bow, "a");
    vec_push(rules, shabda_heteronym_rule_new("bow", 0, 1, t_bow));

    # close: default = verb /kloʊz/, triggers = adjective /kloʊs/
    var t_close = vec_new();
    vec_push(t_close, "a");   vec_push(t_close, "the"); vec_push(t_close, "too");
    vec_push(t_close, "very"); vec_push(t_close, "so"); vec_push(t_close, "how");
    vec_push(t_close, "is");  vec_push(t_close, "was"); vec_push(t_close, "get");
    vec_push(rules, shabda_heteronym_rule_new("close", 0, 1, t_close));

    # record: default = noun /rɛkərd/, triggers = verb /rɪkɔːrd/
    var t_record = vec_new();
    vec_push(t_record, "to");     vec_push(t_record, "will");   vec_push(t_record, "can");
    vec_push(t_record, "could");  vec_push(t_record, "should"); vec_push(t_record, "would");
    vec_push(t_record, "must");   vec_push(t_record, "please");
    vec_push(rules, shabda_heteronym_rule_new("record", 0, 1, t_record));

    # present: default = noun /prɛzənt/, triggers = verb /prɪzɛnt/
    var t_present = vec_new();
    vec_push(t_present, "to");     vec_push(t_present, "will");   vec_push(t_present, "can");
    vec_push(t_present, "could");  vec_push(t_present, "should"); vec_push(t_present, "would");
    vec_push(t_present, "must");   vec_push(t_present, "shall");
    vec_push(rules, shabda_heteronym_rule_new("present", 0, 1, t_present));

    # refuse: default = noun /rɛfjuːs/, triggers = verb /rɪfjuːz/
    var t_refuse = vec_new();
    vec_push(t_refuse, "to");     vec_push(t_refuse, "will");   vec_push(t_refuse, "can");
    vec_push(t_refuse, "could");  vec_push(t_refuse, "should"); vec_push(t_refuse, "would");
    vec_push(t_refuse, "must");   vec_push(t_refuse, "i");
    vec_push(rules, shabda_heteronym_rule_new("refuse", 0, 1, t_refuse));

    # produce: default = noun /proʊduːs/, triggers = verb /prədjuːs/
    var t_produce = vec_new();
    vec_push(t_produce, "to");     vec_push(t_produce, "will");   vec_push(t_produce, "can");
    vec_push(t_produce, "could");  vec_push(t_produce, "should"); vec_push(t_produce, "would");
    vec_push(t_produce, "must");
    vec_push(rules, shabda_heteronym_rule_new("produce", 0, 1, t_produce));

    # object: default = noun /ɒbdʒɛkt/, triggers = verb /əbdʒɛkt/
    var t_object = vec_new();
    vec_push(t_object, "to");     vec_push(t_object, "will");   vec_push(t_object, "can");
    vec_push(t_object, "could");  vec_push(t_object, "should"); vec_push(t_object, "would");
    vec_push(t_object, "must");   vec_push(t_object, "i");      vec_push(t_object, "we");
    vec_push(t_object, "they");
    vec_push(rules, shabda_heteronym_rule_new("object", 0, 1, t_object));

    # project: default = noun /prɒdʒɛkt/, triggers = verb /prədʒɛkt/
    var t_project = vec_new();
    vec_push(t_project, "to");     vec_push(t_project, "will");   vec_push(t_project, "can");
    vec_push(t_project, "could");  vec_push(t_project, "should"); vec_push(t_project, "would");
    vec_push(t_project, "must");
    vec_push(rules, shabda_heteronym_rule_new("project", 0, 1, t_project));

    # permit: default = noun /pɜːrmɪt/, triggers = verb /pərmɪt/
    var t_permit = vec_new();
    vec_push(t_permit, "to");     vec_push(t_permit, "will");   vec_push(t_permit, "can");
    vec_push(t_permit, "could");  vec_push(t_permit, "should"); vec_push(t_permit, "would");
    vec_push(t_permit, "must");   vec_push(t_permit, "not");
    vec_push(rules, shabda_heteronym_rule_new("permit", 0, 1, t_permit));

    # desert: default = noun /dɛzərt/, triggers = verb /dɪzɜːrt/
    var t_desert = vec_new();
    vec_push(t_desert, "to");     vec_push(t_desert, "will");   vec_push(t_desert, "can");
    vec_push(t_desert, "could");  vec_push(t_desert, "should"); vec_push(t_desert, "would");
    vec_push(t_desert, "must");   vec_push(t_desert, "don't");
    vec_push(rules, shabda_heteronym_rule_new("desert", 0, 1, t_desert));

    # minute: default = time /mɪnɪt/, triggers = adjective /maɪnjuːt/
    var t_minute = vec_new();
    vec_push(t_minute, "a");   vec_push(t_minute, "the");  vec_push(t_minute, "very");
    vec_push(t_minute, "most"); vec_push(t_minute, "so");  vec_push(t_minute, "how");
    vec_push(t_minute, "extremely");
    vec_push(rules, shabda_heteronym_rule_new("minute", 0, 1, t_minute));

    # bass: default = music /beɪs/, triggers = fish /bæs/
    var t_bass = vec_new();
    vec_push(t_bass, "a");     vec_push(t_bass, "the");    vec_push(t_bass, "caught");
    vec_push(t_bass, "fishing"); vec_push(t_bass, "lake"); vec_push(t_bass, "sea");
    vec_push(t_bass, "striped"); vec_push(t_bass, "largemouth");
    vec_push(rules, shabda_heteronym_rule_new("bass", 0, 1, t_bass));

    # wound: default = injury /wuːnd/, triggers = past of wind /waʊnd/
    var t_wound = vec_new();
    vec_push(t_wound, "he");  vec_push(t_wound, "she"); vec_push(t_wound, "they");
    vec_push(t_wound, "i");   vec_push(t_wound, "we");  vec_push(t_wound, "had");
    vec_push(t_wound, "was"); vec_push(t_wound, "were");
    vec_push(rules, shabda_heteronym_rule_new("wound", 0, 1, t_wound));

    # dove: default = bird /dʌv/, triggers = past of dive /doʊv/
    var t_dove = vec_new();
    vec_push(t_dove, "he");  vec_push(t_dove, "she"); vec_push(t_dove, "they");
    vec_push(t_dove, "i");   vec_push(t_dove, "we");  vec_push(t_dove, "then");
    vec_push(t_dove, "and");
    vec_push(rules, shabda_heteronym_rule_new("dove", 0, 1, t_dove));

    # sow: default = verb plant /soʊ/, triggers = female pig /saʊ/
    var t_sow = vec_new();
    vec_push(t_sow, "a");   vec_push(t_sow, "the"); vec_push(t_sow, "old");
    vec_push(t_sow, "fat");
    vec_push(rules, shabda_heteronym_rule_new("sow", 0, 1, t_sow));

    return rules;
}

# Cached lazy-init accessor for the rule table (vec of HeteronymRule*).
#must_use
fn _shabda_het_rules(): i64 {
    if (_SHABDA_HET_TABLE == 0) {
        _SHABDA_HET_TABLE = _shabda_het_build();
    }
    return _SHABDA_HET_TABLE;
}

# ================================================================
# lookup(word) -> rule* | 0  (Rust Option::None → 0).
# ================================================================
#must_use
fn shabda_heteronym_lookup(word): i64 {
    var rules = _shabda_het_rules();
    var i = 0;
    var n = vec_len(rules);
    while (i < n) {
        var r = vec_get(rules, i);
        if (streq(load64(r + SHABDA_HET_WORD), word) == 1) {
            return r;
        }
        i = i + 1;
    }
    return 0;
}

# 1 if `word` (cstr) is present in the trigger vec, else 0.
#must_use
fn _shabda_het_triggers_contain(triggers, word): i64 {
    var i = 0;
    var n = vec_len(triggers);
    while (i < n) {
        if (streq(vec_get(triggers, i), word) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# select_variant(rule, preceding_words) -> variant index.
#
# Rust: scan the LAST <=3 preceding words (reverse .take(3)), lowercased; if any
# matches a trigger, return context_variant, else default_variant.
# preceding_words is a vec of cstr.
# ================================================================
#must_use
fn shabda_select_variant(rule, preceding_words): i64 {
    var triggers = load64(rule + SHABDA_HET_TRIGGERS);
    var len = vec_len(preceding_words);
    # last <=3, iterated from the nearest preceding word backwards
    var count = 0;
    var i = len - 1;
    while (i >= 0) {
        if (count >= 3) { return load64(rule + SHABDA_HET_DEFAULT); }
        var lower = str_lower_cstr(vec_get(preceding_words, i));
        if (_shabda_het_triggers_contain(triggers, lower) == 1) {
            return load64(rule + SHABDA_HET_CONTEXT);
        }
        count = count + 1;
        i = i - 1;
    }
    return load64(rule + SHABDA_HET_DEFAULT);
}

# ================================================================
# select_phonemes(rule, preceding_words, pronunciations) -> phonemes vec.
#
# pronunciations = a vec of shabdakosh Pronunciation* (each read via
# shbdk_pronunciation_phonemes). Bounds-checked: if the selected variant index is
# out of range, fall back to pronunciations[0] (matches Rust).
# ================================================================
#must_use
fn shabda_select_phonemes(rule, preceding_words, pronunciations): i64 {
    var idx = shabda_select_variant(rule, preceding_words);
    if (idx < vec_len(pronunciations)) {
        return shbdk_pronunciation_phonemes(vec_get(pronunciations, idx));
    }
    return shbdk_pronunciation_phonemes(vec_get(pronunciations, 0));
}

# --- ssml.cyr ---

# ssml.cyr — SSML subset parser for speech synthesis markup.
#
# Ports rust-old/src/ssml.rs (the hand-rolled, no_std+alloc SSML subset parser —
# no XML crate). Parses <speak>/<break>/<emphasis>/<prosody>/<phoneme> into a
# flat vec of SsmlNode heap blocks. Self-contained: the Rust module's only dep is
# serde; here the codec is hand-written integer/tag round-trips (§ serde below).
#
# DEP POSITION: needs only src/error.cyr (L0) above it, plus the stdlib string/
# str/vec/math/alloc modules (auto-resolved from cyrius.cyml). Modules never
# include each other — the entry file (src/main.cyr / tests/ssml.tcyr) orders the
# includes.
#
# The parser walks the raw input cstring by BYTE INDEX exactly like the Rust
# (`input.as_bytes()[pos]`), so all offset arithmetic stays valid. '<' == 60,
# '>' == 62, '/' == 47.
#
# ---------------------------------------------------------------- byte layouts
# SsmlNode = a tagged heap block. Word [0] is the tag; payload follows.
#   Text     : alloc(16)  [0]=SHABDA_SSML_TEXT     [8]=text (Str fat pointer)
#   Break    : alloc(16)  [0]=SHABDA_SSML_BREAK    [8]=duration_ms (i64)
#   Emphasis : alloc(24)  [0]=SHABDA_SSML_EMPHASIS [8]=level (EmphasisLevel tag)
#                                                  [16]=children (vec of SsmlNode*)
#   Prosody  : alloc(24)  [0]=SHABDA_SSML_PROSODY  [8]=rate (SpeakingRate tag or
#                                                       SHABDA_RATE_NONE sentinel)
#                                                  [16]=children (vec of SsmlNode*)
# Text payload is a Str (str.cyr fat pointer {data,len}); str_cstr() yields a cstr
# for assert_streq. EmphasisLevel + SpeakingRate are Rust Copy enums -> int tags.
# Option<SpeakingRate> -> SHABDA_RATE_NONE (== -1) sentinel in the rate slot.
#
# shabda_ssml_parse(input) -> vec of SsmlNode* | 0 on parse error (Rust's Err).
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`/`Shabda`-prefixed (flat
# link namespace; coexists with shbdk_ / svara_ / varna / sakshi).

# ================================================================
# Node tags (was `enum SsmlNode`, #[non_exhaustive]). Stored at block offset 0.
# ================================================================
var SHABDA_SSML_TEXT     = 0;
var SHABDA_SSML_BREAK    = 1;
var SHABDA_SSML_EMPHASIS = 2;
var SHABDA_SSML_PROSODY  = 3;

# Node block offsets.
var SHABDA_SSML_OFF_TAG      = 0;
var SHABDA_SSML_OFF_TEXT     = 8;    # Text: Str payload
var SHABDA_SSML_OFF_DURATION = 8;    # Break: duration_ms
var SHABDA_SSML_OFF_LEVEL    = 8;    # Emphasis: level tag
var SHABDA_SSML_OFF_RATE     = 8;    # Prosody: rate tag/sentinel
var SHABDA_SSML_OFF_CHILDREN = 16;   # Emphasis/Prosody: children vec

# EmphasisLevel (was `enum EmphasisLevel`, #[non_exhaustive], Copy). Int tags.
var SHABDA_EMPH_STRONG   = 0;
var SHABDA_EMPH_MODERATE = 1;
var SHABDA_EMPH_REDUCED  = 2;

# SpeakingRate (was `enum SpeakingRate`, #[non_exhaustive], Copy). Int tags.
var SHABDA_RATE_XSLOW  = 0;
var SHABDA_RATE_SLOW   = 1;
var SHABDA_RATE_MEDIUM = 2;
var SHABDA_RATE_FAST   = 3;
var SHABDA_RATE_XFAST  = 4;
# Option<SpeakingRate>::None sentinel (Rust `rate: Option<SpeakingRate>`).
var SHABDA_RATE_NONE = (0 - 1);

# ================================================================
# SpeakingRate::wpm — approximate words-per-minute. Rust returns f32; promoted to
# f64 (math is f64-only). Values match ssml.rs EXACTLY: 75/100/150/200/250.
# Returns an f64 bit pattern.
# ================================================================
#must_use
fn shabda_speaking_rate_wpm(rate): i64 {
    if (rate == SHABDA_RATE_XSLOW)  { return f64_from(75); }
    if (rate == SHABDA_RATE_SLOW)   { return f64_from(100); }
    if (rate == SHABDA_RATE_MEDIUM) { return f64_from(150); }
    if (rate == SHABDA_RATE_FAST)   { return f64_from(200); }
    if (rate == SHABDA_RATE_XFAST)  { return f64_from(250); }
    return f64_from(0);              # #[non_exhaustive] fallback
}

# ================================================================
# Node constructors.
# ================================================================
#must_use
fn shabda_ssml_text(text_str): i64 {
    var p = alloc(16);
    store64(p + SHABDA_SSML_OFF_TAG, SHABDA_SSML_TEXT);
    store64(p + SHABDA_SSML_OFF_TEXT, text_str);
    return p;
}

#must_use
fn shabda_ssml_break(duration_ms): i64 {
    var p = alloc(16);
    store64(p + SHABDA_SSML_OFF_TAG, SHABDA_SSML_BREAK);
    store64(p + SHABDA_SSML_OFF_DURATION, duration_ms);
    return p;
}

#must_use
fn shabda_ssml_emphasis(level, children): i64 {
    var p = alloc(24);
    store64(p + SHABDA_SSML_OFF_TAG, SHABDA_SSML_EMPHASIS);
    store64(p + SHABDA_SSML_OFF_LEVEL, level);
    store64(p + SHABDA_SSML_OFF_CHILDREN, children);
    return p;
}

#must_use
fn shabda_ssml_prosody(rate, children): i64 {
    var p = alloc(24);
    store64(p + SHABDA_SSML_OFF_TAG, SHABDA_SSML_PROSODY);
    store64(p + SHABDA_SSML_OFF_RATE, rate);
    store64(p + SHABDA_SSML_OFF_CHILDREN, children);
    return p;
}

# ================================================================
# Node accessors.
# ================================================================
#must_use
fn shabda_ssml_node_tag(node): i64 { return load64(node + SHABDA_SSML_OFF_TAG); }

#must_use
fn shabda_ssml_node_text(node): i64 { return load64(node + SHABDA_SSML_OFF_TEXT); }

#must_use
fn shabda_ssml_node_duration(node): i64 { return load64(node + SHABDA_SSML_OFF_DURATION); }

#must_use
fn shabda_ssml_node_level(node): i64 { return load64(node + SHABDA_SSML_OFF_LEVEL); }

#must_use
fn shabda_ssml_node_rate(node): i64 { return load64(node + SHABDA_SSML_OFF_RATE); }

#must_use
fn shabda_ssml_node_children(node): i64 { return load64(node + SHABDA_SSML_OFF_CHILDREN); }

# ================================================================
# Byte-scan primitives (over a raw cstring, mirroring `input.as_bytes()`).
# ================================================================
# ASCII whitespace test (Rust char::is_whitespace, ASCII subset the parser hits):
# space, tab, newline, carriage return, form feed, vertical tab.
#must_use
fn _shabda_ssml_is_ws(c): i64 {
    if (c == 32)  { return 1; }
    if (c == 9)   { return 1; }
    if (c == 10)  { return 1; }
    if (c == 13)  { return 1; }
    if (c == 12)  { return 1; }
    if (c == 11)  { return 1; }
    return 0;
}

# find_tag_end: index of the '>' closing the tag starting at `pos` ('<'),
# scanning from pos+1. Returns -1 when none (Rust's Option::None).
#must_use
fn _shabda_find_tag_end(input, len, pos): i64 {
    var i = pos + 1;
    while (i < len) {
        if (load8(input + i) == 62) { return i; }   # '>'
        i = i + 1;
    }
    return (0 - 1);
}

# Byte-compare bytes[a_off..a_off+n] against cstring `lit` (which must be exactly
# n long). 1 if equal.
#must_use
fn _shabda_slice_eq_cstr(input, a_off, n, lit): i64 {
    var i = 0;
    while (i < n) {
        if (load8(lit + i) == 0) { return 0; }
        if (load8(input + a_off + i) != load8(lit + i)) { return 0; }
        i = i + 1;
    }
    if (load8(lit + n) != 0) { return 0; }
    return 1;
}

# Does bytes[off..] start with cstring `lit`? (Rust str::starts_with)
#must_use
fn _shabda_ssml_starts_with(input, len, off, lit): i64 {
    var i = 0;
    while (load8(lit + i) != 0) {
        if (off + i >= len) { return 0; }
        if (load8(input + off + i) != load8(lit + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ================================================================
# Attribute extraction (was extract_attr). Scans the tag's attribute region
# [attr_start, attr_end) inside `input` for `name="..."` OR `name='...'`, and
# copies the value into a fresh Str. Returns the Str, or 0 (Rust None).
# Byte-index slicing offsets stay valid throughout.
# ================================================================
#must_use
fn _shabda_extract_attr(input, attr_start, attr_end, name): i64 {
    # Try double quote first, then single quote (Rust order).
    var q = 34;                                  # '"'
    var pass = 0;
    while (pass < 2) {
        # Scan for `name` followed by '=' followed by the quote char q.
        var i = attr_start;
        while (i < attr_end) {
            # match `name` at i?
            var nlen = strlen(name);
            var matched = 0;
            if (i + nlen < attr_end + 1) {
                matched = _shabda_slice_eq_at(input, i, name, nlen);
            }
            if (matched == 1) {
                var eq = i + nlen;
                if (eq + 1 < attr_end + 1) {
                    if (load8(input + eq) == 61 && load8(input + eq + 1) == q) {
                        var vstart = eq + 2;
                        # Find closing quote.
                        var j = vstart;
                        while (j < attr_end) {
                            if (load8(input + j) == q) {
                                return str_from_buf(input + vstart, j - vstart);
                            }
                            j = j + 1;
                        }
                    }
                }
            }
            i = i + 1;
        }
        q = 39;                                  # '\''
        pass = pass + 1;
    }
    return 0;
}

# bytes[off..off+n] == name[0..n], not requiring name to terminate (used inside
# extract_attr where name is followed by '=').
#must_use
fn _shabda_slice_eq_at(input, off, name, n): i64 {
    var i = 0;
    while (i < n) {
        if (load8(input + off + i) != load8(name + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ================================================================
# Tag-name split (was split_tag_name): given the tag-content region
# [start, end) inside `input`, return the length of the leading tag name (up to
# the first whitespace); the attrs region is then [start+name_len, end) trimmed.
# ================================================================
#must_use
fn _shabda_tag_name_len(input, start, end): i64 {
    var i = start;
    while (i < end) {
        if (_shabda_ssml_is_ws(load8(input + i)) == 1) { return i - start; }
        i = i + 1;
    }
    return end - start;
}

# Compare the tag name region [start, start+n) to cstring `lit` (exact).
#must_use
fn _shabda_name_eq(input, start, n, lit): i64 {
    return _shabda_slice_eq_cstr(input, start, n, lit);
}

# ================================================================
# break duration parsing (was parse_break_duration). Packs a status+value: on
# success returns duration_ms >= 0; on error returns SHABDA_SSML_PARSE_ERR.
# attrs region is [astart, aend).
# ================================================================
var SHABDA_SSML_PARSE_ERR = (0 - 1);

#must_use
fn _shabda_parse_break_duration(input, astart, aend): i64 {
    var time_str = _shabda_extract_attr(input, astart, aend, "time");
    if (time_str != 0) {
        var tcstr = str_cstr(time_str);
        var tlen = strlen(tcstr);
        # strip_suffix("ms")
        if (tlen >= 2 && load8(tcstr + tlen - 2) == 109 && load8(tcstr + tlen - 1) == 115) {
            # ms_str = tcstr[..tlen-2]; parse::<u32>. Must be all digits.
            if (_shabda_all_digits(tcstr, tlen - 2) == 1) {
                return _shabda_atoi_n(tcstr, tlen - 2);
            }
            return SHABDA_SSML_PARSE_ERR;        # invalid break time
        }
        # strip_suffix('s')
        if (tlen >= 1 && load8(tcstr + tlen - 1) == 115) {
            # s_str = tcstr[..tlen-1]; parse::<f32>. (secs * 1000.0) as u32.
            var sbuf = alloc(tlen);
            memcpy(sbuf, tcstr, tlen - 1);
            store8(sbuf + tlen - 1, 0);
            var fout = alloc(8);
            var ok = f64_parse_ok(sbuf, fout);
            if (ok == 0) { return SHABDA_SSML_PARSE_ERR; }
            var secs = load64(fout);
            var ms = f64_to(f64_mul(secs, f64_from(1000)));
            return ms;
        }
        # unknown time unit
        return SHABDA_SSML_PARSE_ERR;
    }
    var strength = _shabda_extract_attr(input, astart, aend, "strength");
    if (strength != 0) {
        var scstr = str_cstr(strength);
        if (streq(scstr, "none") == 1)     { return 0; }
        if (streq(scstr, "x-weak") == 1)   { return 100; }
        if (streq(scstr, "weak") == 1)     { return 200; }
        if (streq(scstr, "medium") == 1)   { return 400; }
        if (streq(scstr, "strong") == 1)   { return 600; }
        if (streq(scstr, "x-strong") == 1) { return 1000; }
        return 300;
    }
    return 300;                                  # default break duration
}

# All of the first n bytes of cstr are ASCII digits (n>0 required for validity).
#must_use
fn _shabda_all_digits(s, n): i64 {
    if (n <= 0) { return 0; }
    var i = 0;
    while (i < n) {
        var c = load8(s + i);
        if (c < 48 || c > 57) { return 0; }
        i = i + 1;
    }
    return 1;
}

# atoi over the first n bytes only.
#must_use
fn _shabda_atoi_n(s, n): i64 {
    var v = 0;
    var i = 0;
    while (i < n) {
        var c = load8(s + i);
        if (c < 48 || c > 57) { return v; }
        v = v * 10 + (c - 48);
        i = i + 1;
    }
    return v;
}

# ================================================================
# emphasis level parsing (was parse_emphasis_level). Default = Moderate.
# ================================================================
#must_use
fn _shabda_parse_emphasis_level(input, astart, aend): i64 {
    var lvl = _shabda_extract_attr(input, astart, aend, "level");
    if (lvl != 0) {
        var s = str_cstr(lvl);
        if (streq(s, "strong") == 1)   { return SHABDA_EMPH_STRONG; }
        if (streq(s, "moderate") == 1) { return SHABDA_EMPH_MODERATE; }
        if (streq(s, "reduced") == 1)  { return SHABDA_EMPH_REDUCED; }
    }
    return SHABDA_EMPH_MODERATE;
}

# ================================================================
# prosody rate parsing (was parse_prosody_rate). Default = None (sentinel).
# ================================================================
#must_use
fn _shabda_parse_prosody_rate(input, astart, aend): i64 {
    var r = _shabda_extract_attr(input, astart, aend, "rate");
    if (r != 0) {
        var s = str_cstr(r);
        if (streq(s, "x-slow") == 1) { return SHABDA_RATE_XSLOW; }
        if (streq(s, "slow") == 1)   { return SHABDA_RATE_SLOW; }
        if (streq(s, "medium") == 1) { return SHABDA_RATE_MEDIUM; }
        if (streq(s, "fast") == 1)   { return SHABDA_RATE_FAST; }
        if (streq(s, "x-fast") == 1) { return SHABDA_RATE_XFAST; }
    }
    return SHABDA_RATE_NONE;
}

# ================================================================
# children_to_text (was children_to_text): concat all Text children's text with
# single-space joins. Returns a Str.
# ================================================================
#must_use
fn _shabda_children_to_text(children): i64 {
    var sb = str_builder_new();
    var n = vec_len(children);
    var i = 0;
    var wrote = 0;
    while (i < n) {
        var child = vec_get(children, i);
        if (shabda_ssml_node_tag(child) == SHABDA_SSML_TEXT) {
            if (wrote == 1) { str_builder_putc(sb, 32); }
            str_builder_add(sb, shabda_ssml_node_text(child));
            wrote = 1;
        }
        i = i + 1;
    }
    return str_builder_build(sb);
}

# ================================================================
# Push a trimmed text run bytes[start..end) as a Text node if non-empty (mirrors
# the Rust text-run branch shared by parse() and parse_until()).
# ================================================================
fn _shabda_push_text(nodes, input, start, end): i64 {
    # Trim ASCII whitespace both ends.
    var s = start;
    var e = end;
    while (s < e && _shabda_ssml_is_ws(load8(input + s)) == 1) { s = s + 1; }
    while (e > s && _shabda_ssml_is_ws(load8(input + e - 1)) == 1) { e = e - 1; }
    if (e > s) {
        var ts = str_from_buf(input + s, e - s);
        vec_push(nodes, shabda_ssml_text(ts));
    }
    return 0;
}

# ================================================================
# parse_tag (was parse_tag): parse the single tag/element starting at `pos` (a
# '<'). Writes the produced node* (0 == "no node", Rust None) to *node_out and
# returns the new position, OR returns SHABDA_SSML_PARSE_ERR on malformed input.
# ================================================================
#must_use
fn _shabda_parse_tag(input, len, pos, node_out): i64 {
    store64(node_out, 0);
    var tag_end = _shabda_find_tag_end(input, len, pos);
    if (tag_end < 0) { return SHABDA_SSML_PARSE_ERR; }   # unclosed tag bracket

    # tag_content = input[pos+1..tag_end]
    var cstart = pos + 1;
    var cend = tag_end;

    # self-closing? content ends with '/'
    var self_closing = 0;
    if (cend > cstart && load8(input + cend - 1) == 47) {
        self_closing = 1;
        cend = cend - 1;                          # drop trailing '/'
    }
    # trim the (possibly '/'-stripped) content
    while (cstart < cend && _shabda_ssml_is_ws(load8(input + cstart)) == 1) { cstart = cstart + 1; }
    while (cend > cstart && _shabda_ssml_is_ws(load8(input + cend - 1)) == 1) { cend = cend - 1; }

    # split tag name / attrs
    var name_len = _shabda_tag_name_len(input, cstart, cend);
    var astart = cstart + name_len;
    var aend = cend;
    while (astart < aend && _shabda_ssml_is_ws(load8(input + astart)) == 1) { astart = astart + 1; }
    while (aend > astart && _shabda_ssml_is_ws(load8(input + aend - 1)) == 1) { aend = aend - 1; }

    # break
    if (_shabda_name_eq(input, cstart, name_len, "break") == 1) {
        var dur = _shabda_parse_break_duration(input, astart, aend);
        if (dur == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
        store64(node_out, shabda_ssml_break(dur));
        return tag_end + 1;
    }
    # emphasis
    if (_shabda_name_eq(input, cstart, name_len, "emphasis") == 1) {
        var level = _shabda_parse_emphasis_level(input, astart, aend);
        if (self_closing == 1) {
            store64(node_out, shabda_ssml_emphasis(level, vec_new()));
            return tag_end + 1;
        }
        var kids = vec_new();
        var np = _shabda_parse_until(input, len, tag_end + 1, "emphasis", kids);
        if (np == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
        store64(node_out, shabda_ssml_emphasis(level, kids));
        return np;
    }
    # prosody
    if (_shabda_name_eq(input, cstart, name_len, "prosody") == 1) {
        var rate = _shabda_parse_prosody_rate(input, astart, aend);
        if (self_closing == 1) {
            store64(node_out, shabda_ssml_prosody(rate, vec_new()));
            return tag_end + 1;
        }
        var pkids = vec_new();
        var pnp = _shabda_parse_until(input, len, tag_end + 1, "prosody", pkids);
        if (pnp == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
        store64(node_out, shabda_ssml_prosody(rate, pkids));
        return pnp;
    }
    # phoneme
    if (_shabda_name_eq(input, cstart, name_len, "phoneme") == 1) {
        if (self_closing == 1) {
            var ph = _shabda_extract_attr(input, astart, aend, "ph");
            if (ph != 0) {
                store64(node_out, shabda_ssml_text(ph));
            }
            return tag_end + 1;
        }
        var phkids = vec_new();
        var phnp = _shabda_parse_until(input, len, tag_end + 1, "phoneme", phkids);
        if (phnp == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
        store64(node_out, shabda_ssml_text(_shabda_children_to_text(phkids)));
        return phnp;
    }
    # unknown tag
    if (self_closing == 1) {
        return tag_end + 1;
    }
    var ukids = vec_new();
    # parse_until with the unknown tag name (as a fresh cstr for the closer match)
    var uname = _shabda_dup_name(input, cstart, name_len);
    var unp = _shabda_parse_until(input, len, tag_end + 1, uname, ukids);
    if (unp == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
    if (vec_len(ukids) == 0) {
        return unp;
    }
    # pass through first child as if the tag wasn't there
    store64(node_out, vec_get(ukids, 0));
    return unp;
}

# Copy the tag name [start, start+n) to a fresh NUL-terminated cstr.
#must_use
fn _shabda_dup_name(input, start, n): i64 {
    var buf = alloc(n + 1);
    memcpy(buf, input + start, n);
    store8(buf + n, 0);
    return buf;
}

# ================================================================
# parse_until (was parse_until): parse content into `nodes` until a matching
# </tag_name> closer. Returns position after the closer, OR the end-of-input
# position if no closer (Rust "return what we have"), OR SHABDA_SSML_PARSE_ERR.
# tag_name is a cstr.
# ================================================================
#must_use
fn _shabda_parse_until(input, len, start, tag_name, nodes): i64 {
    var pos = start;
    while (pos < len) {
        if (load8(input + pos) == 60) {          # '<'
            var tag_end = _shabda_find_tag_end(input, len, pos);
            if (tag_end < 0) { return SHABDA_SSML_PARSE_ERR; }
            var cstart = pos + 1;
            # closing tag? content starts with '/'
            if (cstart < tag_end && load8(input + cstart) == 47) {
                # close_name = content[1..].trim()
                var ns = cstart + 1;
                var ne = tag_end;
                while (ns < ne && _shabda_ssml_is_ws(load8(input + ns)) == 1) { ns = ns + 1; }
                while (ne > ns && _shabda_ssml_is_ws(load8(input + ne - 1)) == 1) { ne = ne - 1; }
                if (_shabda_name_eq(input, ns, ne - ns, tag_name) == 1) {
                    return tag_end + 1;
                }
                # mismatched close — skip it
                pos = tag_end + 1;
            } else {
                var node_out = alloc(8);
                var np = _shabda_parse_tag(input, len, pos, node_out);
                if (np == SHABDA_SSML_PARSE_ERR) { return SHABDA_SSML_PARSE_ERR; }
                var node = load64(node_out);
                if (node != 0) { vec_push(nodes, node); }
                pos = np;
            }
        } else {
            var text_end = _shabda_next_lt(input, len, pos);
            _shabda_push_text(nodes, input, pos, text_end);
            pos = text_end;
        }
    }
    return pos;
}

# Index of the next '<' at or after `pos`, or `len` (Rust find('<').map_or(len)).
#must_use
fn _shabda_next_lt(input, len, pos): i64 {
    var i = pos;
    while (i < len) {
        if (load8(input + i) == 60) { return i; }
        i = i + 1;
    }
    return len;
}

# ================================================================
# parse (was parse): top-level. Returns a vec of SsmlNode* on success, or 0 on
# parse error (Rust Err). The <speak> wrapper is optional and its children are
# flattened into the top-level vec.
# ================================================================
#must_use
fn shabda_ssml_parse(input): i64 {
    var nodes = vec_new();
    var len = strlen(input);
    var pos = 0;
    while (pos < len) {
        if (load8(input + pos) == 60) {          # '<'
            var tag_end = _shabda_find_tag_end(input, len, pos);
            if (tag_end < 0) { return 0; }        # unclosed tag bracket -> Err
            var cstart = pos + 1;
            if (cstart < tag_end && load8(input + cstart) == 47) {
                # closing tag at top level — skip
                pos = tag_end + 1;
            } elif (_shabda_is_speak(input, len, cstart) == 1) {
                pos = tag_end + 1;
                var kids = vec_new();
                var np = _shabda_parse_until(input, len, pos, "speak", kids);
                if (np == SHABDA_SSML_PARSE_ERR) { return 0; }
                var kn = vec_len(kids);
                var ki = 0;
                while (ki < kn) {
                    vec_push(nodes, vec_get(kids, ki));
                    ki = ki + 1;
                }
                pos = np;
            } else {
                var node_out = alloc(8);
                var tnp = _shabda_parse_tag(input, len, pos, node_out);
                if (tnp == SHABDA_SSML_PARSE_ERR) { return 0; }
                var node = load64(node_out);
                if (node != 0) { vec_push(nodes, node); }
                pos = tnp;
            }
        } else {
            var text_end = _shabda_next_lt(input, len, pos);
            _shabda_push_text(nodes, input, pos, text_end);
            pos = text_end;
        }
    }
    return nodes;
}

# tag_content.starts_with("speak") || starts_with("speak ") — the Rust guard.
# Since "speak " implies "speak", a single prefix check suffices, matching Rust.
#must_use
fn _shabda_is_speak(input, len, cstart): i64 {
    return _shabda_ssml_starts_with(input, len, cstart, "speak");
}

# ================================================================
# serde codec (Rust `derive(Serialize, Deserialize)`). Self-contained: no bayan
# dependency — the port encodes each Copy enum via its stable integer tag, and an
# SsmlNode is (de)serialized structurally through the constructors/accessors. The
# roundtrip identity is exercised in the tests. These are the "codec" surface a
# format layer would call.
# ================================================================
# EmphasisLevel <-> code (identity; tags are the wire form).
#must_use
fn shabda_emphasis_level_encode(level): i64 { return level; }
#must_use
fn shabda_emphasis_level_decode(code): i64 {
    if (code == SHABDA_EMPH_STRONG)   { return SHABDA_EMPH_STRONG; }
    if (code == SHABDA_EMPH_MODERATE) { return SHABDA_EMPH_MODERATE; }
    if (code == SHABDA_EMPH_REDUCED)  { return SHABDA_EMPH_REDUCED; }
    return SHABDA_EMPH_MODERATE;                  # #[non_exhaustive] fallback
}

# SpeakingRate <-> code (identity; tags are the wire form).
#must_use
fn shabda_speaking_rate_encode(rate): i64 { return rate; }
#must_use
fn shabda_speaking_rate_decode(code): i64 {
    if (code == SHABDA_RATE_XSLOW)  { return SHABDA_RATE_XSLOW; }
    if (code == SHABDA_RATE_SLOW)   { return SHABDA_RATE_SLOW; }
    if (code == SHABDA_RATE_MEDIUM) { return SHABDA_RATE_MEDIUM; }
    if (code == SHABDA_RATE_FAST)   { return SHABDA_RATE_FAST; }
    if (code == SHABDA_RATE_XFAST)  { return SHABDA_RATE_XFAST; }
    return SHABDA_RATE_NONE;                       # unknown/None fallback
}

# SsmlNode deep-clone as a serde round-trip proxy: reconstructs an equal node
# tree via the public constructors (mirrors serialize -> deserialize identity).
#must_use
fn shabda_ssml_node_clone(node): i64 {
    var tag = shabda_ssml_node_tag(node);
    if (tag == SHABDA_SSML_TEXT) {
        return shabda_ssml_text(str_clone(shabda_ssml_node_text(node)));
    }
    if (tag == SHABDA_SSML_BREAK) {
        return shabda_ssml_break(shabda_ssml_node_duration(node));
    }
    if (tag == SHABDA_SSML_EMPHASIS) {
        return shabda_ssml_emphasis(shabda_ssml_node_level(node),
        _shabda_clone_children(shabda_ssml_node_children(node)));
    }
    if (tag == SHABDA_SSML_PROSODY) {
        return shabda_ssml_prosody(shabda_ssml_node_rate(node),
        _shabda_clone_children(shabda_ssml_node_children(node)));
    }
    return 0;                                      # #[non_exhaustive] fallback
}

#must_use
fn _shabda_clone_children(children): i64 {
    var out = vec_new();
    var n = vec_len(children);
    var i = 0;
    while (i < n) {
        vec_push(out, shabda_ssml_node_clone(vec_get(children, i)));
        i = i + 1;
    }
    return out;
}

# Structural equality of two SsmlNode trees (Rust derive(PartialEq)) — used by
# tests to assert parse results and serde round-trips.
#must_use
fn shabda_ssml_node_eq(a, b): i64 {
    var ta = shabda_ssml_node_tag(a);
    var tb = shabda_ssml_node_tag(b);
    if (ta != tb) { return 0; }
    if (ta == SHABDA_SSML_TEXT) {
        return str_eq(shabda_ssml_node_text(a), shabda_ssml_node_text(b));
    }
    if (ta == SHABDA_SSML_BREAK) {
        if (shabda_ssml_node_duration(a) == shabda_ssml_node_duration(b)) { return 1; }
        return 0;
    }
    if (ta == SHABDA_SSML_EMPHASIS) {
        if (shabda_ssml_node_level(a) != shabda_ssml_node_level(b)) { return 0; }
        return _shabda_children_eq(shabda_ssml_node_children(a), shabda_ssml_node_children(b));
    }
    if (ta == SHABDA_SSML_PROSODY) {
        if (shabda_ssml_node_rate(a) != shabda_ssml_node_rate(b)) { return 0; }
        return _shabda_children_eq(shabda_ssml_node_children(a), shabda_ssml_node_children(b));
    }
    return 0;
}

#must_use
fn _shabda_children_eq(a, b): i64 {
    var na = vec_len(a);
    var nb = vec_len(b);
    if (na != nb) { return 0; }
    var i = 0;
    while (i < na) {
        if (shabda_ssml_node_eq(vec_get(a, i), vec_get(b, i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# --- rules.cyr ---

# rules.cyr — rule-based grapheme-to-phoneme conversion (6 language engines).
#
# Ports rust-old/src/rules.rs (1545 LOC). Six public #must_use engines, each
# taking a cstring word and returning a `vec` of svara phoneme ordinals:
#   shabda_english_rules(word)   — silent-letter strip, prefix/suffix, patterns
#   shabda_spanish_rules(word)
#   shabda_german_rules(word)    — + final devoicing post-pass
#   shabda_hindi_rules(word)     — Devanagari + word-final schwa DELETION
#   shabda_sanskrit_rules(word)  — Devanagari + schwa PRESERVATION
#   shabda_arabic_rules(word)    — abjad + harakat/tanween/shadda
#
# DEPENDENCY POSITION: needs the vendored svara bundle (SVARA_PH_* ordinals) and
# src/error.cyr (for shared L0 tags — not strictly used here but part of the
# include chain). Modules never `include` each other; the entry file orders
# includes: lib/hisab, lib/goonj, lib/naad, lib/svara, src/error, src/rules.
#
# PORTING MODEL — everything operates on a codepoint array:
#   _shabda_word_chars(word) UTF-8-decodes the cstring into a `vec` of i64
#   codepoints ONCE; every engine indexes that vec. Devanagari/Arabic literals
#   port as exact codepoint compares against the hex values (load-bearing).
#
# Rust's PatternResult{Static/Dynamic} + custom iterator is FLATTENED: each
# match helper returns the number of chars 'consumed' and pushes the phoneme
# sequence directly into the caller's out vec. No iterator adapter.
#
# Rust `char` `to_lowercase()` → we ASCII-lowercase codepoints in
# _shabda_word_chars for the Latin engines (matching Rust's word.to_lowercase()
# for the ASCII range; the non-ASCII accented literals á/é/ñ/ä/ö/ü/ß are already
# lowercase in the test inputs, same as Rust). The Devanagari/Arabic engines take
# the raw (un-lowercased) codepoints, mirroring Rust's `word.chars()` there.
#
# Option<Phoneme> / sentinels: SHABDA_PH_NONE from error.cyr. Every match helper
# has a mandatory final fallback arm (the #[non_exhaustive]-style default).
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`/`_shabda_`-prefixed
# (flat link namespace; coexists with shbdk_ / svara_ / varna / sakshi).

# ================================================================
# Codepoint helpers
# ================================================================

# Is `cp` an ASCII vowel letter (a/e/i/o/u)? Ports is_vowel_char.
#must_use
fn _shabda_is_vowel_char(cp): i64 {
    if (cp == 0x61) { return 1; }   # a
    if (cp == 0x65) { return 1; }   # e
    if (cp == 0x69) { return 1; }   # i
    if (cp == 0x6F) { return 1; }   # o
    if (cp == 0x75) { return 1; }   # u
    return 0;
}

# ASCII-lowercase a single codepoint (A..Z -> a..z), leaving all else untouched.
# Mirrors Rust `char::to_lowercase().next()` for the ASCII range.
#must_use
fn _shabda_ascii_lower(cp): i64 {
    if (cp >= 0x41) {
        if (cp <= 0x5A) {
            return cp + 0x20;
        }
    }
    return cp;
}

# UTF-8-decode a NUL-terminated cstring into a `vec` of i64 codepoints.
# Optionally ASCII-lowercases each (lower != 0) — Latin engines lowercase, the
# Devanagari/Arabic engines pass raw. Returns a vec of codepoints.
#must_use
fn _shabda_decode_chars(word, lower): i64 {
    var out = vec_new();
    var n = strlen(word);
    var i = 0;
    while (i < n) {
        var b0 = load8(word + i);
        var cp = 0;
        var adv = 1;
        if (b0 < 0x80) {
            cp = b0;
        } elif (b0 < 0xE0) {
            # 2-byte sequence
            var b1 = load8(word + i + 1);
            cp = ((b0 & 0x1F) << 6) | (b1 & 0x3F);
            adv = 2;
        } elif (b0 < 0xF0) {
            # 3-byte sequence (Devanagari, Arabic presentation etc.)
            var b1b = load8(word + i + 1);
            var b2b = load8(word + i + 2);
            cp = ((b0 & 0x0F) << 12) | ((b1b & 0x3F) << 6) | (b2b & 0x3F);
            adv = 3;
        } else {
            # 4-byte sequence
            var b1c = load8(word + i + 1);
            var b2c = load8(word + i + 2);
            var b3c = load8(word + i + 3);
            cp = ((b0 & 0x07) << 18) | ((b1c & 0x3F) << 12) | ((b2c & 0x3F) << 6) | (b3c & 0x3F);
            adv = 4;
        }
        if (lower != 0) {
            cp = _shabda_ascii_lower(cp);
        }
        vec_push(out, cp);
        i = i + adv;
    }
    return out;
}

# Build the lowercased codepoint array for a word (Latin engines).
#must_use
fn _shabda_word_chars(word): i64 {
    return _shabda_decode_chars(word, 1);
}

# Safe vec_get: returns -1 when idx is out of bounds (Rust's chars.get(i)).
#must_use
fn _shabda_cp_at(chars, idx): i64 {
    if (idx < 0) { return (0 - 1); }
    if (idx >= vec_len(chars)) { return (0 - 1); }
    return vec_get(chars, idx);
}

# ================================================================
# English G2P rules — ports english_rules().
# ================================================================

# --- Step 1: silent-letter pre-processing. Ports preprocess_silent().
# Mutates a copy of `chars` in place (removals), returns the new vec.
#must_use
fn _shabda_preprocess_silent(chars): i64 {
    # copy into a fresh vec
    var result = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        vec_push(result, vec_get(chars, i));
        i = i + 1;
    }

    # Word-initial silent patterns: kn gn wr ps pn mn -> drop first.
    if (vec_len(result) >= 2) {
        var c0 = vec_get(result, 0);
        var c1 = vec_get(result, 1);
        var skip_first = 0;
        if (c0 == 0x6B) { if (c1 == 0x6E) { skip_first = 1; } }   # kn
        if (c0 == 0x67) { if (c1 == 0x6E) { skip_first = 1; } }   # gn
        if (c0 == 0x77) { if (c1 == 0x72) { skip_first = 1; } }   # wr
        if (c0 == 0x70) { if (c1 == 0x73) { skip_first = 1; } }   # ps
        if (c0 == 0x70) { if (c1 == 0x6E) { skip_first = 1; } }   # pn
        if (c0 == 0x6D) { if (c1 == 0x6E) { skip_first = 1; } }   # mn
        if (skip_first == 1) {
            vec_remove(result, 0);
        }
    }

    # Word-final silent patterns: mb bt mn -> drop last.
    if (vec_len(result) >= 2) {
        var len = vec_len(result);
        var p2 = vec_get(result, len - 2);
        var p1 = vec_get(result, len - 1);
        var strip_last = 0;
        if (p2 == 0x6D) { if (p1 == 0x62) { strip_last = 1; } }   # mb
        if (p2 == 0x62) { if (p1 == 0x74) { strip_last = 1; } }   # bt
        if (p2 == 0x6D) { if (p1 == 0x6E) { strip_last = 1; } }   # mn
        if (strip_last == 1) {
            vec_pop(result);
        }
        # gn at word-final (sign, design) — strip the g.
        var len2 = vec_len(result);
        if (len2 >= 2) {
            var g2 = vec_get(result, len2 - 2);
            var g1 = vec_get(result, len2 - 1);
            if (g2 == 0x67) {
                if (g1 == 0x6E) {
                    vec_remove(result, len2 - 2);
                }
            }
        }
    }

    return result;
}

# --- magic-e long vowel. Ports magic_e_vowel(). Pushes onto out.
fn _shabda_push_magic_e_vowel(out, v): i64 {
    if (v == 0x61) { vec_push(out, SVARA_PH_DIPH_EI); return 0; }   # a
    if (v == 0x69) { vec_push(out, SVARA_PH_DIPH_AI); return 0; }   # i
    if (v == 0x6F) { vec_push(out, SVARA_PH_DIPH_OU); return 0; }   # o
    if (v == 0x75) { vec_push(out, SVARA_PH_VOWEL_U); return 0; }   # u
    if (v == 0x65) { vec_push(out, SVARA_PH_VOWEL_E); return 0; }   # e
    vec_push(out, SVARA_PH_VOWEL_SCHWA);
    return 0;
}

# --- single consonant (magic-e). Ports single_consonant(). Pushes onto out.
fn _shabda_push_single_consonant(out, c): i64 {
    if (c == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 0; }   # b
    if (c == 0x63) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }   # c
    if (c == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 0; }   # d
    if (c == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 0; }      # f
    if (c == 0x67) { vec_push(out, SVARA_PH_PLOSIVE_G); return 0; }   # g
    if (c == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }   # k
    if (c == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 0; }   # l
    if (c == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 0; }     # m
    if (c == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 0; }     # n
    if (c == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 0; }   # p
    if (c == 0x72) { vec_push(out, SVARA_PH_APPROX_R); return 0; }    # r
    if (c == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 0; }      # s
    if (c == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 0; }   # t
    if (c == 0x76) { vec_push(out, SVARA_PH_FRIC_V); return 0; }      # v
    if (c == 0x7A) { vec_push(out, SVARA_PH_FRIC_Z); return 0; }      # z
    return 0;
}

# --- Step 4: English pattern matching. Ports match_pattern().
# `chars` is the stem vec, `pos` the current index. Pushes the matched phoneme
# sequence onto `out` and returns the number of chars consumed. Longest-match
# (4 -> 3 -> 2 -> 1).
fn _shabda_english_match(chars, pos, out): i64 {
    var n = vec_len(chars);
    var rem = n - pos;
    if (rem <= 0) { return 1; }

    var c0 = vec_get(chars, pos);

    # 4-letter patterns
    if (rem >= 4) {
        var a = c0;
        var b = vec_get(chars, pos + 1);
        var c = vec_get(chars, pos + 2);
        var d = vec_get(chars, pos + 3);
        # eigh
        if (a == 0x65) { if (b == 0x69) { if (c == 0x67) { if (d == 0x68) {
                        vec_push(out, SVARA_PH_DIPH_EI); return 4; } } } }
        # augh
        if (a == 0x61) { if (b == 0x75) { if (c == 0x67) { if (d == 0x68) {
                        vec_push(out, SVARA_PH_VOWEL_OPEN_O); return 4; } } } }
        # ough
        if (a == 0x6F) { if (b == 0x75) { if (c == 0x67) { if (d == 0x68) {
                        vec_push(out, SVARA_PH_DIPH_OU); return 4; } } } }
        # tion -> Sh schwa N
        if (a == 0x74) { if (b == 0x69) { if (c == 0x6F) { if (d == 0x6E) {
                        vec_push(out, SVARA_PH_FRIC_SH); vec_push(out, SVARA_PH_VOWEL_SCHWA);
                        vec_push(out, SVARA_PH_NASAL_N); return 4; } } } }
        # sion -> Zh schwa N
        if (a == 0x73) { if (b == 0x69) { if (c == 0x6F) { if (d == 0x6E) {
                        vec_push(out, SVARA_PH_FRIC_ZH); vec_push(out, SVARA_PH_VOWEL_SCHWA);
                        vec_push(out, SVARA_PH_NASAL_N); return 4; } } } }
        # cian -> same as tion
        if (a == 0x63) { if (b == 0x69) { if (c == 0x61) { if (d == 0x6E) {
                        vec_push(out, SVARA_PH_FRIC_SH); vec_push(out, SVARA_PH_VOWEL_SCHWA);
                        vec_push(out, SVARA_PH_NASAL_N); return 4; } } } }
    }

    # 3-letter patterns
    if (rem >= 3) {
        var t0 = c0;
        var t1 = vec_get(chars, pos + 1);
        var t2 = vec_get(chars, pos + 2);

        # Magic-e: VCe at word end (rem == 3, vowel, non-vowel, 'e')
        if (rem == 3) {
            if (t2 == 0x65) {
                if (_shabda_is_vowel_char(t0) == 1) {
                    if (_shabda_is_vowel_char(t1) == 0) {
                        _shabda_push_magic_e_vowel(out, t0);
                        _shabda_push_single_consonant(out, t1);
                        return 3;
                    }
                }
            }
        }
        # air -> OpenE R
        if (t0 == 0x61) { if (t1 == 0x69) { if (t2 == 0x72) {
                    vec_push(out, SVARA_PH_VOWEL_OPEN_E); vec_push(out, SVARA_PH_APPROX_R); return 3; } } }
        # ear -> NearI R
        if (t0 == 0x65) { if (t1 == 0x61) { if (t2 == 0x72) {
                    vec_push(out, SVARA_PH_VOWEL_NEAR_I); vec_push(out, SVARA_PH_APPROX_R); return 3; } } }
        # our -> AU R
        if (t0 == 0x6F) { if (t1 == 0x75) { if (t2 == 0x72) {
                    vec_push(out, SVARA_PH_DIPH_AU); vec_push(out, SVARA_PH_APPROX_R); return 3; } } }
        # igh -> AI
        if (t0 == 0x69) { if (t1 == 0x67) { if (t2 == 0x68) {
                    vec_push(out, SVARA_PH_DIPH_AI); return 3; } } }
        # thr -> Th R
        if (t0 == 0x74) { if (t1 == 0x68) { if (t2 == 0x72) {
                    vec_push(out, SVARA_PH_FRIC_TH); vec_push(out, SVARA_PH_APPROX_R); return 3; } } }
        # the -> Dh schwa
        if (t0 == 0x74) { if (t1 == 0x68) { if (t2 == 0x65) {
                    vec_push(out, SVARA_PH_FRIC_DH); vec_push(out, SVARA_PH_VOWEL_SCHWA); return 3; } } }
        # sh_ (consume 2)
        if (t0 == 0x73) { if (t1 == 0x68) {
                vec_push(out, SVARA_PH_FRIC_SH); return 2; } }
        # ch_ (consume 2)
        if (t0 == 0x63) { if (t1 == 0x68) {
                vec_push(out, SVARA_PH_AFFR_CH); return 2; } }
        # th_ (consume 2)
        if (t0 == 0x74) { if (t1 == 0x68) {
                vec_push(out, SVARA_PH_FRIC_TH); return 2; } }
        # ng_ : Rust guards `!chars[2].is_alphabetic() || chars.len() == 3`.
        # Here rem is the remaining-slice length; rem == 3 corresponds to
        # chars.len() == 3 in Rust's remaining slice. t2 alphabetic check below.
        if (t0 == 0x6E) { if (t1 == 0x67) {
                var ng_ok = 0;
                if (rem == 3) { ng_ok = 1; }
                if (_shabda_rules_is_ascii_alpha(t2) == 0) { ng_ok = 1; }
                if (ng_ok == 1) {
                    vec_push(out, SVARA_PH_NASAL_NG); return 2;
                }
            } }
        # ing (only when rem == 3)
        if (t0 == 0x69) { if (t1 == 0x6E) { if (t2 == 0x67) {
                    if (rem == 3) {
                        vec_push(out, SVARA_PH_VOWEL_NEAR_I); vec_push(out, SVARA_PH_NASAL_NG); return 3;
                    }
                } } }
        # ou_
        if (t0 == 0x6F) { if (t1 == 0x75) {
                vec_push(out, SVARA_PH_DIPH_AU); return 2; } }
        # ow_
        if (t0 == 0x6F) { if (t1 == 0x77) {
                vec_push(out, SVARA_PH_DIPH_OU); return 2; } }
        # ai_
        if (t0 == 0x61) { if (t1 == 0x69) {
                vec_push(out, SVARA_PH_DIPH_AI); return 2; } }
        # ee_
        if (t0 == 0x65) { if (t1 == 0x65) {
                vec_push(out, SVARA_PH_VOWEL_E); return 2; } }
        # oo_
        if (t0 == 0x6F) { if (t1 == 0x6F) {
                vec_push(out, SVARA_PH_VOWEL_U); return 2; } }
        # ea_
        if (t0 == 0x65) { if (t1 == 0x61) {
                vec_push(out, SVARA_PH_VOWEL_E); return 2; } }
    }

    # 2-letter patterns
    if (rem >= 2) {
        var d0 = c0;
        var d1 = vec_get(chars, pos + 1);
        if (d0 == 0x73) { if (d1 == 0x68) { vec_push(out, SVARA_PH_FRIC_SH); return 2; } }   # sh
        if (d0 == 0x63) { if (d1 == 0x68) { vec_push(out, SVARA_PH_AFFR_CH); return 2; } }   # ch
        if (d0 == 0x74) { if (d1 == 0x68) { vec_push(out, SVARA_PH_FRIC_TH); return 2; } }   # th
        if (d0 == 0x77) { if (d1 == 0x68) { vec_push(out, SVARA_PH_APPROX_W); return 2; } }  # wh
        if (d0 == 0x70) { if (d1 == 0x68) { vec_push(out, SVARA_PH_FRIC_F); return 2; } }    # ph
        if (d0 == 0x63) { if (d1 == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 2; } } # ck
        if (d0 == 0x71) { if (d1 == 0x75) {                                                  # qu
                vec_push(out, SVARA_PH_PLOSIVE_K); vec_push(out, SVARA_PH_APPROX_W); return 2; } }
        if (d0 == 0x61) { if (d1 == 0x72) {                                                  # ar
                vec_push(out, SVARA_PH_VOWEL_OPEN_A); vec_push(out, SVARA_PH_APPROX_R); return 2; } }
        # er/ir/ur -> Bird R
        if (d1 == 0x72) {
            if (d0 == 0x65) { vec_push(out, SVARA_PH_VOWEL_BIRD); vec_push(out, SVARA_PH_APPROX_R); return 2; }
            if (d0 == 0x69) { vec_push(out, SVARA_PH_VOWEL_BIRD); vec_push(out, SVARA_PH_APPROX_R); return 2; }
            if (d0 == 0x75) { vec_push(out, SVARA_PH_VOWEL_BIRD); vec_push(out, SVARA_PH_APPROX_R); return 2; }
            if (d0 == 0x6F) { vec_push(out, SVARA_PH_VOWEL_OPEN_O); vec_push(out, SVARA_PH_APPROX_R); return 2; }   # or
        }
    }

    # Single-letter patterns.
    return _shabda_english_single(chars, pos, out);
}

# ASCII alphabetic test (Rust char::is_alphabetic for ASCII inputs).
#must_use
fn _shabda_rules_is_ascii_alpha(cp): i64 {
    if (cp >= 0x61) { if (cp <= 0x7A) { return 1; } }
    if (cp >= 0x41) { if (cp <= 0x5A) { return 1; } }
    return 0;
}

# Single-letter English rule. Pushes phoneme(s), returns consumed (always 1).
fn _shabda_english_single(chars, pos, out): i64 {
    var n = vec_len(chars);
    var rem = n - pos;
    var ch = vec_get(chars, pos);
    var next = 0;
    if (rem > 1) { next = vec_get(chars, pos + 1); }

    if (ch == 0x61) { vec_push(out, SVARA_PH_VOWEL_ASH); return 1; }   # a
    if (ch == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 1; }   # b
    if (ch == 0x63) {                                                  # c
        if (rem > 1) {
            if (next == 0x65) { vec_push(out, SVARA_PH_FRIC_S); return 1; }
            if (next == 0x69) { vec_push(out, SVARA_PH_FRIC_S); return 1; }
            if (next == 0x79) { vec_push(out, SVARA_PH_FRIC_S); return 1; }
        }
        vec_push(out, SVARA_PH_PLOSIVE_K); return 1;
    }
    if (ch == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 1; }   # d
    if (ch == 0x65) {                                                  # e
        if (rem == 1) { return 1; }
        vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1;
    }
    if (ch == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 1; }      # f
    if (ch == 0x67) {                                                  # g
        if (rem > 1) {
            if (next == 0x65) { vec_push(out, SVARA_PH_AFFR_J); return 1; }
            if (next == 0x69) { vec_push(out, SVARA_PH_AFFR_J); return 1; }
            if (next == 0x79) { vec_push(out, SVARA_PH_AFFR_J); return 1; }
        }
        vec_push(out, SVARA_PH_PLOSIVE_G); return 1;
    }
    if (ch == 0x68) { vec_push(out, SVARA_PH_FRIC_H); return 1; }      # h
    if (ch == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 1; } # i
    if (ch == 0x6A) { vec_push(out, SVARA_PH_AFFR_J); return 1; }      # j
    if (ch == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }   # k
    if (ch == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 1; }   # l
    if (ch == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 1; }     # m
    if (ch == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 1; }     # n
    if (ch == 0x6F) { vec_push(out, SVARA_PH_VOWEL_O); return 1; }     # o
    if (ch == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 1; }   # p
    if (ch == 0x72) { vec_push(out, SVARA_PH_APPROX_R); return 1; }    # r
    if (ch == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 1; }      # s
    if (ch == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 1; }   # t
    if (ch == 0x75) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 1; } # u
    if (ch == 0x76) { vec_push(out, SVARA_PH_FRIC_V); return 1; }      # v
    if (ch == 0x77) { vec_push(out, SVARA_PH_APPROX_W); return 1; }    # w
    if (ch == 0x78) {                                                  # x -> ks
        vec_push(out, SVARA_PH_PLOSIVE_K); vec_push(out, SVARA_PH_FRIC_S); return 1;
    }
    if (ch == 0x79) {                                                  # y
        if (rem > 1) { vec_push(out, SVARA_PH_APPROX_J); return 1; }
        vec_push(out, SVARA_PH_VOWEL_E); return 1;
    }
    if (ch == 0x7A) { vec_push(out, SVARA_PH_FRIC_Z); return 1; }      # z
    if (ch == 0x27) { return 1; }                                      # ' (apostrophe)
    if (ch == 0x2D) { vec_push(out, SVARA_PH_SILENCE); return 1; }     # -
    return 1;
}

# Public English engine. Ports english_rules().
#must_use
fn shabda_english_rules(word): i64 {
    var chars0 = _shabda_word_chars(word);
    if (vec_len(chars0) == 0) {
        return vec_new();
    }

    # Step 1: strip silent letters.
    var chars = _shabda_preprocess_silent(chars0);

    # Step 2: detect + strip prefix. We compute the prefix phonemes (pushed later)
    # and the stem-start offset into `chars`.
    var prefix_out = vec_new();
    var stem_start = _shabda_strip_prefix(chars, prefix_out);

    # Build the stem vec (chars[stem_start..]).
    var stem_full = vec_new();
    var si = stem_start;
    var cn = vec_len(chars);
    while (si < cn) {
        vec_push(stem_full, vec_get(chars, si));
        si = si + 1;
    }

    # Step 3: detect suffix (-ed) and shorten the stem.
    var suffix = _shabda_detect_suffix(stem_full);
    var stem = stem_full;
    if (suffix == 1) {
        # drop the last 2 chars
        var stem2 = vec_new();
        var k = 0;
        var slen = vec_len(stem_full) - 2;
        while (k < slen) {
            vec_push(stem2, vec_get(stem_full, k));
            k = k + 1;
        }
        stem = stem2;
    }

    # Step 4: assemble phonemes: prefix, then left-to-right pattern match.
    var phonemes = vec_new();
    var pi = 0;
    var plen = vec_len(prefix_out);
    while (pi < plen) {
        vec_push(phonemes, vec_get(prefix_out, pi));
        pi = pi + 1;
    }

    var i = 0;
    var stemlen = vec_len(stem);
    while (i < stemlen) {
        var consumed = _shabda_english_match(stem, i, phonemes);
        i = i + consumed;
    }

    # Step 5: post-process the -ed suffix.
    _shabda_apply_suffix(phonemes, suffix);

    return phonemes;
}

# --- Step 2 helper: strip_prefix. Pushes prefix phonemes onto `prefix_out` and
# returns the stem-start offset. Only strips when remainder >= 4 and remainder[0]
# is a consonant. Ports strip_prefix(). Prefix order matters (un, dis, mis, pre,
# re) — 're' is checked last so 'pre' wins first.
#must_use
fn _shabda_strip_prefix(chars, prefix_out): i64 {
    var n = vec_len(chars);

    # un (len 2)
    if (_shabda_prefix_matches(chars, 0x75, 0x6E, 0, 0, 2) == 1) {
        var rem = n - 2;
        if (rem >= 4) {
            if (_shabda_is_vowel_char(vec_get(chars, 2)) == 0) {
                vec_push(prefix_out, SVARA_PH_VOWEL_CUP_V);
                vec_push(prefix_out, SVARA_PH_NASAL_N);
                return 2;
            }
        }
    }
    # dis (len 3)
    if (_shabda_prefix_matches(chars, 0x64, 0x69, 0x73, 0, 3) == 1) {
        var rem = n - 3;
        if (rem >= 4) {
            if (_shabda_is_vowel_char(vec_get(chars, 3)) == 0) {
                vec_push(prefix_out, SVARA_PH_PLOSIVE_D);
                vec_push(prefix_out, SVARA_PH_VOWEL_NEAR_I);
                vec_push(prefix_out, SVARA_PH_FRIC_S);
                return 3;
            }
        }
    }
    # mis (len 3)
    if (_shabda_prefix_matches(chars, 0x6D, 0x69, 0x73, 0, 3) == 1) {
        var rem = n - 3;
        if (rem >= 4) {
            if (_shabda_is_vowel_char(vec_get(chars, 3)) == 0) {
                vec_push(prefix_out, SVARA_PH_NASAL_M);
                vec_push(prefix_out, SVARA_PH_VOWEL_NEAR_I);
                vec_push(prefix_out, SVARA_PH_FRIC_S);
                return 3;
            }
        }
    }
    # pre (len 3)
    if (_shabda_prefix_matches(chars, 0x70, 0x72, 0x65, 0, 3) == 1) {
        var rem = n - 3;
        if (rem >= 4) {
            if (_shabda_is_vowel_char(vec_get(chars, 3)) == 0) {
                vec_push(prefix_out, SVARA_PH_PLOSIVE_P);
                vec_push(prefix_out, SVARA_PH_APPROX_R);
                vec_push(prefix_out, SVARA_PH_VOWEL_E);
                return 3;
            }
        }
    }
    # re (len 2)
    if (_shabda_prefix_matches(chars, 0x72, 0x65, 0, 0, 2) == 1) {
        var rem = n - 2;
        if (rem >= 4) {
            if (_shabda_is_vowel_char(vec_get(chars, 2)) == 0) {
                vec_push(prefix_out, SVARA_PH_APPROX_R);
                vec_push(prefix_out, SVARA_PH_VOWEL_E);
                return 2;
            }
        }
    }
    return 0;
}

# Does `chars` start with the given prefix (up to `plen` codepoints)?
#must_use
fn _shabda_prefix_matches(chars, p0, p1, p2, p3, plen): i64 {
    if (vec_len(chars) < plen) { return 0; }
    if (vec_get(chars, 0) != p0) { return 0; }
    if (plen >= 2) { if (vec_get(chars, 1) != p1) { return 0; } }
    if (plen >= 3) { if (vec_get(chars, 2) != p2) { return 0; } }
    if (plen >= 4) { if (vec_get(chars, 3) != p3) { return 0; } }
    return 1;
}

# --- Step 3 helper: detect_suffix. Returns 1 for -ed, 0 for none. Ports
# detect_suffix(): -ed only when len >= 4 and last two chars are 'e','d'.
#must_use
fn _shabda_detect_suffix(chars): i64 {
    var n = vec_len(chars);
    if (n >= 3) {
        if (vec_get(chars, n - 2) == 0x65) {
            if (vec_get(chars, n - 1) == 0x64) {
                if (n >= 4) {
                    return 1;
                }
            }
        }
    }
    return 0;
}

# --- Step 5 helper: apply_suffix (-ed). Ports apply_suffix(). Mutates in place.
fn _shabda_apply_suffix(phonemes, suffix): i64 {
    if (suffix == 0) { return 0; }
    var n = vec_len(phonemes);
    if (n == 0) {
        # Rust: last == None -> falls to the _ arm -> push /d/
        vec_push(phonemes, SVARA_PH_PLOSIVE_D);
        return 0;
    }
    var last = vec_get(phonemes, n - 1);
    # After /t/ or /d/: -ed = /ɪd/
    if (last == SVARA_PH_PLOSIVE_T) {
        vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        vec_push(phonemes, SVARA_PH_PLOSIVE_D);
        return 0;
    }
    if (last == SVARA_PH_PLOSIVE_D) {
        vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        vec_push(phonemes, SVARA_PH_PLOSIVE_D);
        return 0;
    }
    # After voiceless consonants: -ed = /t/
    if (last == SVARA_PH_PLOSIVE_P) { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_PLOSIVE_K) { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_FRIC_F)    { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_FRIC_S)    { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_FRIC_SH)   { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_AFFR_CH)   { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    if (last == SVARA_PH_FRIC_TH)   { vec_push(phonemes, SVARA_PH_PLOSIVE_T); return 0; }
    # After voiced consonants and vowels: -ed = /d/
    vec_push(phonemes, SVARA_PH_PLOSIVE_D);
    return 0;
}

# ================================================================
# Spanish G2P rules — ports spanish_rules(). Accented codepoints (2-byte UTF-8):
#   á=0xE1 é=0xE9 í=0xED ó=0xF3 ú=0xFA ü=0xFC ñ=0xF1. ASCII-lower leaves them
#   as-is (already lowercase in inputs), matching Rust's word.to_lowercase().
# ================================================================

# Spanish pattern match at `pos`. Pushes phonemes onto `out`, returns consumed.
fn _shabda_spanish_match(chars, pos, out): i64 {
    var n = vec_len(chars);
    var rem = n - pos;
    if (rem <= 0) { return 1; }

    var c0 = vec_get(chars, pos);

    # 2-letter digraphs first.
    if (rem >= 2) {
        var c1 = vec_get(chars, pos + 1);
        if (c0 == 0x63) { if (c1 == 0x68) { vec_push(out, SVARA_PH_AFFR_CH); return 2; } }   # ch
        if (c0 == 0x6C) { if (c1 == 0x6C) { vec_push(out, SVARA_PH_APPROX_J); return 2; } }  # ll
        if (c0 == 0x72) { if (c1 == 0x72) { vec_push(out, SVARA_PH_APPROX_R); return 2; } }  # rr
        if (c0 == 0x71) { if (c1 == 0x75) { vec_push(out, SVARA_PH_PLOSIVE_K); return 2; } } # qu
        # gu before e/i: u silent, g -> /g/
        if (c0 == 0x67) {
            if (c1 == 0x75) {
                if (rem >= 3) {
                    var c2 = vec_get(chars, pos + 2);
                    if (c2 == 0x65) { vec_push(out, SVARA_PH_PLOSIVE_G); return 2; }
                    if (c2 == 0x69) { vec_push(out, SVARA_PH_PLOSIVE_G); return 2; }
                }
            }
        }
    }

    # Single characters.
    var next = 0;
    if (rem > 1) { next = vec_get(chars, pos + 1); }

    if (c0 == 0x61) { vec_push(out, SVARA_PH_VOWEL_OPEN_A); return 1; }   # a
    if (c0 == 0xE1) { vec_push(out, SVARA_PH_VOWEL_OPEN_A); return 1; }   # á
    if (c0 == 0x65) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1; }   # e
    if (c0 == 0xE9) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1; }   # é
    if (c0 == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 1; }   # i
    if (c0 == 0xED) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 1; }   # í
    if (c0 == 0x6F) { vec_push(out, SVARA_PH_VOWEL_O); return 1; }        # o
    if (c0 == 0xF3) { vec_push(out, SVARA_PH_VOWEL_O); return 1; }        # ó
    if (c0 == 0x75) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 1; }    # u
    if (c0 == 0xFA) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 1; }    # ú
    if (c0 == 0xFC) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 1; }    # ü
    if (c0 == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 1; }      # b
    if (c0 == 0x76) { vec_push(out, SVARA_PH_PLOSIVE_B); return 1; }      # v
    if (c0 == 0x63) {                                                     # c
        if (rem > 1) {
            if (next == 0x65) { vec_push(out, SVARA_PH_FRIC_TH); return 1; }
            if (next == 0x69) { vec_push(out, SVARA_PH_FRIC_TH); return 1; }
        }
        vec_push(out, SVARA_PH_PLOSIVE_K); return 1;
    }
    if (c0 == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 1; }      # d
    if (c0 == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 1; }         # f
    if (c0 == 0x67) {                                                     # g
        if (rem > 1) {
            if (next == 0x65) { vec_push(out, SVARA_PH_FRIC_H); return 1; }
            if (next == 0x69) { vec_push(out, SVARA_PH_FRIC_H); return 1; }
        }
        vec_push(out, SVARA_PH_PLOSIVE_G); return 1;
    }
    if (c0 == 0x68) { return 1; }                                        # h — silent
    if (c0 == 0x6A) { vec_push(out, SVARA_PH_FRIC_H); return 1; }         # j /x/
    if (c0 == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }      # k
    if (c0 == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 1; }      # l
    if (c0 == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 1; }        # m
    if (c0 == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 1; }        # n
    if (c0 == 0xF1) { vec_push(out, SVARA_PH_NASAL_NG); return 1; }       # ñ palatal nasal
    if (c0 == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 1; }      # p
    if (c0 == 0x72) { vec_push(out, SVARA_PH_TAP_FLAP); return 1; }       # r
    if (c0 == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 1; }         # s
    if (c0 == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 1; }      # t
    if (c0 == 0x77) { vec_push(out, SVARA_PH_APPROX_W); return 1; }       # w
    if (c0 == 0x78) {                                                     # x -> ks
        vec_push(out, SVARA_PH_PLOSIVE_K); vec_push(out, SVARA_PH_FRIC_S); return 1;
    }
    if (c0 == 0x79) {                                                     # y
        if (rem == 1) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 1; }
        vec_push(out, SVARA_PH_APPROX_J); return 1;
    }
    if (c0 == 0x7A) { vec_push(out, SVARA_PH_FRIC_TH); return 1; }        # z Castilian /θ/
    if (c0 == 0x27) { return 1; }                                        # '
    if (c0 == 0x2D) { return 1; }                                        # -
    return 1;
}

# Public Spanish engine. Ports spanish_rules().
#must_use
fn shabda_spanish_rules(word): i64 {
    var chars = _shabda_word_chars(word);
    if (vec_len(chars) == 0) {
        return vec_new();
    }
    var phonemes = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        var consumed = _shabda_spanish_match(chars, i, phonemes);
        i = i + consumed;
    }
    return phonemes;
}

# ================================================================
# German G2P rules — ports german_rules(). Accented codepoints (2-byte UTF-8):
#   ä=0xE4 ö=0xF6 ü=0xFC ß=0xDF á=0xE1. Post-pass: final devoicing on the last
#   phoneme (b->p d->t g->k v->f z->s).
# ================================================================

# German double-consonant helper: for a doubled non-vowel `a`, push its single
# phoneme (Rust's inner match). Pushes onto out, returns 1 if handled else 0.
fn _shabda_german_double(out, a): i64 {
    if (a == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 1; }   # b
    if (a == 0x63) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }   # c
    if (a == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 1; }   # d
    if (a == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 1; }      # f
    if (a == 0x67) { vec_push(out, SVARA_PH_PLOSIVE_G); return 1; }   # g
    if (a == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 1; }   # l
    if (a == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 1; }     # m
    if (a == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 1; }     # n
    if (a == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 1; }   # p
    if (a == 0x72) { vec_push(out, SVARA_PH_APPROX_R); return 1; }    # r
    if (a == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 1; }      # s
    if (a == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 1; }   # t
    # _ arm: empty phoneme sequence, but still consumes 2.
    return 1;
}

# German pattern match at `pos`. Pushes phonemes onto `out`, returns consumed.
fn _shabda_german_match(chars, pos, out): i64 {
    var n = vec_len(chars);
    var rem = n - pos;
    if (rem <= 0) { return 1; }

    var c0 = vec_get(chars, pos);

    # 3-letter: sch -> /ʃ/
    if (rem >= 3) {
        if (c0 == 0x73) {
            if (vec_get(chars, pos + 1) == 0x63) {
                if (vec_get(chars, pos + 2) == 0x68) {
                    vec_push(out, SVARA_PH_FRIC_SH); return 3;
                }
            }
        }
    }

    # 2-letter patterns.
    if (rem >= 2) {
        var c1 = vec_get(chars, pos + 1);
        if (c0 == 0x63) { if (c1 == 0x68) { vec_push(out, SVARA_PH_FRIC_SH); return 2; } }   # ch (ich-Laut)
        if (c0 == 0x63) { if (c1 == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 2; } } # ck
        if (c0 == 0x65) { if (c1 == 0x69) { vec_push(out, SVARA_PH_DIPH_AI); return 2; } }   # ei
        if (c0 == 0x69) { if (c1 == 0x65) { vec_push(out, SVARA_PH_VOWEL_E); return 2; } }   # ie long /iː/
        if (c0 == 0x65) { if (c1 == 0x75) { vec_push(out, SVARA_PH_DIPH_OI); return 2; } }   # eu
        if (c0 == 0xE4) { if (c1 == 0x75) { vec_push(out, SVARA_PH_DIPH_OI); return 2; } }   # äu
        if (c0 == 0x70) { if (c1 == 0x66) {                                                  # pf
                vec_push(out, SVARA_PH_PLOSIVE_P); vec_push(out, SVARA_PH_FRIC_F); return 2; } }
        # ('t','z') | ('z',_) if chars[0]=='z' => {} : no-op, falls to single 'z'.
        # (We simply don't match here for z; the single-char handler runs.)
        # sp/st at word start -> /ʃp/, /ʃt/ : Dynamic(1, [Sh]) — consumes ONE.
        if (c0 == 0x73) {
            if (c1 == 0x70) { vec_push(out, SVARA_PH_FRIC_SH); return 1; }   # sp
            if (c1 == 0x74) { vec_push(out, SVARA_PH_FRIC_SH); return 1; }   # st
        }
        if (c0 == 0x74) { if (c1 == 0x68) { vec_push(out, SVARA_PH_PLOSIVE_T); return 2; } } # th
        if (c0 == 0x70) { if (c1 == 0x68) { vec_push(out, SVARA_PH_FRIC_F); return 2; } }    # ph
        if (c0 == 0x71) { if (c1 == 0x75) {                                                  # qu
                vec_push(out, SVARA_PH_PLOSIVE_K); vec_push(out, SVARA_PH_FRIC_V); return 2; } }
        # Double consonants -> single phoneme (only if a==b and non-vowel).
        # Rust reaches this arm AFTER the z-guard no-op; z==z would have been
        # caught by the no-op arm first, so exclude z here to match (z doubles
        # fall through to single 'z' twice in Rust — but the no-op arm returns
        # nothing and Rust re-loops; actually the no-op arm has empty body so the
        # match falls through to single-char. Replicate: only handle a==b for
        # non-vowel, non-z.)
        if (c0 == c1) {
            if (_shabda_is_vowel_char(c0) == 0) {
                if (c0 != 0x7A) {
                    _shabda_german_double(out, c0);
                    return 2;
                }
            }
        }
    }

    # Single characters.
    var next = 0;
    if (rem > 1) { next = vec_get(chars, pos + 1); }

    if (c0 == 0x61) { vec_push(out, SVARA_PH_VOWEL_OPEN_A); return 1; }   # a
    if (c0 == 0xE1) { vec_push(out, SVARA_PH_VOWEL_OPEN_A); return 1; }   # á
    if (c0 == 0xE4) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1; }   # ä
    if (c0 == 0x65) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1; }   # e
    if (c0 == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 1; }   # i
    if (c0 == 0x6F) { vec_push(out, SVARA_PH_VOWEL_O); return 1; }        # o
    if (c0 == 0xF6) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 1; }   # ö /œ/
    if (c0 == 0x75) { vec_push(out, SVARA_PH_VOWEL_U); return 1; }        # u
    if (c0 == 0xFC) { vec_push(out, SVARA_PH_VOWEL_E); return 1; }        # ü /yː/
    if (c0 == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 1; }      # b
    if (c0 == 0x63) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }      # c
    if (c0 == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 1; }      # d
    if (c0 == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 1; }         # f
    if (c0 == 0x67) { vec_push(out, SVARA_PH_PLOSIVE_G); return 1; }      # g
    if (c0 == 0x68) { vec_push(out, SVARA_PH_FRIC_H); return 1; }         # h
    if (c0 == 0x6A) { vec_push(out, SVARA_PH_APPROX_J); return 1; }       # j
    if (c0 == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }      # k
    if (c0 == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 1; }      # l
    if (c0 == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 1; }        # m
    if (c0 == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 1; }        # n
    if (c0 == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 1; }      # p
    if (c0 == 0x72) { vec_push(out, SVARA_PH_APPROX_R); return 1; }       # r
    if (c0 == 0x73) {                                                     # s
        if (rem > 1) {
            if (_shabda_is_vowel_char(next) == 1) {
                vec_push(out, SVARA_PH_FRIC_Z); return 1;   # s before vowel -> /z/
            }
        }
        vec_push(out, SVARA_PH_FRIC_S); return 1;
    }
    if (c0 == 0xDF) { vec_push(out, SVARA_PH_FRIC_S); return 1; }         # ß
    if (c0 == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 1; }      # t
    if (c0 == 0x76) { vec_push(out, SVARA_PH_FRIC_F); return 1; }         # v = /f/
    if (c0 == 0x77) { vec_push(out, SVARA_PH_FRIC_V); return 1; }         # w = /v/
    if (c0 == 0x78) { vec_push(out, SVARA_PH_PLOSIVE_K); return 1; }      # x
    if (c0 == 0x79) { vec_push(out, SVARA_PH_VOWEL_E); return 1; }        # y /yː/
    if (c0 == 0x7A) {                                                     # z -> /ts/
        vec_push(out, SVARA_PH_PLOSIVE_T); vec_push(out, SVARA_PH_FRIC_S); return 1;
    }
    if (c0 == 0x27) { return 1; }                                        # '
    if (c0 == 0x2D) { return 1; }                                        # -
    return 1;
}

# Public German engine. Ports german_rules().
#must_use
fn shabda_german_rules(word): i64 {
    var chars = _shabda_word_chars(word);
    if (vec_len(chars) == 0) {
        return vec_new();
    }
    var phonemes = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        var consumed = _shabda_german_match(chars, i, phonemes);
        i = i + consumed;
    }

    # Final devoicing: voiced -> voiceless at word end (mutate last element).
    var pn = vec_len(phonemes);
    if (pn > 0) {
        var last = vec_get(phonemes, pn - 1);
        var newl = last;
        if (last == SVARA_PH_PLOSIVE_B) { newl = SVARA_PH_PLOSIVE_P; }
        if (last == SVARA_PH_PLOSIVE_D) { newl = SVARA_PH_PLOSIVE_T; }
        if (last == SVARA_PH_PLOSIVE_G) { newl = SVARA_PH_PLOSIVE_K; }
        if (last == SVARA_PH_FRIC_V)    { newl = SVARA_PH_FRIC_F; }
        if (last == SVARA_PH_FRIC_Z)    { newl = SVARA_PH_FRIC_S; }
        vec_set(phonemes, pn - 1, newl);
    }

    return phonemes;
}

# ================================================================
# Hindi G2P rules (Devanagari) — ports hindi_rules(). Devanagari codepoints are
# load-bearing: independent vowels, matras (combining vowel signs), virama,
# anusvara/visarga/chandrabindu. Each consonant carries an inherent schwa unless
# followed by a matra/virama/anusvara/chandrabindu. Word-final schwa DELETION.
# The word is decoded WITHOUT ASCII-lowering (Rust uses word.chars() here); the
# Latin fallback lowercases per-codepoint.
# ================================================================

# Should the inherent schwa be suppressed given the following codepoint `next`?
# Ports push_consonant's suppress set (Hindi). next == -1 means end-of-word.
#must_use
fn _shabda_hindi_suppress(next): i64 {
    if (next == 0x093E) { return 1; }   # ा aa matra
    if (next == 0x093F) { return 1; }   # ि i
    if (next == 0x0940) { return 1; }   # ी ii
    if (next == 0x0941) { return 1; }   # ु u
    if (next == 0x0942) { return 1; }   # ू uu
    if (next == 0x0947) { return 1; }   # े e
    if (next == 0x0948) { return 1; }   # ै ai
    if (next == 0x094B) { return 1; }   # ो o
    if (next == 0x094C) { return 1; }   # ौ au
    if (next == 0x0943) { return 1; }   # ृ vocalic r
    if (next == 0x094D) { return 1; }   # ् virama
    if (next == 0x0902) { return 1; }   # ं anusvara
    if (next == 0x0901) { return 1; }   # ँ chandrabindu
    return 0;
}

# Push a Hindi consonant + inherent schwa unless suppressed. Ports push_consonant.
fn _shabda_hindi_push_consonant(out, consonant, next): i64 {
    vec_push(out, consonant);
    if (_shabda_hindi_suppress(next) == 0) {
        vec_push(out, SVARA_PH_VOWEL_SCHWA);
    }
    return 0;
}

# Latin fallback for romanized Hindi. Pushes phoneme(s) for an ASCII letter.
fn _shabda_hindi_latin(out, cp): i64 {
    var lower = _shabda_ascii_lower(cp);
    if (lower == 0x61) { vec_push(out, SVARA_PH_VOWEL_SCHWA); return 0; }   # a
    if (lower == 0x65) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 0; }  # e
    if (lower == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 0; }  # i
    if (lower == 0x6F) { vec_push(out, SVARA_PH_VOWEL_O); return 0; }       # o
    if (lower == 0x75) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 0; }   # u
    if (lower == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }     # k
    if (lower == 0x67) { vec_push(out, SVARA_PH_PLOSIVE_G); return 0; }     # g
    if (lower == 0x63) { vec_push(out, SVARA_PH_AFFR_CH); return 0; }       # c
    if (lower == 0x6A) { vec_push(out, SVARA_PH_AFFR_J); return 0; }        # j
    if (lower == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 0; }     # t
    if (lower == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 0; }     # d
    if (lower == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 0; }       # n
    if (lower == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 0; }     # p
    if (lower == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 0; }     # b
    if (lower == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 0; }       # m
    if (lower == 0x79) { vec_push(out, SVARA_PH_APPROX_J); return 0; }      # y
    if (lower == 0x72) { vec_push(out, SVARA_PH_TAP_FLAP); return 0; }      # r
    if (lower == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 0; }     # l
    if (lower == 0x76) { vec_push(out, SVARA_PH_FRIC_V); return 0; }        # v
    if (lower == 0x77) { vec_push(out, SVARA_PH_FRIC_V); return 0; }        # w
    if (lower == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 0; }        # s
    if (lower == 0x68) { vec_push(out, SVARA_PH_FRIC_H); return 0; }        # h
    if (lower == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 0; }        # f
    if (lower == 0x7A) { vec_push(out, SVARA_PH_FRIC_Z); return 0; }        # z
    return 0;
}

# Handle a single Devanagari consonant codepoint for Hindi. Returns 1 if `ch`
# was a recognized consonant (and pushed via push_consonant), else 0.
#must_use
fn _shabda_hindi_consonant(out, ch, next): i64 {
    # Velar
    if (ch == 0x0915) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_K, next); return 1; }   # क
    if (ch == 0x0916) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_K, next); return 1; }   # ख
    if (ch == 0x0917) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_G, next); return 1; }   # ग
    if (ch == 0x0918) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_G, next); return 1; }   # घ
    if (ch == 0x0919) { _shabda_hindi_push_consonant(out, SVARA_PH_NASAL_NG, next); return 1; }    # ङ
    # Palatal
    if (ch == 0x091A) { _shabda_hindi_push_consonant(out, SVARA_PH_AFFR_CH, next); return 1; }     # च
    if (ch == 0x091B) { _shabda_hindi_push_consonant(out, SVARA_PH_AFFR_CH, next); return 1; }     # छ
    if (ch == 0x091C) { _shabda_hindi_push_consonant(out, SVARA_PH_AFFR_J, next); return 1; }      # ज
    if (ch == 0x091D) { _shabda_hindi_push_consonant(out, SVARA_PH_AFFR_J, next); return 1; }      # झ
    if (ch == 0x091E) { _shabda_hindi_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # ञ
    # Retroflex
    if (ch == 0x091F) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # ट
    if (ch == 0x0920) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # ठ
    if (ch == 0x0921) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ड
    if (ch == 0x0922) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ढ
    if (ch == 0x0923) { _shabda_hindi_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # ण
    # Dental
    if (ch == 0x0924) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # त
    if (ch == 0x0925) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # थ
    if (ch == 0x0926) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # द
    if (ch == 0x0927) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ध
    if (ch == 0x0928) { _shabda_hindi_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # न
    # Labial
    if (ch == 0x092A) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_P, next); return 1; }   # प
    if (ch == 0x092B) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_P, next); return 1; }   # फ
    if (ch == 0x092C) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_B, next); return 1; }   # ब
    if (ch == 0x092D) { _shabda_hindi_push_consonant(out, SVARA_PH_PLOSIVE_B, next); return 1; }   # भ
    if (ch == 0x092E) { _shabda_hindi_push_consonant(out, SVARA_PH_NASAL_M, next); return 1; }     # म
    # Semivowels / liquids
    if (ch == 0x092F) { _shabda_hindi_push_consonant(out, SVARA_PH_APPROX_J, next); return 1; }    # य
    if (ch == 0x0930) { _shabda_hindi_push_consonant(out, SVARA_PH_TAP_FLAP, next); return 1; }    # र
    if (ch == 0x0932) { _shabda_hindi_push_consonant(out, SVARA_PH_LATERAL_L, next); return 1; }   # ल
    if (ch == 0x0935) { _shabda_hindi_push_consonant(out, SVARA_PH_FRIC_V, next); return 1; }      # व
    # Sibilants
    if (ch == 0x0936) { _shabda_hindi_push_consonant(out, SVARA_PH_FRIC_SH, next); return 1; }     # श
    if (ch == 0x0937) { _shabda_hindi_push_consonant(out, SVARA_PH_FRIC_SH, next); return 1; }     # ष
    if (ch == 0x0938) { _shabda_hindi_push_consonant(out, SVARA_PH_FRIC_S, next); return 1; }      # स
    if (ch == 0x0939) { _shabda_hindi_push_consonant(out, SVARA_PH_FRIC_H, next); return 1; }      # ह
    return 0;
}

# Public Hindi engine. Ports hindi_rules().
#must_use
fn shabda_hindi_rules(word): i64 {
    var chars = _shabda_decode_chars(word, 0);
    if (vec_len(chars) == 0) {
        return vec_new();
    }
    var phonemes = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        var ch = vec_get(chars, i);
        var next = _shabda_cp_at(chars, i + 1);

        # Independent vowels + matras.
        if (ch == 0x0905) { vec_push(phonemes, SVARA_PH_VOWEL_SCHWA); }
        elif (ch == 0x0906) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x093E) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x0907) { vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); }
        elif (ch == 0x093F) { vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); }
        elif (ch == 0x0908) { vec_push(phonemes, SVARA_PH_VOWEL_E); }
        elif (ch == 0x0940) { vec_push(phonemes, SVARA_PH_VOWEL_E); }
        elif (ch == 0x0909) { vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); }
        elif (ch == 0x0941) { vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); }
        elif (ch == 0x090A) { vec_push(phonemes, SVARA_PH_VOWEL_U); }
        elif (ch == 0x0942) { vec_push(phonemes, SVARA_PH_VOWEL_U); }
        elif (ch == 0x090F) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_E); }
        elif (ch == 0x0947) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_E); }
        elif (ch == 0x0910) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x0948) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x0913) { vec_push(phonemes, SVARA_PH_VOWEL_O); }
        elif (ch == 0x094B) { vec_push(phonemes, SVARA_PH_VOWEL_O); }
        elif (ch == 0x0914) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_O); }
        elif (ch == 0x094C) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_O); }
        elif (ch == 0x090B) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0943) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        # Nukta / virama — skip (base consonant already handled).
        elif (ch == 0x093C) { i = i; }
        elif (ch == 0x094D) { i = i; }
        # Anusvara / visarga / chandrabindu.
        elif (ch == 0x0902) { vec_push(phonemes, SVARA_PH_NASAL_N); }
        elif (ch == 0x0903) { vec_push(phonemes, SVARA_PH_FRIC_H); }
        elif (ch == 0x0901) { vec_push(phonemes, SVARA_PH_NASAL_N); }
        else {
            # Consonants, then Latin fallback, else skip.
            if (_shabda_hindi_consonant(phonemes, ch, next) == 0) {
                if (_shabda_rules_is_ascii_alpha(ch) == 1) {
                    _shabda_hindi_latin(phonemes, ch);
                }
            }
        }

        i = i + 1;
    }

    # Hindi schwa deletion: remove word-final schwa (only if len > 1).
    var pn = vec_len(phonemes);
    if (pn > 1) {
        if (vec_get(phonemes, pn - 1) == SVARA_PH_VOWEL_SCHWA) {
            vec_pop(phonemes);
        }
    }

    return phonemes;
}

# ================================================================
# Sanskrit G2P rules (Devanagari) — ports sanskrit_rules(). Same Devanagari
# codepoints as Hindi, but: NO word-final schwa deletion (schwa PRESERVATION),
# anusvara -> NasalM (not NasalN), and richer independent-vowel expansions
# (ai/au -> two phonemes; vocalic rr/l). Suppress set adds vocalic-rr matra
# (0x0944) and vocalic-l matra (0x0962).
# ================================================================

# Sanskrit suppress set for the inherent schwa. Ports push_sanskrit_consonant.
#must_use
fn _shabda_sanskrit_suppress(next): i64 {
    if (next == 0x093E) { return 1; }   # ा
    if (next == 0x093F) { return 1; }   # ि
    if (next == 0x0940) { return 1; }   # ी
    if (next == 0x0941) { return 1; }   # ु
    if (next == 0x0942) { return 1; }   # ू
    if (next == 0x0947) { return 1; }   # े
    if (next == 0x0948) { return 1; }   # ै
    if (next == 0x094B) { return 1; }   # ो
    if (next == 0x094C) { return 1; }   # ौ
    if (next == 0x0943) { return 1; }   # ृ vocalic r
    if (next == 0x0944) { return 1; }   # ॄ vocalic rr
    if (next == 0x0962) { return 1; }   # ॢ vocalic l
    if (next == 0x094D) { return 1; }   # ् virama
    if (next == 0x0902) { return 1; }   # ं anusvara
    if (next == 0x0901) { return 1; }   # ँ chandrabindu
    return 0;
}

# Push a Sanskrit consonant + inherent schwa unless suppressed.
fn _shabda_sanskrit_push_consonant(out, consonant, next): i64 {
    vec_push(out, consonant);
    if (_shabda_sanskrit_suppress(next) == 0) {
        vec_push(out, SVARA_PH_VOWEL_SCHWA);
    }
    return 0;
}

# Latin fallback for romanized Sanskrit (IAST-like). Ports the inline arm.
fn _shabda_sanskrit_latin(out, cp): i64 {
    var lower = _shabda_ascii_lower(cp);
    if (lower == 0x61) { vec_push(out, SVARA_PH_VOWEL_SCHWA); return 0; }   # a
    if (lower == 0x65) { vec_push(out, SVARA_PH_VOWEL_OPEN_E); return 0; }  # e
    if (lower == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 0; }  # i
    if (lower == 0x6F) { vec_push(out, SVARA_PH_VOWEL_O); return 0; }       # o
    if (lower == 0x75) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 0; }   # u
    if (lower == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }     # k
    if (lower == 0x67) { vec_push(out, SVARA_PH_PLOSIVE_G); return 0; }     # g
    if (lower == 0x63) { vec_push(out, SVARA_PH_AFFR_CH); return 0; }       # c
    if (lower == 0x6A) { vec_push(out, SVARA_PH_AFFR_J); return 0; }        # j
    if (lower == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 0; }     # t
    if (lower == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 0; }     # d
    if (lower == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 0; }       # n
    if (lower == 0x70) { vec_push(out, SVARA_PH_PLOSIVE_P); return 0; }     # p
    if (lower == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 0; }     # b
    if (lower == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 0; }       # m
    if (lower == 0x79) { vec_push(out, SVARA_PH_APPROX_J); return 0; }      # y
    if (lower == 0x72) { vec_push(out, SVARA_PH_TAP_FLAP); return 0; }      # r
    if (lower == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 0; }     # l
    if (lower == 0x76) { vec_push(out, SVARA_PH_FRIC_V); return 0; }        # v
    if (lower == 0x77) { vec_push(out, SVARA_PH_FRIC_V); return 0; }        # w
    if (lower == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 0; }        # s
    if (lower == 0x68) { vec_push(out, SVARA_PH_FRIC_H); return 0; }        # h
    return 0;
}

# Handle a Devanagari consonant for Sanskrit. Returns 1 if recognized else 0.
#must_use
fn _shabda_sanskrit_consonant(out, ch, next): i64 {
    if (ch == 0x0915) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_K, next); return 1; }   # क
    if (ch == 0x0916) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_K, next); return 1; }   # ख
    if (ch == 0x0917) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_G, next); return 1; }   # ग
    if (ch == 0x0918) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_G, next); return 1; }   # घ
    if (ch == 0x0919) { _shabda_sanskrit_push_consonant(out, SVARA_PH_NASAL_NG, next); return 1; }    # ङ
    if (ch == 0x091A) { _shabda_sanskrit_push_consonant(out, SVARA_PH_AFFR_CH, next); return 1; }     # च
    if (ch == 0x091B) { _shabda_sanskrit_push_consonant(out, SVARA_PH_AFFR_CH, next); return 1; }     # छ
    if (ch == 0x091C) { _shabda_sanskrit_push_consonant(out, SVARA_PH_AFFR_J, next); return 1; }      # ज
    if (ch == 0x091D) { _shabda_sanskrit_push_consonant(out, SVARA_PH_AFFR_J, next); return 1; }      # झ
    if (ch == 0x091E) { _shabda_sanskrit_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # ञ
    if (ch == 0x091F) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # ट
    if (ch == 0x0920) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # ठ
    if (ch == 0x0921) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ड
    if (ch == 0x0922) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ढ
    if (ch == 0x0923) { _shabda_sanskrit_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # ण
    if (ch == 0x0924) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # त
    if (ch == 0x0925) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_T, next); return 1; }   # थ
    if (ch == 0x0926) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # द
    if (ch == 0x0927) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_D, next); return 1; }   # ध
    if (ch == 0x0928) { _shabda_sanskrit_push_consonant(out, SVARA_PH_NASAL_N, next); return 1; }     # न
    if (ch == 0x092A) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_P, next); return 1; }   # प
    if (ch == 0x092B) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_P, next); return 1; }   # फ
    if (ch == 0x092C) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_B, next); return 1; }   # ब
    if (ch == 0x092D) { _shabda_sanskrit_push_consonant(out, SVARA_PH_PLOSIVE_B, next); return 1; }   # भ
    if (ch == 0x092E) { _shabda_sanskrit_push_consonant(out, SVARA_PH_NASAL_M, next); return 1; }     # म
    if (ch == 0x092F) { _shabda_sanskrit_push_consonant(out, SVARA_PH_APPROX_J, next); return 1; }    # य
    if (ch == 0x0930) { _shabda_sanskrit_push_consonant(out, SVARA_PH_TAP_FLAP, next); return 1; }    # र
    if (ch == 0x0932) { _shabda_sanskrit_push_consonant(out, SVARA_PH_LATERAL_L, next); return 1; }   # ल
    if (ch == 0x0935) { _shabda_sanskrit_push_consonant(out, SVARA_PH_FRIC_V, next); return 1; }      # व
    if (ch == 0x0936) { _shabda_sanskrit_push_consonant(out, SVARA_PH_FRIC_SH, next); return 1; }     # श
    if (ch == 0x0937) { _shabda_sanskrit_push_consonant(out, SVARA_PH_FRIC_SH, next); return 1; }     # ष
    if (ch == 0x0938) { _shabda_sanskrit_push_consonant(out, SVARA_PH_FRIC_S, next); return 1; }      # स
    if (ch == 0x0939) { _shabda_sanskrit_push_consonant(out, SVARA_PH_FRIC_H, next); return 1; }      # ह
    return 0;
}

# Public Sanskrit engine. Ports sanskrit_rules().
#must_use
fn shabda_sanskrit_rules(word): i64 {
    var chars = _shabda_decode_chars(word, 0);
    if (vec_len(chars) == 0) {
        return vec_new();
    }
    var phonemes = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        var ch = vec_get(chars, i);
        var next = _shabda_cp_at(chars, i + 1);

        # Independent vowels + matras.
        if (ch == 0x0905) { vec_push(phonemes, SVARA_PH_VOWEL_SCHWA); }
        elif (ch == 0x0906) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x093E) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }
        elif (ch == 0x0907) { vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); }
        elif (ch == 0x093F) { vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); }
        elif (ch == 0x0908) { vec_push(phonemes, SVARA_PH_VOWEL_E); }
        elif (ch == 0x0940) { vec_push(phonemes, SVARA_PH_VOWEL_E); }
        elif (ch == 0x0909) { vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); }
        elif (ch == 0x0941) { vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); }
        elif (ch == 0x090A) { vec_push(phonemes, SVARA_PH_VOWEL_U); }
        elif (ch == 0x0942) { vec_push(phonemes, SVARA_PH_VOWEL_U); }
        elif (ch == 0x090B) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0943) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0960) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_E);
        }
        elif (ch == 0x0944) {
            vec_push(phonemes, SVARA_PH_TAP_FLAP); vec_push(phonemes, SVARA_PH_VOWEL_E);
        }
        elif (ch == 0x090C) {
            vec_push(phonemes, SVARA_PH_LATERAL_L); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0962) {
            vec_push(phonemes, SVARA_PH_LATERAL_L); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x090F) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_E); }
        elif (ch == 0x0947) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_E); }
        elif (ch == 0x0910) {
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0948) {
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I);
        }
        elif (ch == 0x0913) { vec_push(phonemes, SVARA_PH_VOWEL_O); }
        elif (ch == 0x094B) { vec_push(phonemes, SVARA_PH_VOWEL_O); }
        elif (ch == 0x0914) {
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); vec_push(phonemes, SVARA_PH_VOWEL_CUP_V);
        }
        elif (ch == 0x094C) {
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); vec_push(phonemes, SVARA_PH_VOWEL_CUP_V);
        }
        # Virama / nukta — skip.
        elif (ch == 0x094D) { i = i; }
        elif (ch == 0x093C) { i = i; }
        # Anusvara -> NasalM (Sanskrit), visarga -> FricH.
        elif (ch == 0x0902) { vec_push(phonemes, SVARA_PH_NASAL_M); }
        elif (ch == 0x0903) { vec_push(phonemes, SVARA_PH_FRIC_H); }
        else {
            if (_shabda_sanskrit_consonant(phonemes, ch, next) == 0) {
                if (_shabda_rules_is_ascii_alpha(ch) == 1) {
                    _shabda_sanskrit_latin(phonemes, ch);
                }
            }
        }

        i = i + 1;
    }

    # Sanskrit: NO schwa deletion (preservation).
    return phonemes;
}

# ================================================================
# Arabic G2P rules — ports arabic_rules(). Abjad: 28 letters (emphatics collapsed
# to their plain counterparts), hamza/ain -> GlottalStop, harakat (fatha/kasra/
# damma), tanween -> V+n, shadda -> duplicate previous phoneme, taa marbuta,
# alef maqsura, + ASCII romanized fallback. Iterates codepoint-by-codepoint with
# no lookahead (Rust `for &ch in &chars`). Word decoded WITHOUT ASCII-lowering.
# ================================================================

# Latin fallback for romanized Arabic. Pushes phoneme(s) for an ASCII letter.
fn _shabda_arabic_latin(out, cp): i64 {
    var lower = _shabda_ascii_lower(cp);
    if (lower == 0x61) { vec_push(out, SVARA_PH_VOWEL_OPEN_A); return 0; }  # a
    if (lower == 0x69) { vec_push(out, SVARA_PH_VOWEL_NEAR_I); return 0; }  # i
    if (lower == 0x75) { vec_push(out, SVARA_PH_VOWEL_CUP_V); return 0; }   # u
    if (lower == 0x62) { vec_push(out, SVARA_PH_PLOSIVE_B); return 0; }     # b
    if (lower == 0x74) { vec_push(out, SVARA_PH_PLOSIVE_T); return 0; }     # t
    if (lower == 0x64) { vec_push(out, SVARA_PH_PLOSIVE_D); return 0; }     # d
    if (lower == 0x6B) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }     # k
    if (lower == 0x66) { vec_push(out, SVARA_PH_FRIC_F); return 0; }        # f
    if (lower == 0x73) { vec_push(out, SVARA_PH_FRIC_S); return 0; }        # s
    if (lower == 0x7A) { vec_push(out, SVARA_PH_FRIC_Z); return 0; }        # z
    if (lower == 0x68) { vec_push(out, SVARA_PH_FRIC_H); return 0; }        # h
    if (lower == 0x6C) { vec_push(out, SVARA_PH_LATERAL_L); return 0; }     # l
    if (lower == 0x6D) { vec_push(out, SVARA_PH_NASAL_M); return 0; }       # m
    if (lower == 0x6E) { vec_push(out, SVARA_PH_NASAL_N); return 0; }       # n
    if (lower == 0x72) { vec_push(out, SVARA_PH_TAP_FLAP); return 0; }      # r
    if (lower == 0x77) { vec_push(out, SVARA_PH_APPROX_W); return 0; }      # w
    if (lower == 0x79) { vec_push(out, SVARA_PH_APPROX_J); return 0; }      # y
    if (lower == 0x6A) { vec_push(out, SVARA_PH_AFFR_J); return 0; }        # j
    if (lower == 0x71) { vec_push(out, SVARA_PH_PLOSIVE_K); return 0; }     # q
    return 0;
}

# Public Arabic engine. Ports arabic_rules().
#must_use
fn shabda_arabic_rules(word): i64 {
    var chars = _shabda_decode_chars(word, 0);
    if (vec_len(chars) == 0) {
        return vec_new();
    }
    var phonemes = vec_new();
    var i = 0;
    var n = vec_len(chars);
    while (i < n) {
        var ch = vec_get(chars, i);

        # Consonants.
        if (ch == 0x0628) { vec_push(phonemes, SVARA_PH_PLOSIVE_B); }       # ب
        elif (ch == 0x062A) { vec_push(phonemes, SVARA_PH_PLOSIVE_T); }     # ت
        elif (ch == 0x062B) { vec_push(phonemes, SVARA_PH_FRIC_TH); }       # ث
        elif (ch == 0x062C) { vec_push(phonemes, SVARA_PH_AFFR_J); }        # ج
        elif (ch == 0x062D) { vec_push(phonemes, SVARA_PH_FRIC_H); }        # ح /ħ/
        elif (ch == 0x062E) { vec_push(phonemes, SVARA_PH_FRIC_H); }        # خ /x/
        elif (ch == 0x062F) { vec_push(phonemes, SVARA_PH_PLOSIVE_D); }     # د
        elif (ch == 0x0630) { vec_push(phonemes, SVARA_PH_FRIC_DH); }       # ذ
        elif (ch == 0x0631) { vec_push(phonemes, SVARA_PH_TAP_FLAP); }      # ر
        elif (ch == 0x0632) { vec_push(phonemes, SVARA_PH_FRIC_Z); }        # ز
        elif (ch == 0x0633) { vec_push(phonemes, SVARA_PH_FRIC_S); }        # س
        elif (ch == 0x0634) { vec_push(phonemes, SVARA_PH_FRIC_SH); }       # ش
        elif (ch == 0x0635) { vec_push(phonemes, SVARA_PH_FRIC_S); }        # ص emphatic /s/
        elif (ch == 0x0636) { vec_push(phonemes, SVARA_PH_PLOSIVE_D); }     # ض emphatic /d/
        elif (ch == 0x0637) { vec_push(phonemes, SVARA_PH_PLOSIVE_T); }     # ط emphatic /t/
        elif (ch == 0x0638) { vec_push(phonemes, SVARA_PH_FRIC_DH); }       # ظ emphatic /ð/
        elif (ch == 0x0639) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }  # ع /ʕ/ -> glottal
        elif (ch == 0x063A) { vec_push(phonemes, SVARA_PH_PLOSIVE_G); }     # غ /ɣ/
        elif (ch == 0x0641) { vec_push(phonemes, SVARA_PH_FRIC_F); }        # ف
        elif (ch == 0x0642) { vec_push(phonemes, SVARA_PH_PLOSIVE_K); }     # ق /q/
        elif (ch == 0x0643) { vec_push(phonemes, SVARA_PH_PLOSIVE_K); }     # ك
        elif (ch == 0x0644) { vec_push(phonemes, SVARA_PH_LATERAL_L); }     # ل
        elif (ch == 0x0645) { vec_push(phonemes, SVARA_PH_NASAL_M); }       # م
        elif (ch == 0x0646) { vec_push(phonemes, SVARA_PH_NASAL_N); }       # ن
        elif (ch == 0x0647) { vec_push(phonemes, SVARA_PH_FRIC_H); }        # ه
        elif (ch == 0x0648) { vec_push(phonemes, SVARA_PH_APPROX_W); }      # و
        elif (ch == 0x064A) { vec_push(phonemes, SVARA_PH_APPROX_J); }      # ي
        # Hamza (glottal stop): ء أ إ ؤ ئ.
        elif (ch == 0x0621) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }
        elif (ch == 0x0623) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }
        elif (ch == 0x0625) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }
        elif (ch == 0x0624) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }
        elif (ch == 0x0626) { vec_push(phonemes, SVARA_PH_GLOTTAL_STOP); }
        # Alef (long /aː/).
        elif (ch == 0x0627) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }  # ا
        elif (ch == 0x0622) {                                               # آ
            vec_push(phonemes, SVARA_PH_GLOTTAL_STOP);
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A);
        }
        # Taa marbuta.
        elif (ch == 0x0629) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }  # ة
        # Short vowel diacritics.
        elif (ch == 0x064E) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }  # fatha /a/
        elif (ch == 0x0650) { vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); }  # kasra /i/
        elif (ch == 0x064F) { vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); }   # damma /u/
        # Tanween (nunation) -> V + n.
        elif (ch == 0x064B) {
            vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); vec_push(phonemes, SVARA_PH_NASAL_N);
        }
        elif (ch == 0x064D) {
            vec_push(phonemes, SVARA_PH_VOWEL_NEAR_I); vec_push(phonemes, SVARA_PH_NASAL_N);
        }
        elif (ch == 0x064C) {
            vec_push(phonemes, SVARA_PH_VOWEL_CUP_V); vec_push(phonemes, SVARA_PH_NASAL_N);
        }
        # Sukun (no vowel) — skip.
        elif (ch == 0x0652) { i = i; }
        # Shadda (gemination) — repeat the previous phoneme.
        elif (ch == 0x0651) {
            var pn = vec_len(phonemes);
            if (pn > 0) {
                vec_push(phonemes, vec_get(phonemes, pn - 1));
            }
        }
        # Alef maqsura.
        elif (ch == 0x0649) { vec_push(phonemes, SVARA_PH_VOWEL_OPEN_A); }  # ى
        else {
            # Latin fallback for romanized Arabic, else skip.
            if (_shabda_rules_is_ascii_alpha(ch) == 1) {
                _shabda_arabic_latin(phonemes, ch);
            }
        }

        i = i + 1;
    }

    return phonemes;
}

# --- prosody.cyr ---

# prosody.cyr — prosody assignment: stress patterns, emphasis, rate, timing,
# and sentence intonation.
#
# Ports rust-old/src/prosody.rs. Maps sentence structure and word class to
# stress and intonation, producing svara-compatible PhonemeEvents.
#
# DEP POSITION: svara (PhonemeEvent ctor + accessors, phoneme class/duration,
# Stress/Intonation consts, SVARA_PH_SILENCE) + src/error.cyr (SentenceType tags,
# SHABDA_NO_STRESS_IDX, SHABDA_TIMING_* layout offsets) + src/syllable.cyr
# (Syllable accessors + shabda_syllable_is_heavy). The entry file includes all of
# those ABOVE this module. Modules never include each other.
#
# PhonemeEvent is immutable-by-handle in Cyrius: the Rust `event.stress = ...` /
# `event.duration *= ...` in-place mutations are re-expressed by rebuilding the
# event via svara_phoneme_event_new(phoneme, dur, stress) and vec_set-ing it back.
#
# Float parity: every Rust f32 constant is promoted to f64 (svara durations are
# f64 bits). The f64 arithmetic/comparison intrinsics (f64_mul/f64_gt/f64_lt/
# f64_from) are compiler builtins; clamp/max are inlined here (math.cyr is not in
# the include set).
#
# NAMING: public surface is `shabda_`-prefixed; private helpers are
# `_shabda_prosody_*` to keep the flat link namespace collision-free.

# ---- Promoted f64 constants (were Rust f32) ----------------------------------
# DEFAULT_WPM = 150.0
var SHABDA_PROSODY_DEFAULT_WPM = 0x4062_C000_0000_0000;
# MIN_WPM = 50.0
var SHABDA_PROSODY_MIN_WPM = 0x4049_0000_0000_0000;
# MAX_WPM = 300.0
var SHABDA_PROSODY_MAX_WPM = 0x4072_C000_0000_0000;
# MIN_CONSONANT_DURATION = 0.03
var SHABDA_PROSODY_MIN_CONSONANT_DURATION = 0x3F9E_B851_EB85_1EB8;
# MIN_VOWEL_DURATION = 0.05
var SHABDA_PROSODY_MIN_VOWEL_DURATION = 0x3FA9_9999_9999_999A;
# EMPHASIS_DURATION_SCALE = 1.3
var SHABDA_PROSODY_EMPHASIS_DURATION_SCALE = 0x3FF4_CCCC_CCCC_CCCD;

# ---- Private helpers ---------------------------------------------------------
# True if the phoneme is a vowel or diphthong (stress-bearing).
fn _shabda_prosody_is_vowel_like(ph): i64 {
    var c = svara_phoneme_class(ph);
    if (c == SVARA_CLASS_VOWEL) { return 1; }
    if (c == SVARA_CLASS_DIPHTHONG) { return 1; }
    return 0;
}

# f64 max(a, b) — larger of two IEEE-754 f64 bit patterns.
fn _shabda_prosody_f64_max(a, b): i64 {
    if (f64_gt(a, b) == 1) { return a; }
    return b;
}

# f64 clamp(x, lo, hi).
fn _shabda_prosody_f64_clamp(x, lo, hi): i64 {
    if (f64_lt(x, lo) == 1) { return lo; }
    if (f64_gt(x, hi) == 1) { return hi; }
    return x;
}

# ---- assign_stress -----------------------------------------------------------
# Convert a word's phoneme sequence (vec of ordinals) into PhonemeEvents with
# stress. First vowel-like ph in a content word -> Primary, later vowel-like ->
# Secondary, else Unstressed; function words -> all Unstressed.
#must_use
fn shabda_assign_stress(phonemes, is_content_word): i64 {
    var events = vec_new();
    var found_primary = 0;
    var n = vec_len(phonemes);
    var i = 0;
    while (i < n) {
        var ph = vec_get(phonemes, i);
        var dur = svara_phoneme_duration(ph);
        var stress = SVARA_STRESS_UNSTRESSED;
        if (is_content_word == 0) {
            stress = SVARA_STRESS_UNSTRESSED;
        } elif ((_shabda_prosody_is_vowel_like(ph) == 1) & (found_primary == 0)) {
            found_primary = 1;
            stress = SVARA_STRESS_PRIMARY;
        } elif (_shabda_prosody_is_vowel_like(ph) == 1) {
            stress = SVARA_STRESS_SECONDARY;
        } else {
            stress = SVARA_STRESS_UNSTRESSED;
        }
        vec_push(events, svara_phoneme_event_new(ph, dur, stress));
        i = i + 1;
    }
    return events;
}

# ---- assign_stress_syllabic --------------------------------------------------
# Assign stress using syllable-weight analysis over a vec of Syllable*.
# Monosyllable/2-syllable -> stress first; heavy penult -> penult; else
# antepenult; function words -> none.
#must_use
fn shabda_assign_stress_syllabic(syllables, is_content_word): i64 {
    var events = vec_new();
    var len = vec_len(syllables);
    if (len == 0) { return events; }

    # Determine which syllable index gets primary stress.
    var primary_idx = SHABDA_NO_STRESS_IDX;
    if (is_content_word == 0) {
        primary_idx = SHABDA_NO_STRESS_IDX;
    } elif (len <= 2) {
        primary_idx = 0;
    } else {
        var penult = len - 2;
        if (shabda_syllable_is_heavy(vec_get(syllables, penult)) == 1) {
            primary_idx = penult;
        } else {
            # Stress antepenult (third from end); Rust saturating_sub(3).
            if (len >= 3) {
                primary_idx = len - 3;
            } else {
                primary_idx = 0;
            }
        }
    }

    var syl_idx = 0;
    while (syl_idx < len) {
        var syllable = vec_get(syllables, syl_idx);
        var syl_stress = SVARA_STRESS_UNSTRESSED;
        if (syl_idx == primary_idx) {
            syl_stress = SVARA_STRESS_PRIMARY;
        } else {
            syl_stress = SVARA_STRESS_UNSTRESSED;
        }

        # Onset: unstressed.
        var onset = shabda_syllable_onset(syllable);
        var on = vec_len(onset);
        var oi = 0;
        while (oi < on) {
            var oph = vec_get(onset, oi);
            var odur = svara_phoneme_duration(oph);
            vec_push(events, svara_phoneme_event_new(oph, odur, SVARA_STRESS_UNSTRESSED));
            oi = oi + 1;
        }
        # Nucleus: carries the syllable's stress.
        var nuc = shabda_syllable_nucleus(syllable);
        var ndur = svara_phoneme_duration(nuc);
        vec_push(events, svara_phoneme_event_new(nuc, ndur, syl_stress));
        # Coda: unstressed.
        var coda = shabda_syllable_coda(syllable);
        var cn = vec_len(coda);
        var ci = 0;
        while (ci < cn) {
            var cph = vec_get(coda, ci);
            var cdur = svara_phoneme_duration(cph);
            vec_push(events, svara_phoneme_event_new(cph, cdur, SVARA_STRESS_UNSTRESSED));
            ci = ci + 1;
        }

        syl_idx = syl_idx + 1;
    }

    return events;
}

# ---- is_content_word ---------------------------------------------------------
# 1 if `word` (cstr) is a content word, 0 if it is one of the ~40 English
# function words. Compares the ASCII-lowercased word against the function set.
#must_use
fn shabda_is_content_word(word): i64 {
    var w = str_lower_cstr(word);
    if (streq(w, "a") == 1) { return 0; }
    if (streq(w, "an") == 1) { return 0; }
    if (streq(w, "the") == 1) { return 0; }
    if (streq(w, "is") == 1) { return 0; }
    if (streq(w, "am") == 1) { return 0; }
    if (streq(w, "are") == 1) { return 0; }
    if (streq(w, "was") == 1) { return 0; }
    if (streq(w, "were") == 1) { return 0; }
    if (streq(w, "be") == 1) { return 0; }
    if (streq(w, "been") == 1) { return 0; }
    if (streq(w, "to") == 1) { return 0; }
    if (streq(w, "of") == 1) { return 0; }
    if (streq(w, "in") == 1) { return 0; }
    if (streq(w, "on") == 1) { return 0; }
    if (streq(w, "at") == 1) { return 0; }
    if (streq(w, "by") == 1) { return 0; }
    if (streq(w, "for") == 1) { return 0; }
    if (streq(w, "and") == 1) { return 0; }
    if (streq(w, "or") == 1) { return 0; }
    if (streq(w, "but") == 1) { return 0; }
    if (streq(w, "if") == 1) { return 0; }
    if (streq(w, "it") == 1) { return 0; }
    if (streq(w, "he") == 1) { return 0; }
    if (streq(w, "she") == 1) { return 0; }
    if (streq(w, "we") == 1) { return 0; }
    if (streq(w, "they") == 1) { return 0; }
    if (streq(w, "that") == 1) { return 0; }
    if (streq(w, "this") == 1) { return 0; }
    if (streq(w, "with") == 1) { return 0; }
    if (streq(w, "not") == 1) { return 0; }
    if (streq(w, "do") == 1) { return 0; }
    if (streq(w, "did") == 1) { return 0; }
    if (streq(w, "has") == 1) { return 0; }
    if (streq(w, "had") == 1) { return 0; }
    if (streq(w, "have") == 1) { return 0; }
    return 1;
}

# ---- apply_emphasis ----------------------------------------------------------
# Boost every vowel-like event to Primary stress and scale its duration by 1.3x.
# Rebuilds each mutated event in place (immutable-by-handle).
fn shabda_apply_emphasis(events): i64 {
    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        var ph = SvPhonemeEvent_phoneme(e);
        if (_shabda_prosody_is_vowel_like(ph) == 1) {
            var dur = f64_mul(SvPhonemeEvent_duration(e), SHABDA_PROSODY_EMPHASIS_DURATION_SCALE);
            vec_set(events, i, svara_phoneme_event_new(ph, dur, SVARA_STRESS_PRIMARY));
        }
        i = i + 1;
    }
    return 0;
}

# ---- apply_rate --------------------------------------------------------------
# Scale event durations to a target speaking rate (WPM clamped to 50..300).
# scale = 150/clamped; enforce per-class minimum durations.
fn shabda_apply_rate(events, target_wpm): i64 {
    var clamped_wpm = _shabda_prosody_f64_clamp(target_wpm, SHABDA_PROSODY_MIN_WPM, SHABDA_PROSODY_MAX_WPM);
    var scale = f64_div(SHABDA_PROSODY_DEFAULT_WPM, clamped_wpm);

    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        var ph = SvPhonemeEvent_phoneme(e);
        var scaled = f64_mul(SvPhonemeEvent_duration(e), scale);
        var min = SHABDA_PROSODY_MIN_CONSONANT_DURATION;
        if (_shabda_prosody_is_vowel_like(ph) == 1) {
            min = SHABDA_PROSODY_MIN_VOWEL_DURATION;
        }
        var dur = _shabda_prosody_f64_max(scaled, min);
        vec_set(events, i, svara_phoneme_event_new(ph, dur, SvPhonemeEvent_stress(e)));
        i = i + 1;
    }
    return 0;
}

# ---- apply_timing ------------------------------------------------------------
# Scale each event's duration by a per-category factor from a TimingProfile:
# silence -> pause_scale, vowel-like -> vowel_scale, else consonant_scale. The
# profile stores three f64-bit scales at the SHABDA_TIMING_* offsets.
fn shabda_apply_timing(events, profile): i64 {
    var vowel_scale = load64(profile + SHABDA_TIMING_VOWEL);
    var consonant_scale = load64(profile + SHABDA_TIMING_CONSONANT);
    var pause_scale = load64(profile + SHABDA_TIMING_PAUSE);

    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        var ph = SvPhonemeEvent_phoneme(e);
        var scale = consonant_scale;
        if (ph == SVARA_PH_SILENCE) {
            scale = pause_scale;
        } elif (_shabda_prosody_is_vowel_like(ph) == 1) {
            scale = vowel_scale;
        } else {
            scale = consonant_scale;
        }
        var dur = f64_mul(SvPhonemeEvent_duration(e), scale);
        vec_set(events, i, svara_phoneme_event_new(ph, dur, SvPhonemeEvent_stress(e)));
        i = i + 1;
    }
    return 0;
}

# ---- sentence_intonation -----------------------------------------------------
# Map a SentenceType tag to a svara IntonationPattern.
#must_use
fn shabda_sentence_intonation(sentence_type): i64 {
    if (sentence_type == SHABDA_STYPE_STATEMENT) { return SVARA_INTONATION_DECLARATIVE; }
    if (sentence_type == SHABDA_STYPE_QUESTION) { return SVARA_INTONATION_INTERROGATIVE; }
    if (sentence_type == SHABDA_STYPE_EXCLAMATION) { return SVARA_INTONATION_EXCLAMATORY; }
    return SVARA_INTONATION_DECLARATIVE;
}

# --- validate.cyr ---

# validate.cyr — phoneme inventory + phonotactic validation via varna.
#
# Ports rust-old/src/validate.rs. In Rust the whole module is
# #[cfg(feature = "varna")]; here it is compiled UNCONDITIONALLY (varna is a
# hard dep of the Cyrius port, mirroring shabdakosh's always-on inventory).
#
# Verifies that phoneme output from the G2P rules is valid for a target
# language's phoneme inventory as defined by varna. Every IPA string below MUST
# match the Rust oracle byte-for-byte — downstream tests assert exact strings.
#
# DEP POSITION: svara + varna. The entry file (tests/validate.tcyr / main.cyr)
# includes lib/svara.cyr (SVARA_PH_* ordinals + SVARA_CLASS_* + phoneme class
# query), lib/varna.cyr (phoneme_english/… inventories, phoneme_has,
# phonotactics_english + max_onset/max_coda) and src/error.cyr (SHABDA_LANG_*,
# SHABDA_PH_NONE) ABOVE this module. Modules never include each other.
#
# A svara Phoneme is an i64 ordinal (0..SVARA_PH_SILENCE). Rust's Option::None
# on an IPA lookup becomes the sentinel 0 (a null cstr pointer) — a phoneme with
# no IPA in the given inventory returns 0. Report Strings become cstr vecs.
#
# NAMING: public surface is `shabda_`-prefixed; private helpers are
# `_shabda_validate_<name>` (flat link namespace, avoids duplicate-fn clashes).

# ================================================================
# Phoneme -> &'static str IPA tables. Six of them, one per language. Each is an
# if-chain over the svara phoneme ordinal returning a cstring; a phoneme with no
# single-IPA equivalent (Silence, inventory gaps) returns 0 (== Rust None).
# ================================================================

# English (was `phoneme_to_ipa`). Returns 0 for Silence and for the four
# phonemes valid in English but absent from varna 1.0's inventory (DiphthongAI,
# DiphthongAU, DiphthongOI, VowelBird) — see VARNA_INVENTORY_GAPS below.
#must_use
fn shabda_phoneme_to_ipa(phoneme): cstring {
    # Vowels
    if (phoneme == SVARA_PH_VOWEL_A)       { return "ɑː"; }
    if (phoneme == SVARA_PH_VOWEL_E)       { return "iː"; }
    if (phoneme == SVARA_PH_VOWEL_I)       { return "ɪ"; }
    if (phoneme == SVARA_PH_VOWEL_O)       { return "oʊ"; }
    if (phoneme == SVARA_PH_VOWEL_U)       { return "uː"; }
    if (phoneme == SVARA_PH_VOWEL_SCHWA)   { return "ə"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_O)  { return "ɔː"; }
    if (phoneme == SVARA_PH_VOWEL_ASH)     { return "æ"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "ɪ"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_U)  { return "ʊ"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "ɑː"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_E)  { return "ɛ"; }
    if (phoneme == SVARA_PH_VOWEL_CUP_V)   { return "ʌ"; }
    if (phoneme == SVARA_PH_VOWEL_LONG_I)  { return "iː"; }
    # NURSE vowel (ɜː) — valid English, not yet in varna 1.0 inventory  #skip-lint
    if (phoneme == SVARA_PH_VOWEL_BIRD)    { return 0; }
    # Diphthongs present in varna's English inventory
    if (phoneme == SVARA_PH_DIPH_EI)       { return "eɪ"; }
    if (phoneme == SVARA_PH_DIPH_OU)       { return "oʊ"; }
    # Diphthongs valid in English but not yet in varna 1.0 inventory  #skip-lint
    if (phoneme == SVARA_PH_DIPH_AI)       { return 0; }
    if (phoneme == SVARA_PH_DIPH_AU)       { return 0; }
    if (phoneme == SVARA_PH_DIPH_OI)       { return 0; }
    # Plosives
    if (phoneme == SVARA_PH_PLOSIVE_P)     { return "p"; }
    if (phoneme == SVARA_PH_PLOSIVE_B)     { return "b"; }
    if (phoneme == SVARA_PH_PLOSIVE_T)     { return "t"; }
    if (phoneme == SVARA_PH_PLOSIVE_D)     { return "d"; }
    if (phoneme == SVARA_PH_PLOSIVE_K)     { return "k"; }
    if (phoneme == SVARA_PH_PLOSIVE_G)     { return "ɡ"; }
    # Fricatives
    if (phoneme == SVARA_PH_FRIC_F)        { return "f"; }
    if (phoneme == SVARA_PH_FRIC_V)        { return "v"; }
    if (phoneme == SVARA_PH_FRIC_S)        { return "s"; }
    if (phoneme == SVARA_PH_FRIC_Z)        { return "z"; }
    if (phoneme == SVARA_PH_FRIC_SH)       { return "ʃ"; }
    if (phoneme == SVARA_PH_FRIC_ZH)       { return "ʒ"; }
    if (phoneme == SVARA_PH_FRIC_TH)       { return "θ"; }
    if (phoneme == SVARA_PH_FRIC_DH)       { return "ð"; }
    if (phoneme == SVARA_PH_FRIC_H)        { return "h"; }
    # Nasals
    if (phoneme == SVARA_PH_NASAL_M)       { return "m"; }
    if (phoneme == SVARA_PH_NASAL_N)       { return "n"; }
    if (phoneme == SVARA_PH_NASAL_NG)      { return "ŋ"; }
    # Affricates
    if (phoneme == SVARA_PH_AFFR_CH)       { return "t͡ʃ"; }
    if (phoneme == SVARA_PH_AFFR_J)        { return "d͡ʒ"; }
    # Approximants & lateral
    if (phoneme == SVARA_PH_APPROX_R)      { return "ɹ"; }
    if (phoneme == SVARA_PH_APPROX_W)      { return "w"; }
    if (phoneme == SVARA_PH_APPROX_J)      { return "j"; }
    if (phoneme == SVARA_PH_LATERAL_L)     { return "l"; }
    # Not in English inventory (but do have an IPA in the mapping)
    if (phoneme == SVARA_PH_GLOTTAL_STOP)  { return "ʔ"; }
    if (phoneme == SVARA_PH_TAP_FLAP)      { return "ɾ"; }
    if (phoneme == SVARA_PH_SILENCE)       { return 0; }
    # #[non_exhaustive] fallback (Rust `_ => None`).
    return 0;
}

# Spanish (was `spanish_phoneme_to_ipa`).
#must_use
fn shabda_spanish_phoneme_to_ipa(phoneme): cstring {
    # Spanish vowels (5 pure vowels)
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "a"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_E)  { return "e"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "i"; }
    if (phoneme == SVARA_PH_VOWEL_O)       { return "o"; }
    if (phoneme == SVARA_PH_VOWEL_CUP_V)   { return "u"; }
    # Plosives
    if (phoneme == SVARA_PH_PLOSIVE_P)     { return "p"; }
    if (phoneme == SVARA_PH_PLOSIVE_B)     { return "b"; }
    if (phoneme == SVARA_PH_PLOSIVE_T)     { return "t"; }
    if (phoneme == SVARA_PH_PLOSIVE_D)     { return "d"; }
    if (phoneme == SVARA_PH_PLOSIVE_K)     { return "k"; }
    if (phoneme == SVARA_PH_PLOSIVE_G)     { return "ɡ"; }
    # Fricatives
    if (phoneme == SVARA_PH_FRIC_F)        { return "f"; }
    if (phoneme == SVARA_PH_FRIC_TH)       { return "θ"; }
    if (phoneme == SVARA_PH_FRIC_S)        { return "s"; }
    if (phoneme == SVARA_PH_FRIC_H)        { return "x"; }   # Spanish /x/ (jota)
    # Nasals
    if (phoneme == SVARA_PH_NASAL_M)       { return "m"; }
    if (phoneme == SVARA_PH_NASAL_N)       { return "n"; }
    if (phoneme == SVARA_PH_NASAL_NG)      { return "ɲ"; }   # ñ -> palatal nasal
    # Liquids & approximants
    if (phoneme == SVARA_PH_LATERAL_L)     { return "l"; }
    if (phoneme == SVARA_PH_TAP_FLAP)      { return "r"; }   # Spanish tap
    if (phoneme == SVARA_PH_APPROX_R)      { return "rr"; }  # Spanish trill
    if (phoneme == SVARA_PH_APPROX_J)      { return "j"; }
    if (phoneme == SVARA_PH_APPROX_W)      { return "w"; }
    # Affricate
    if (phoneme == SVARA_PH_AFFR_CH)       { return "t͡ʃ"; }
    # No IPA in Spanish
    if (phoneme == SVARA_PH_SILENCE)       { return 0; }
    return 0;
}

# German (was `german_phoneme_to_ipa`).
#must_use
fn shabda_german_phoneme_to_ipa(phoneme): cstring {
    # Vowels (short)
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "ɪ"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_E)  { return "ɛ"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "a"; }
    if (phoneme == SVARA_PH_VOWEL_SCHWA)   { return "ə"; }
    # Vowels (long)
    if (phoneme == SVARA_PH_VOWEL_E)       { return "iː"; }
    if (phoneme == SVARA_PH_VOWEL_O)       { return "oː"; }
    if (phoneme == SVARA_PH_VOWEL_U)       { return "uː"; }
    if (phoneme == SVARA_PH_VOWEL_ASH)     { return "aː"; }
    # Plosives
    if (phoneme == SVARA_PH_PLOSIVE_P)     { return "p"; }
    if (phoneme == SVARA_PH_PLOSIVE_B)     { return "b"; }
    if (phoneme == SVARA_PH_PLOSIVE_T)     { return "t"; }
    if (phoneme == SVARA_PH_PLOSIVE_D)     { return "d"; }
    if (phoneme == SVARA_PH_PLOSIVE_K)     { return "k"; }
    if (phoneme == SVARA_PH_PLOSIVE_G)     { return "ɡ"; }
    # Fricatives
    if (phoneme == SVARA_PH_FRIC_F)        { return "f"; }
    if (phoneme == SVARA_PH_FRIC_V)        { return "v"; }
    if (phoneme == SVARA_PH_FRIC_S)        { return "s"; }
    if (phoneme == SVARA_PH_FRIC_Z)        { return "z"; }
    if (phoneme == SVARA_PH_FRIC_SH)       { return "ʃ"; }
    if (phoneme == SVARA_PH_FRIC_H)        { return "h"; }
    # Nasals
    if (phoneme == SVARA_PH_NASAL_M)       { return "m"; }
    if (phoneme == SVARA_PH_NASAL_N)       { return "n"; }
    if (phoneme == SVARA_PH_NASAL_NG)      { return "ŋ"; }
    # Affricates
    if (phoneme == SVARA_PH_AFFR_CH)       { return "t͡ʃ"; }
    # Approximants & lateral
    if (phoneme == SVARA_PH_APPROX_J)      { return "j"; }
    if (phoneme == SVARA_PH_LATERAL_L)     { return "l"; }
    if (phoneme == SVARA_PH_APPROX_R)      { return "ʁ"; }
    # Not mapped
    if (phoneme == SVARA_PH_SILENCE)       { return 0; }
    return 0;
}

# Hindi (was `hindi_phoneme_to_ipa`).
#must_use
fn shabda_hindi_phoneme_to_ipa(phoneme): cstring {
    # Vowels
    if (phoneme == SVARA_PH_VOWEL_SCHWA)   { return "ə"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "i"; }
    if (phoneme == SVARA_PH_VOWEL_E)       { return "iː"; }
    if (phoneme == SVARA_PH_VOWEL_CUP_V)   { return "u"; }
    if (phoneme == SVARA_PH_VOWEL_U)       { return "uː"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_E)  { return "e"; }
    if (phoneme == SVARA_PH_VOWEL_O)       { return "o"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "ɛː"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_O)  { return "ɔː"; }
    # Plosives (unaspirated only)
    if (phoneme == SVARA_PH_PLOSIVE_P)     { return "p"; }
    if (phoneme == SVARA_PH_PLOSIVE_B)     { return "b"; }
    if (phoneme == SVARA_PH_PLOSIVE_T)     { return "t̪"; }
    if (phoneme == SVARA_PH_PLOSIVE_D)     { return "d̪"; }
    if (phoneme == SVARA_PH_PLOSIVE_K)     { return "k"; }
    if (phoneme == SVARA_PH_PLOSIVE_G)     { return "ɡ"; }
    # Fricatives
    if (phoneme == SVARA_PH_FRIC_S)        { return "s"; }
    if (phoneme == SVARA_PH_FRIC_H)        { return "ɦ"; }
    if (phoneme == SVARA_PH_FRIC_F)        { return "f"; }
    if (phoneme == SVARA_PH_FRIC_SH)       { return "ɕ"; }
    # Nasals
    if (phoneme == SVARA_PH_NASAL_M)       { return "m"; }
    if (phoneme == SVARA_PH_NASAL_N)       { return "n"; }
    if (phoneme == SVARA_PH_NASAL_NG)      { return "ŋ"; }
    # Approximants & lateral
    if (phoneme == SVARA_PH_APPROX_J)      { return "j"; }
    if (phoneme == SVARA_PH_LATERAL_L)     { return "l"; }
    if (phoneme == SVARA_PH_TAP_FLAP)      { return "r"; }
    if (phoneme == SVARA_PH_FRIC_V)        { return "ʋ"; }
    # Affricates
    if (phoneme == SVARA_PH_AFFR_CH)       { return "t͡ɕ"; }
    if (phoneme == SVARA_PH_AFFR_J)        { return "d͡ʑ"; }
    # Not mapped
    if (phoneme == SVARA_PH_SILENCE)       { return 0; }
    return 0;
}

# Arabic (was `arabic_phoneme_to_ipa`).
#must_use
fn shabda_arabic_phoneme_to_ipa(phoneme): cstring {
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "a"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "i"; }
    if (phoneme == SVARA_PH_VOWEL_CUP_V)   { return "u"; }
    if (phoneme == SVARA_PH_PLOSIVE_B)     { return "b"; }
    if (phoneme == SVARA_PH_PLOSIVE_T)     { return "t"; }
    if (phoneme == SVARA_PH_PLOSIVE_D)     { return "d"; }
    if (phoneme == SVARA_PH_PLOSIVE_K)     { return "k"; }
    if (phoneme == SVARA_PH_PLOSIVE_G)     { return "ɣ"; }
    if (phoneme == SVARA_PH_FRIC_F)        { return "f"; }
    if (phoneme == SVARA_PH_FRIC_TH)       { return "θ"; }
    if (phoneme == SVARA_PH_FRIC_DH)       { return "ð"; }
    if (phoneme == SVARA_PH_FRIC_S)        { return "s"; }
    if (phoneme == SVARA_PH_FRIC_Z)        { return "z"; }
    if (phoneme == SVARA_PH_FRIC_SH)       { return "ʃ"; }
    if (phoneme == SVARA_PH_FRIC_H)        { return "h"; }
    if (phoneme == SVARA_PH_NASAL_M)       { return "m"; }
    if (phoneme == SVARA_PH_NASAL_N)       { return "n"; }
    if (phoneme == SVARA_PH_LATERAL_L)     { return "l"; }
    if (phoneme == SVARA_PH_TAP_FLAP)      { return "r"; }
    if (phoneme == SVARA_PH_APPROX_W)      { return "w"; }
    if (phoneme == SVARA_PH_APPROX_J)      { return "j"; }
    if (phoneme == SVARA_PH_AFFR_J)        { return "d͡ʒ"; }
    if (phoneme == SVARA_PH_GLOTTAL_STOP)  { return "ʔ"; }
    if (phoneme == SVARA_PH_SILENCE)       { return 0; }
    return 0;
}

# Sanskrit (was `sanskrit_phoneme_to_ipa`). Overrides a handful of vowels, then
# DELEGATES every other phoneme to the Hindi table (Rust `other => hindi(...)`).
#must_use
fn shabda_sanskrit_phoneme_to_ipa(phoneme): cstring {
    # Sanskrit schwa is /ɐ/ not /ə/
    if (phoneme == SVARA_PH_VOWEL_SCHWA)   { return "ɐ"; }
    # Long vowels
    if (phoneme == SVARA_PH_VOWEL_OPEN_A)  { return "ɐː"; }
    if (phoneme == SVARA_PH_VOWEL_NEAR_I)  { return "i"; }
    if (phoneme == SVARA_PH_VOWEL_E)       { return "iː"; }
    if (phoneme == SVARA_PH_VOWEL_CUP_V)   { return "u"; }
    if (phoneme == SVARA_PH_VOWEL_U)       { return "uː"; }
    if (phoneme == SVARA_PH_VOWEL_OPEN_E)  { return "eː"; }
    if (phoneme == SVARA_PH_VOWEL_O)       { return "oː"; }
    # Consonants — same as Hindi
    return shabda_hindi_phoneme_to_ipa(phoneme);
}

# Dispatch a phoneme to the language's IPA table (was `phoneme_to_ipa_for`).
# #[non_exhaustive] Language -> if-chain + mandatory fallback (Rust exhaustive
# match; fall back to English).
#must_use
fn shabda_phoneme_to_ipa_for(phoneme, language): cstring {
    if (language == SHABDA_LANG_ENGLISH)  { return shabda_phoneme_to_ipa(phoneme); }
    if (language == SHABDA_LANG_SPANISH)  { return shabda_spanish_phoneme_to_ipa(phoneme); }
    if (language == SHABDA_LANG_GERMAN)   { return shabda_german_phoneme_to_ipa(phoneme); }
    if (language == SHABDA_LANG_HINDI)    { return shabda_hindi_phoneme_to_ipa(phoneme); }
    if (language == SHABDA_LANG_ARABIC)   { return shabda_arabic_phoneme_to_ipa(phoneme); }
    if (language == SHABDA_LANG_SANSKRIT) { return shabda_sanskrit_phoneme_to_ipa(phoneme); }
    return shabda_phoneme_to_ipa(phoneme);
}

# ================================================================
# VARNA_INVENTORY_GAPS — phonemes that are valid English sounds but not yet in  #skip-lint
# varna 1.0's inventory; skipped during validation to avoid false positives.
# Built as a fresh vec of ordinals (order matches the Rust const array).
# ================================================================
#must_use
fn shabda_varna_inventory_gaps(): i64 {
    var v = vec_new();
    vec_push(v, SVARA_PH_DIPH_AI);    # PRICE: aɪ
    vec_push(v, SVARA_PH_DIPH_AU);    # MOUTH: aʊ
    vec_push(v, SVARA_PH_DIPH_OI);    # CHOICE: ɔɪ
    vec_push(v, SVARA_PH_VOWEL_BIRD); # NURSE: ɜː
    return v;
}

# ================================================================
# Inventory + phonotactics dispatch (varna handles).
# ================================================================

# varna PhonemeInventory for a language (was `inventory_for`). #[non_exhaustive]
# Language -> if-chain + fallback to English.
#must_use
fn shabda_inventory_for(language): i64 {
    if (language == SHABDA_LANG_ENGLISH)  { return phoneme_english(); }
    if (language == SHABDA_LANG_SPANISH)  { return phoneme_spanish(); }
    if (language == SHABDA_LANG_GERMAN)   { return phoneme_german(); }
    if (language == SHABDA_LANG_HINDI)    { return phoneme_hindi(); }
    if (language == SHABDA_LANG_ARABIC)   { return phoneme_classical_arabic(); }
    if (language == SHABDA_LANG_SANSKRIT) { return phoneme_sanskrit(); }
    return phoneme_english();
}

# varna Phonotactics for a language (was `phonotactics_for`). Rust returns
# Option: Some(english_phonotactics()) for English, None for every other
# language. Sentinel: English -> handle, else 0 (== None).
#must_use
fn shabda_phonotactics_for(language): i64 {
    if (language == SHABDA_LANG_ENGLISH) { return phonotactics_english(); }
    return 0;
}

# ================================================================
# Validation.
# ================================================================

# True (1) if a phoneme counts as a "vowel" for the phonotactics consonant-run
# reset: Vowel or Diphthong class, OR the Silence phoneme (Rust
# `matches!(ph.class(), Vowel | Diphthong) || ph == Silence`).
fn _shabda_validate_is_vowel(ph): i64 {
    var c = svara_phoneme_class(ph);
    if (c == SVARA_CLASS_VOWEL) { return 1; }
    if (c == SVARA_CLASS_DIPHTHONG) { return 1; }
    if (ph == SVARA_PH_SILENCE) { return 1; }
    return 0;
}

# Validate a phoneme sequence (vec of ordinals) against phonotactic constraints
# (was `validate_phonotactics`). Returns a vec of report Strings (cstr). Empty
# vec means no violations. No constraints for the language -> empty vec.
#
# The consonant run is a vec of IPA cstrs; on a vowel boundary a run longer than
# max_onset is a violation; a trailing run longer than max_coda is a violation.
# Report text mirrors Rust's alloc::format! output exactly (join is empty-sep
# concat of the collected IPA cstrs).
#must_use
fn shabda_validate_phonotactics(phonemes, language): i64 {
    var violations = vec_new();
    var constraints = shabda_phonotactics_for(language);
    if (constraints == 0) { return violations; }   # no constraints available

    var max_onset = phonotactics_max_onset(constraints);
    var max_coda = phonotactics_max_coda(constraints);

    # Walk phonemes, tracking a run of consonant IPA cstrs.
    var consonant_run = vec_new();
    var n = vec_len(phonemes);
    var i = 0;
    while (i < n) {
        var ph = vec_get(phonemes, i);
        # Rust: `if let Some(ipa) = phoneme_to_ipa(ph)` — English table, always.
        var ipa = shabda_phoneme_to_ipa(ph);
        if (ipa != 0) {
            if (_shabda_validate_is_vowel(ph) == 1) {
                if (vec_len(consonant_run) > max_onset) {
                    var joined = _shabda_validate_join(consonant_run);
                    vec_push(violations, _shabda_validate_onset_msg(joined));
                }
                consonant_run = vec_new();   # Rust `consonant_run.clear()`
            } else {
                vec_push(consonant_run, ipa);
            }
        }
        i = i + 1;
    }

    # Final consonant run vs max coda.
    if (vec_len(consonant_run) > max_coda) {
        var joined2 = _shabda_validate_join(consonant_run);
        vec_push(violations, _shabda_validate_coda_msg(joined2));
    }

    return violations;
}

# Join a vec of IPA cstrs with the empty separator (Rust `run.join("")`).
# Returns a fresh NUL-terminated cstr.
fn _shabda_validate_join(run): cstring {
    var sb = str_builder_new();
    var n = vec_len(run);
    var i = 0;
    while (i < n) {
        str_builder_add_cstr(sb, vec_get(run, i));
        i = i + 1;
    }
    return str_cstr(str_builder_build(sb));
}

# "consonant cluster too long for onset: {joined}" (Rust format!).
fn _shabda_validate_onset_msg(joined): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "consonant cluster too long for onset: ");
    str_builder_add_cstr(sb, joined);
    return str_cstr(str_builder_build(sb));
}

# "consonant cluster too long for coda: {joined}" (Rust format!).
fn _shabda_validate_coda_msg(joined): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "consonant cluster too long for coda: ");
    str_builder_add_cstr(sb, joined);
    return str_cstr(str_builder_build(sb));
}

# Validate that every phoneme in the vec exists in the given inventory, using
# language-aware IPA mapping (was `validate_phonemes_for`). Returns a vec of IPA
# cstrs NOT in the inventory. Empty vec == all valid. A phoneme with no IPA
# (sentinel 0) is skipped (Rust `if let Some(ipa) = ... && !inventory.has(ipa)`).
#must_use
fn shabda_validate_phonemes_for(phonemes, inventory, language): i64 {
    var invalid = vec_new();
    var n = vec_len(phonemes);
    var i = 0;
    while (i < n) {
        var ph = vec_get(phonemes, i);
        var ipa = shabda_phoneme_to_ipa_for(ph, language);
        if (ipa != 0) {
            if (phoneme_has(inventory, ipa) == 0) {
                vec_push(invalid, ipa);
            }
        }
        i = i + 1;
    }
    return invalid;
}

# Validate phonemes against the English inventory (was `validate_phonemes`,
# backwards-compatible alias). Returns a vec of invalid IPA cstrs.
#must_use
fn shabda_validate_phonemes(phonemes, inventory): i64 {
    return shabda_validate_phonemes_for(phonemes, inventory, SHABDA_LANG_ENGLISH);
}

# --- engine.cyr ---

# engine.cyr — the G2P engine: ties normalization, dictionary, rules, and prosody
# together.
#
# Ports rust-old/src/engine.rs (751 LOC). Owns Language, TimingProfile,
# ConvertOptions, and G2PEngine, plus the conversion pipeline
# (convert / convert_with / convert_ssml / convert_streaming / speak / speak_with)
# and the varna-gated helpers (detect_language, phoneme_inventory) which are
# ALWAYS compiled here (the Rust #[cfg(feature="varna")] gate is dropped).
#
# DEP POSITION: needs the vendored dep chain (svara for PhonemeEvent/sequence/
# voice, shabdakosh for the dictionary, varna for script detection + inventories)
# plus every earlier shabda module (error, normalize, syllable, heteronym, ssml,
# rules, prosody, validate). The entry file (tests/engine.tcyr / src/main.cyr)
# orders the includes; modules never include each other.
#
# ---------------------------------------------------------------- byte layouts
# ShabdaTimingProfile (24 bytes): three f64-bit scale factors, at the
#   SHABDA_TIMING_VOWEL/CONSONANT/PAUSE offsets (0/8/16) that prosody's
#   shabda_apply_timing reads directly via load64. Rust's TimingProfile.
#     [0]  vowel_scale     (f64 bits)
#     [8]  consonant_scale (f64 bits)
#     [16] pause_scale     (f64 bits)
#
# ShabdaConvertOptions (32 bytes): Rust's ConvertOptions.
#     [0]  emphasis            (i64 bool: 1 = on)
#     [8]  has_rate            (i64 bool: Option<f32> tag; 1 = Some)
#     [16] rate_wpm            (f64 bits; valid only when has_rate == 1)
#     [24] timing              (ShabdaTimingProfile* or 0 == None)
#
# ShabdaG2PEngine (16 bytes): Rust's G2PEngine.
#     [0]  language            (SHABDA_LANG_* tag)
#     [8]  dictionary          (shabdakosh dict handle)
#
# PhonemeEvent is svara's immutable-by-handle triple (phoneme, duration-f64,
# stress); build via svara_phoneme_event_new. Rust's `event.stress = ...` in-place
# mutation (Reduced emphasis) is re-expressed by rebuilding the event.
#
# CONVENTION (fallible fns): convert / convert_with / convert_ssml / speak /
# speak_with RETURN a packed shabda error (0 == ok, tested via shabda_is_err) and
# WRITE their result vec (events / samples) to an out-param pointer. This is the
# idiomatic Cyrius fallible shape (a vec handle is a non-zero heap pointer and can
# NOT be told apart from a packed error by shabda_is_err, so the payload rides an
# out-param instead). convert_streaming has no result vec — it returns the packed
# error directly (0 == ok). The empty-input path returns shabda_err_invalid_input()
# and leaves the out-param untouched.
#
# NAMING: every top-level symbol is `shabda_`/`SHABDA_`-prefixed (flat link
# namespace; coexists with shbdk_ / svara_ / varna / sakshi). Private helpers are
# `_shabda_engine_*`.

# ================================================================
# Silence durations (Rust f32 literals promoted to f64 bits). Match engine.rs.
# ================================================================
# 0.15 — comma phrase pause
var SHABDA_ENGINE_COMMA_DUR = 0x3FC3_3333_3333_3333;
# 0.30 — period phrase pause
var SHABDA_ENGINE_PERIOD_DUR = 0x3FD3_3333_3333_3333;
# 0.04 — inter-word silence
var SHABDA_ENGINE_WORD_DUR = 0x3FA4_7AE1_47AE_147B;

# ConvertOptions block offsets.
var SHABDA_OPT_EMPHASIS = 0;
var SHABDA_OPT_HAS_RATE = 8;
var SHABDA_OPT_RATE_WPM = 16;
var SHABDA_OPT_TIMING   = 24;
var SHABDA_OPT_SIZE     = 32;

# G2PEngine block offsets.
var SHABDA_ENGINE_LANG = 0;
var SHABDA_ENGINE_DICT = 8;
var SHABDA_ENGINE_SIZE = 16;

# ================================================================
# TimingProfile — three f64-bit scales at SHABDA_TIMING_* offsets. (Rust
# TimingProfile::new / Default.)
# ================================================================
#must_use
fn shabda_timing_new(vowel_scale, consonant_scale, pause_scale): i64 {
    var p = alloc(SHABDA_TIMING_SIZE);
    store64(p + SHABDA_TIMING_VOWEL, vowel_scale);
    store64(p + SHABDA_TIMING_CONSONANT, consonant_scale);
    store64(p + SHABDA_TIMING_PAUSE, pause_scale);
    return p;
}

# Default: 1.0 / 1.0 / 1.0.
#must_use
fn shabda_timing_default(): i64 {
    return shabda_timing_new(f64_from(1), f64_from(1), f64_from(1));
}

#must_use
fn shabda_timing_vowel_scale(p): i64 { return load64(p + SHABDA_TIMING_VOWEL); }

#must_use
fn shabda_timing_consonant_scale(p): i64 { return load64(p + SHABDA_TIMING_CONSONANT); }

#must_use
fn shabda_timing_pause_scale(p): i64 { return load64(p + SHABDA_TIMING_PAUSE); }

# ================================================================
# ConvertOptions — builders mutate in place and return self (chainable), mirroring
# the Rust `with_*(mut self) -> Self`.
# ================================================================
#must_use
fn shabda_convert_options_new(): i64 {
    var o = alloc(SHABDA_OPT_SIZE);
    store64(o + SHABDA_OPT_EMPHASIS, 0);
    store64(o + SHABDA_OPT_HAS_RATE, 0);
    store64(o + SHABDA_OPT_RATE_WPM, f64_from(0));
    store64(o + SHABDA_OPT_TIMING, 0);
    return o;
}

#must_use
fn shabda_convert_options_default(): i64 {
    return shabda_convert_options_new();
}

#must_use
fn shabda_convert_options_with_emphasis(o, emphasis): i64 {
    store64(o + SHABDA_OPT_EMPHASIS, emphasis);
    return o;
}

# wpm is an f64 bit pattern (Rust took f32; promoted).
#must_use
fn shabda_convert_options_with_speaking_rate(o, wpm): i64 {
    store64(o + SHABDA_OPT_HAS_RATE, 1);
    store64(o + SHABDA_OPT_RATE_WPM, wpm);
    return o;
}

#must_use
fn shabda_convert_options_with_timing(o, timing): i64 {
    store64(o + SHABDA_OPT_TIMING, timing);
    return o;
}

#must_use
fn shabda_convert_options_emphasis(o): i64 { return load64(o + SHABDA_OPT_EMPHASIS); }

#must_use
fn shabda_convert_options_has_rate(o): i64 { return load64(o + SHABDA_OPT_HAS_RATE); }

#must_use
fn shabda_convert_options_rate_wpm(o): i64 { return load64(o + SHABDA_OPT_RATE_WPM); }

#must_use
fn shabda_convert_options_timing(o): i64 { return load64(o + SHABDA_OPT_TIMING); }

# ================================================================
# Language serde/name (Rust derives Serialize/Deserialize + Debug). Provide the
# string<->tag map + fallback; a roundtrip test pins it.
# ================================================================
#must_use
fn shabda_language_to_str(lang): cstring {
    if (lang == SHABDA_LANG_ENGLISH)  { return "English"; }
    if (lang == SHABDA_LANG_SPANISH)  { return "Spanish"; }
    if (lang == SHABDA_LANG_GERMAN)   { return "German"; }
    if (lang == SHABDA_LANG_HINDI)    { return "Hindi"; }
    if (lang == SHABDA_LANG_ARABIC)   { return "Arabic"; }
    if (lang == SHABDA_LANG_SANSKRIT) { return "Sanskrit"; }
    return "English";                 # #[non_exhaustive] fallback
}

#must_use
fn shabda_language_from_str(s): i64 {
    if (streq(s, "English") == 1)  { return SHABDA_LANG_ENGLISH; }
    if (streq(s, "Spanish") == 1)  { return SHABDA_LANG_SPANISH; }
    if (streq(s, "German") == 1)   { return SHABDA_LANG_GERMAN; }
    if (streq(s, "Hindi") == 1)    { return SHABDA_LANG_HINDI; }
    if (streq(s, "Arabic") == 1)   { return SHABDA_LANG_ARABIC; }
    if (streq(s, "Sanskrit") == 1) { return SHABDA_LANG_SANSKRIT; }
    return SHABDA_LANG_ENGLISH;       # unknown -> English fallback
}

# ================================================================
# detect_language(text) -> Language tag or -1 (Rust Option::None). Always
# compiled. Count codepoints in each known script via varna script_by_code; only
# ("Latn", English) is wired (Rust leaves the rest as future). Return the language
# with the most matching codepoints, or -1.
# ================================================================
#must_use
fn shabda_detect_language(text): i64 {
    # trim empty -> None
    var n = strlen(text);
    var s = 0;
    var e = n;
    while (s < e && _shabda_engine_is_ws(load8(text + s)) == 1) { s = s + 1; }
    while (e > s && _shabda_engine_is_ws(load8(text + e - 1)) == 1) { e = e - 1; }
    if (e <= s) { return (0 - 1); }

    # Only ("Latn", English) is wired.
    var best_lang = (0 - 1);
    var best_count = 0;
    var script = script_by_code("Latn");
    if (script != 0) {
        var count = _shabda_engine_count_script_cps(text, script);
        if (count > 0) {
            best_lang = SHABDA_LANG_ENGLISH;
            best_count = count;
        }
    }
    return best_lang;
}

# ASCII whitespace (Rust str::trim on the inputs this crate sees).
fn _shabda_engine_is_ws(c): i64 {
    if (c == 32) { return 1; }
    if (c == 9)  { return 1; }
    if (c == 10) { return 1; }
    if (c == 13) { return 1; }
    if (c == 12) { return 1; }
    if (c == 11) { return 1; }
    return 0;
}

# Count codepoints in `text` that belong to `script` (via script_contains_codepoint).
fn _shabda_engine_count_script_cps(text, script): i64 {
    var count = 0;
    var p = text;
    var cpo = alloc(8);
    var adv = _shabda_utf8_next(p, cpo);
    while (adv > 0) {
        if (script_contains_codepoint(script, load64(cpo)) == 1) { count = count + 1; }
        p = p + adv;
        adv = _shabda_utf8_next(p, cpo);
    }
    return count;
}

# ================================================================
# G2PEngine.
# ================================================================
# Rust: English -> PronunciationDict::english(); every other language ->
# PronunciationDict::new() (EMPTY — NOT a language-specific dict).
#must_use
fn shabda_g2p_new(language): i64 {
    var e = alloc(SHABDA_ENGINE_SIZE);
    store64(e + SHABDA_ENGINE_LANG, language);
    var dict = shbdk_dict_new();
    if (language == SHABDA_LANG_ENGLISH) {
        dict = shbdk_dict_english();
    }
    store64(e + SHABDA_ENGINE_DICT, dict);
    return e;
}

#must_use
fn shabda_g2p_language(e): i64 { return load64(e + SHABDA_ENGINE_LANG); }

#must_use
fn shabda_g2p_dictionary(e): i64 { return load64(e + SHABDA_ENGINE_DICT); }

# Rust dictionary_mut() — returns the same handle; mutation is via shbdk_dict_*.
fn shabda_g2p_dictionary_mut(e): i64 { return load64(e + SHABDA_ENGINE_DICT); }

# phoneme_inventory(e) -> varna inventory for the active language. Always compiled.
#must_use
fn shabda_g2p_phoneme_inventory(e): i64 {
    return shabda_inventory_for(load64(e + SHABDA_ENGINE_LANG));
}

# ================================================================
# <lang>_rules dispatch on the language tag. (Rust match self.language.)
# ================================================================
#must_use
fn _shabda_engine_rules(language, word): i64 {
    if (language == SHABDA_LANG_ENGLISH)  { return shabda_english_rules(word); }
    if (language == SHABDA_LANG_SPANISH)  { return shabda_spanish_rules(word); }
    if (language == SHABDA_LANG_GERMAN)   { return shabda_german_rules(word); }
    if (language == SHABDA_LANG_HINDI)    { return shabda_hindi_rules(word); }
    if (language == SHABDA_LANG_ARABIC)   { return shabda_arabic_rules(word); }
    if (language == SHABDA_LANG_SANSKRIT) { return shabda_sanskrit_rules(word); }
    return shabda_english_rules(word);    # #[non_exhaustive] fallback
}

# ================================================================
# split a normalized cstring on whitespace -> vec of cstr words. The normalized
# text uses single-space separation plus the ,pause/.pause/<emph></emph> marker
# tokens; this collapses runs and drops empties (Rust str::split_whitespace).
# ================================================================
#must_use
fn _shabda_engine_split_ws(text): i64 {
    var words = vec_new();
    var n = strlen(text);
    var i = 0;
    var start = 0;
    var inword = 0;
    while (i < n) {
        var c = load8(text + i);
        if (_shabda_engine_is_ws(c) == 1) {
            if (inword == 1) {
                var len = i - start;
                var buf = alloc(len + 1);
                memcpy(buf, text + start, len);
                store8(buf + len, 0);
                vec_push(words, buf);
                inword = 0;
            }
        } else {
            if (inword == 0) { start = i; inword = 1; }
        }
        i = i + 1;
    }
    if (inword == 1) {
        var len2 = n - start;
        var buf2 = alloc(len2 + 1);
        memcpy(buf2, text + start, len2);
        store8(buf2 + len2, 0);
        vec_push(words, buf2);
    }
    return words;
}

# Make a Silence PhonemeEvent of the given f64-bit duration (Unstressed).
#must_use
fn _shabda_engine_silence(duration): i64 {
    return svara_phoneme_event_new(SVARA_PH_SILENCE, duration, SVARA_STRESS_UNSTRESSED);
}

# 1 if `word` is any of the 4 marker tokens (comma/period pause, emph start/end).
fn _shabda_engine_is_marker(word): i64 {
    if (streq(word, SHABDA_COMMA_PAUSE) == 1) { return 1; }
    if (streq(word, SHABDA_PERIOD_PAUSE) == 1) { return 1; }
    if (streq(word, SHABDA_EMPHASIS_START) == 1) { return 1; }
    if (streq(word, SHABDA_EMPHASIS_END) == 1) { return 1; }
    return 0;
}

# Collect up to 3 preceding non-marker words (indices i-1,i-2,i-3 downward),
# nearest first (Rust words[..i].iter().rev().filter(non-marker).take(3)).
#must_use
fn _shabda_engine_preceding(words, i): i64 {
    var preceding = vec_new();
    var j = i - 1;
    while (j >= 0) {
        if (vec_len(preceding) >= 3) { return preceding; }
        var w = vec_get(words, j);
        if (_shabda_engine_is_marker(w) == 0) {
            vec_push(preceding, w);
        }
        j = j - 1;
    }
    return preceding;
}

# Copy a vec of i64 (phoneme ordinals) into a fresh owned vec (Rust .to_vec()).
#must_use
fn _shabda_engine_copy_vec(v): i64 {
    var out = vec_new();
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        vec_push(out, vec_get(v, i));
        i = i + 1;
    }
    return out;
}

# ================================================================
# LOOKUP (the exact fallback order from engine.rs convert_with).
# Returns a phonemes vec (owned).
# ================================================================
#must_use
fn _shabda_engine_lookup(e, word, preceding): i64 {
    var language = load64(e + SHABDA_ENGINE_LANG);
    var dict = load64(e + SHABDA_ENGINE_DICT);

    var rule = shabda_heteronym_lookup(word);
    if (rule != 0) {
        var prons = shbdk_dict_lookup_all(dict, word);
        if (prons != 0) {
            return _shabda_engine_copy_vec(shabda_select_phonemes(rule, preceding, prons));
        }
        var entry = shbdk_dict_lookup(dict, word);
        if (entry != 0) {
            return _shabda_engine_copy_vec(entry);
        }
        return _shabda_engine_rules(language, word);
    }

    var dhit = shbdk_dict_lookup(dict, word);
    if (dhit != 0) {
        return _shabda_engine_copy_vec(dhit);
    }

    if (shabda_is_foreign_word(word) == 1) {
        var stripped = shabda_strip_diacritics(word);
        var shit = shbdk_dict_lookup(dict, stripped);
        if (shit != 0) {
            return _shabda_engine_copy_vec(shit);
        }
        return _shabda_engine_rules(language, stripped);
    }

    return _shabda_engine_rules(language, word);
}

# ================================================================
# convert(e, text, out_events) -> packed err (0 ok); writes events vec to
# *out_events. Delegates to convert_with with default options.
# ================================================================
#must_use
fn shabda_convert(e, text, out_events): i64 {
    return shabda_convert_with(e, text, shabda_convert_options_default(), out_events);
}

# ================================================================
# convert_with(e, text, options, out_events) -> packed err (0 ok); on ok writes
# the events vec to *out_events. THE PIPELINE — replicates engine.rs convert_with.
# ================================================================
#must_use
fn shabda_convert_with(e, text, options, out_events): i64 {
    # 1. empty text -> InvalidInput error.
    var tn = strlen(text);
    var ts = 0;
    var te = tn;
    while (ts < te && _shabda_engine_is_ws(load8(text + ts)) == 1) { ts = ts + 1; }
    while (te > ts && _shabda_engine_is_ws(load8(text + te - 1)) == 1) { te = te - 1; }
    if (te <= ts) { return shabda_err_invalid_input(); }

    var language = load64(e + SHABDA_ENGINE_LANG);

    # 2. inventory (always compiled).
    var inv = shabda_inventory_for(language);

    # 3. intonation (computed; used by nothing downstream — parity with Rust).
    var intonation = shabda_detect_intonation(text);

    # 4. normalize (with or without emphasis).
    var normalized = 0;
    if (shabda_convert_options_emphasis(options) != 0) {
        normalized = shabda_normalize_with_emphasis(text);
    } else {
        normalized = shabda_normalize(text);
    }

    # 5. split on whitespace.
    var words = _shabda_engine_split_ws(normalized);
    var nwords = vec_len(words);

    # 6. events + emphasis state.
    var events = vec_new();
    var emphasis_active = 0;

    # 7. per-word loop.
    var i = 0;
    while (i < nwords) {
        var word = vec_get(words, i);

        # a/b. emphasis markers.
        if (streq(word, SHABDA_EMPHASIS_START) == 1) {
            emphasis_active = 1;
            i = i + 1;
            continue;
        }
        if (streq(word, SHABDA_EMPHASIS_END) == 1) {
            emphasis_active = 0;
            i = i + 1;
            continue;
        }
        # c/d. phrase-boundary markers.
        if (streq(word, SHABDA_COMMA_PAUSE) == 1) {
            vec_push(events, _shabda_engine_silence(SHABDA_ENGINE_COMMA_DUR));
            i = i + 1;
            continue;
        }
        if (streq(word, SHABDA_PERIOD_PAUSE) == 1) {
            vec_push(events, _shabda_engine_silence(SHABDA_ENGINE_PERIOD_DUR));
            i = i + 1;
            continue;
        }

        # e. preceding context.
        var preceding = _shabda_engine_preceding(words, i);

        # f. LOOKUP (dict-first, rule fallback).
        var phonemes = _shabda_engine_lookup(e, word, preceding);

        # g. debug validation — always compiled, results DISCARDED, never abort.
        var _invalid = shabda_validate_phonemes_for(phonemes, inv, language);
        var _violations = shabda_validate_phonotactics(phonemes, language);

        # h. skip empties.
        if (vec_len(phonemes) == 0) {
            i = i + 1;
            continue;
        }

        # i/j/k. syllabify + assign stress.
        var is_content = shabda_is_content_word(word);
        var syllables = shabda_syllabify(phonemes);
        var word_events = 0;
        if (vec_len(syllables) == 0) {
            word_events = shabda_assign_stress(phonemes, is_content);
        } else {
            word_events = shabda_assign_stress_syllabic(syllables, is_content);
        }

        # l. emphasis if active.
        if (emphasis_active == 1) {
            shabda_apply_emphasis(word_events);
        }

        # m. append word events.
        var wn = vec_len(word_events);
        var wi = 0;
        while (wi < wn) {
            vec_push(events, vec_get(word_events, wi));
            wi = wi + 1;
        }

        # n. inter-word silence (not after last word).
        if (i < nwords - 1) {
            vec_push(events, _shabda_engine_silence(SHABDA_ENGINE_WORD_DUR));
        }

        i = i + 1;
    }

    # 8. rate scaling.
    if (shabda_convert_options_has_rate(options) == 1) {
        shabda_apply_rate(events, shabda_convert_options_rate_wpm(options));
    }
    # 9. timing profile.
    var timing = shabda_convert_options_timing(options);
    if (timing != 0) {
        shabda_apply_timing(events, timing);
    }

    # 10. ok — write out the events vec.
    store64(out_events, events);
    return 0;
}

# ================================================================
# speak(e, text, voice, sr, out_samples) -> packed err (0 ok); writes samples.
# ================================================================
#must_use
fn shabda_speak(e, text, voice, sample_rate, out_samples): i64 {
    return shabda_speak_with(e, text, voice, sample_rate, shabda_convert_options_default(), out_samples);
}

# speak_with: convert, push each event to a sequence, render to samples. Render
# error -> shabda_err_rule_error() (Rust maps the svara error into RuleError).
# Writes the samples vec to *out_samples on ok.
#must_use
fn shabda_speak_with(e, text, voice, sample_rate, options, out_samples): i64 {
    var evslot = alloc(8);
    var cerr = shabda_convert_with(e, text, options, evslot);
    if (shabda_is_err(cerr) == 1) { return cerr; }
    var events = load64(evslot);

    var seq = svara_sequence_new();
    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        svara_sequence_push(seq, vec_get(events, i));
        i = i + 1;
    }

    var samples = svara_sequence_render(seq, voice, sample_rate);
    if (svara_is_err(samples) == 1) { return shabda_err_rule_error(); }
    store64(out_samples, samples);
    return 0;
}

# ================================================================
# convert_ssml(e, ssml, out_events) -> packed err (0 ok); writes events on ok.
# ================================================================
#must_use
fn shabda_convert_ssml(e, ssml, out_events): i64 {
    # trim empty -> InvalidInput.
    var n = strlen(ssml);
    var s = 0;
    var en = n;
    while (s < en && _shabda_engine_is_ws(load8(ssml + s)) == 1) { s = s + 1; }
    while (en > s && _shabda_engine_is_ws(load8(ssml + en - 1)) == 1) { en = en - 1; }
    if (en <= s) { return shabda_err_invalid_input(); }

    var nodes = shabda_ssml_parse(ssml);
    if (nodes == 0) { return shabda_err_invalid_input(); }   # Rust parse Err

    var events = vec_new();
    var rc = _shabda_engine_render_ssml_nodes(e, nodes, shabda_convert_options_default(), events);
    if (shabda_is_err(rc) == 1) { return rc; }
    store64(out_events, events);
    return 0;
}

# ================================================================
# render_ssml_nodes (recursive). Appends into `events`. Returns 0 on ok, or a
# packed error propagated from a convert_with call (Rust `?`).
# ================================================================
#must_use
fn _shabda_engine_render_ssml_nodes(e, nodes, base_options, events): i64 {
    var n = vec_len(nodes);
    var i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);
        var tag = shabda_ssml_node_tag(node);

        if (tag == SHABDA_SSML_TEXT) {
            var text_str = shabda_ssml_node_text(node);
            var text = str_cstr(text_str);
            # non-empty (trimmed) text only.
            var tn = strlen(text);
            var ts = 0;
            var te = tn;
            while (ts < te && _shabda_engine_is_ws(load8(text + ts)) == 1) { ts = ts + 1; }
            while (te > ts && _shabda_engine_is_ws(load8(text + te - 1)) == 1) { te = te - 1; }
            if (te > ts) {
                var teslot = alloc(8);
                var terr = shabda_convert_with(e, text, base_options, teslot);
                if (shabda_is_err(terr) == 1) { return terr; }
                var text_events = load64(teslot);
                var ten = vec_len(text_events);
                var ti = 0;
                while (ti < ten) {
                    vec_push(events, vec_get(text_events, ti));
                    ti = ti + 1;
                }
            }
        } elif (tag == SHABDA_SSML_BREAK) {
            # duration_ms / 1000.0 seconds.
            var duration_ms = shabda_ssml_node_duration(node);
            var duration_secs = f64_div(f64_from(duration_ms), f64_from(1000));
            vec_push(events, _shabda_engine_silence(duration_secs));
        } elif (tag == SHABDA_SSML_EMPHASIS) {
            # base + emphasis=1; recurse; then boost per level.
            var eopts = _shabda_engine_opts_with_emphasis(base_options);
            var start = vec_len(events);
            var erc = _shabda_engine_render_ssml_nodes(e, shabda_ssml_node_children(node), eopts, events);
            if (shabda_is_err(erc) == 1) { return erc; }
            var level = shabda_ssml_node_level(node);
            if (level == SHABDA_EMPH_STRONG) {
                _shabda_engine_apply_emphasis_range(events, start);
            } elif (level == SHABDA_EMPH_REDUCED) {
                _shabda_engine_destress_range(events, start);
            }
            # Moderate: nothing (emphasis=true already handled it).
        } elif (tag == SHABDA_SSML_PROSODY) {
            # rate? base+speaking_rate : base.
            var popts = base_options;
            var rate = shabda_ssml_node_rate(node);
            if (rate != SHABDA_RATE_NONE) {
                popts = _shabda_engine_opts_with_rate(base_options, shabda_speaking_rate_wpm(rate));
            }
            var prc = _shabda_engine_render_ssml_nodes(e, shabda_ssml_node_children(node), popts, events);
            if (shabda_is_err(prc) == 1) { return prc; }
        }
        i = i + 1;
    }
    return 0;
}

# Clone `base` options, set emphasis=1 (Rust ConvertOptions{ emphasis:true, ..base }).
#must_use
fn _shabda_engine_opts_with_emphasis(base): i64 {
    var o = alloc(SHABDA_OPT_SIZE);
    store64(o + SHABDA_OPT_EMPHASIS, 1);
    store64(o + SHABDA_OPT_HAS_RATE, load64(base + SHABDA_OPT_HAS_RATE));
    store64(o + SHABDA_OPT_RATE_WPM, load64(base + SHABDA_OPT_RATE_WPM));
    store64(o + SHABDA_OPT_TIMING, load64(base + SHABDA_OPT_TIMING));
    return o;
}

# Clone `base` options, set speaking_rate=wpm (Rust ConvertOptions{ speaking_rate_wpm:Some(r), ..base }).
#must_use
fn _shabda_engine_opts_with_rate(base, wpm): i64 {
    var o = alloc(SHABDA_OPT_SIZE);
    store64(o + SHABDA_OPT_EMPHASIS, load64(base + SHABDA_OPT_EMPHASIS));
    store64(o + SHABDA_OPT_HAS_RATE, 1);
    store64(o + SHABDA_OPT_RATE_WPM, wpm);
    store64(o + SHABDA_OPT_TIMING, load64(base + SHABDA_OPT_TIMING));
    return o;
}

# apply_emphasis over events[start..] (Rust prosody::apply_emphasis on the tail).
fn _shabda_engine_apply_emphasis_range(events, start): i64 {
    var n = vec_len(events);
    var i = start;
    while (i < n) {
        var ev = vec_get(events, i);
        var ph = SvPhonemeEvent_phoneme(ev);
        var c = svara_phoneme_class(ph);
        if (c == SVARA_CLASS_VOWEL || c == SVARA_CLASS_DIPHTHONG) {
            var dur = f64_mul(SvPhonemeEvent_duration(ev), SHABDA_PROSODY_EMPHASIS_DURATION_SCALE);
            vec_set(events, i, svara_phoneme_event_new(ph, dur, SVARA_STRESS_PRIMARY));
        }
        i = i + 1;
    }
    return 0;
}

# De-stress events[start..] to Unstressed (Rust Reduced: event.stress = Unstressed).
fn _shabda_engine_destress_range(events, start): i64 {
    var n = vec_len(events);
    var i = start;
    while (i < n) {
        var ev = vec_get(events, i);
        var dph = SvPhonemeEvent_phoneme(ev);
        var ddur = SvPhonemeEvent_duration(ev);
        vec_set(events, i, svara_phoneme_event_new(dph, ddur, SVARA_STRESS_UNSTRESSED));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# convert_streaming(e, text, callback_fp) -> 0 (ok) | packed error.
# Simpler than convert_with (NO heteronym/foreign/emphasis) — matches engine.rs.
# callback_fp is a fn pointer called as callptr(fp, word, word_events).
# ================================================================
#must_use
fn shabda_convert_streaming(e, text, callback_fp): i64 {
    # trim empty -> InvalidInput.
    var n = strlen(text);
    var ts = 0;
    var te = n;
    while (ts < te && _shabda_engine_is_ws(load8(text + ts)) == 1) { ts = ts + 1; }
    while (te > ts && _shabda_engine_is_ws(load8(text + te - 1)) == 1) { te = te - 1; }
    if (te <= ts) { return shabda_err_invalid_input(); }

    var language = load64(e + SHABDA_ENGINE_LANG);
    var dict = load64(e + SHABDA_ENGINE_DICT);

    var normalized = shabda_normalize(text);
    var words = _shabda_engine_split_ws(normalized);
    var nwords = vec_len(words);

    var i = 0;
    while (i < nwords) {
        var word = vec_get(words, i);

        if (streq(word, SHABDA_COMMA_PAUSE) == 1) {
            var cev = vec_new();
            vec_push(cev, _shabda_engine_silence(SHABDA_ENGINE_COMMA_DUR));
            var cr = callptr(callback_fp, word, cev);
            i = i + 1;
            continue;
        }
        if (streq(word, SHABDA_PERIOD_PAUSE) == 1) {
            var pev = vec_new();
            vec_push(pev, _shabda_engine_silence(SHABDA_ENGINE_PERIOD_DUR));
            var pr = callptr(callback_fp, word, pev);
            i = i + 1;
            continue;
        }

        # dict.lookup | <lang>_rules (no heteronym/foreign/emphasis).
        var phonemes = shbdk_dict_lookup(dict, word);
        if (phonemes != 0) {
            phonemes = _shabda_engine_copy_vec(phonemes);
        } else {
            phonemes = _shabda_engine_rules(language, word);
        }

        if (vec_len(phonemes) == 0) {
            i = i + 1;
            continue;
        }

        var is_content = shabda_is_content_word(word);
        var syllables = shabda_syllabify(phonemes);
        var word_events = 0;
        if (vec_len(syllables) == 0) {
            word_events = shabda_assign_stress(phonemes, is_content);
        } else {
            word_events = shabda_assign_stress_syllabic(syllables, is_content);
        }

        var wr = callptr(callback_fp, word, word_events);
        i = i + 1;
    }

    return 0;
}
