# test_content_vs_function_word_stress — "the" first event unstressed
# ==============================================================================
test_group("content vs function stress");
var tc_ev = _conv(g_en, "the cat");
assert_eq(SvPhonemeEvent_stress(vec_get(tc_ev, 0)), SVARA_STRESS_UNSTRESSED, "the[0] unstressed");

# ==============================================================================
# test_serde_roundtrip_language (+ per-language variants)
# ==============================================================================
test_group("language roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_ENGLISH)), SHABDA_LANG_ENGLISH, "English roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_SPANISH)), SHABDA_LANG_SPANISH, "Spanish roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_GERMAN)), SHABDA_LANG_GERMAN, "German roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_HINDI)), SHABDA_LANG_HINDI, "Hindi roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_ARABIC)), SHABDA_LANG_ARABIC, "Arabic roundtrip");
assert_eq(shabda_language_from_str(shabda_language_to_str(SHABDA_LANG_SANSKRIT)), SHABDA_LANG_SANSKRIT, "Sanskrit roundtrip");
assert_streq(shabda_language_to_str(SHABDA_LANG_ENGLISH), "English", "English to_str");

