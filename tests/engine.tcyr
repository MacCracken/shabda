# ==============================================================================
# Hindi
# ==============================================================================
test_group("hindi");
var g_hi = shabda_g2p_new(SHABDA_LANG_HINDI);
# Parity with Rust test_hindi_namaste: native Devanagari convert yields events.
# normalize keeps char::is_alphabetic() code points (incl. Devanagari letters +
# matras) so the word survives to hindi_rules — see normalize.cyr _shabda_is_alpha.
var hi_deva_slot = alloc(8);
var hi_deva_err = shabda_convert(g_hi, "नमस्ते", hi_deva_slot);
assert_eq(shabda_is_err(hi_deva_err), 0, "hindi devanagari convert ok");
assert_neq(vec_len(load64(hi_deva_slot)), 0, "hindi devanagari non-empty events");
var hi_rom = _conv(g_hi, "namaste");
assert_neq(vec_len(hi_rom), 0, "hindi romanized non-empty");
var hi_samples = _speak(g_hi, "namaste", voice_m, f64_from(44100));
assert_neq(vec_len(hi_samples), 0, "hindi samples non-empty");

# ==============================================================================
# Arabic
# ==============================================================================
test_group("arabic");
var g_ar = shabda_g2p_new(SHABDA_LANG_ARABIC);
# Parity with Rust test_arabic_convert: native Arabic script yields events
# (normalize keeps Arabic letters + harakat via _shabda_is_alpha).
var ar_ev_slot = alloc(8);
var ar_ev_err = shabda_convert(g_ar, "كتاب", ar_ev_slot);
assert_eq(shabda_is_err(ar_ev_err), 0, "arabic convert ok");
assert_neq(vec_len(load64(ar_ev_slot)), 0, "arabic native non-empty events");
var ar_rom = _conv(g_ar, "salam");
assert_neq(vec_len(ar_rom), 0, "arabic romanized non-empty");

# ==============================================================================
# Sanskrit
# ==============================================================================
test_group("sanskrit");
var g_sa = shabda_g2p_new(SHABDA_LANG_SANSKRIT);
# Parity with Rust test_sanskrit_convert: native Devanagari yields events
# (Sanskrit rules preserve the inherent schwa; normalize keeps the codepoints).
var sa_ev_slot = alloc(8);
var sa_ev_err = shabda_convert(g_sa, "धर्म", sa_ev_slot);
assert_eq(shabda_is_err(sa_ev_err), 0, "sanskrit convert ok");
assert_neq(vec_len(load64(sa_ev_slot)), 0, "sanskrit native non-empty events");
var sa_rom = _conv(g_sa, "dharma");
assert_neq(vec_len(sa_rom), 0, "sanskrit romanized non-empty");

# ==============================================================================
# phoneme_inventory (varna, always compiled)
# ==============================================================================
test_group("phoneme inventory");
var inv_en = shabda_g2p_phoneme_inventory(g_en);
assert_eq(phoneme_has(inv_en, "p"), 1, "english inv has p");
assert_eq(phoneme_has(inv_en, "ʃ"), 1, "english inv has esh");
assert_eq(phoneme_has(inv_en, "ə"), 1, "english inv has schwa");
var inv_de = shabda_g2p_phoneme_inventory(g_de);
assert_eq(phoneme_has(inv_de, "p"), 1, "german inv has p");
assert_eq(phoneme_has(inv_de, "ʃ"), 1, "german inv has esh");
var inv_hi = shabda_g2p_phoneme_inventory(g_hi);
assert_eq(phoneme_has(inv_hi, "p"), 1, "hindi inv has p");
assert_eq(phoneme_has(inv_hi, "ə"), 1, "hindi inv has schwa");
var inv_ar = shabda_g2p_phoneme_inventory(g_ar);
assert_eq(phoneme_has(inv_ar, "b"), 1, "arabic inv has b");
assert_eq(phoneme_has(inv_ar, "ʔ"), 1, "arabic inv has glottal");
var inv_sa = shabda_g2p_phoneme_inventory(g_sa);
assert_eq(phoneme_has(inv_sa, "p"), 1, "sanskrit inv has p");
assert_eq(phoneme_has(inv_sa, "ɐ"), 1, "sanskrit inv has near-open");
var inv_sp = shabda_g2p_phoneme_inventory(g_sp);
assert_eq(phoneme_has(inv_sp, "p"), 1, "spanish inv has p");
assert_eq(phoneme_has(inv_sp, "θ"), 1, "spanish inv has theta");
assert_eq(phoneme_has(inv_sp, "a"), 1, "spanish inv has a");

# ==============================================================================
# detect_language — "hello world" -> English, "" -> None
# ==============================================================================
test_group("detect language");
assert_eq(shabda_detect_language("hello world"), SHABDA_LANG_ENGLISH, "latin -> english");
assert_eq(shabda_detect_language(""), (0 - 1), "empty -> none");

# is_content 'the' -> 0
test_group("is_content the");
assert_eq(shabda_is_content_word("the"), 0, "the is function word");

var rc = assert_summary();
syscall(60, rc);
