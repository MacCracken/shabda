# ==============================================================================
# TimingProfile accessors (serde-ish roundtrip)
# ==============================================================================
test_group("timing profile accessors");
var tp3 = shabda_timing_new(f64_from(3), f64_from(4), f64_from(5));
assert_eq(shabda_timing_vowel_scale(tp3), f64_from(3), "vowel 3");
assert_eq(shabda_timing_consonant_scale(tp3), f64_from(4), "consonant 4");
assert_eq(shabda_timing_pause_scale(tp3), f64_from(5), "pause 5");
var tpd = shabda_timing_default();
assert_eq(shabda_timing_vowel_scale(tpd), f64_from(1), "default vowel 1");

# ==============================================================================
# test_serde_roundtrip_convert_options — build ConvertOptions{emphasis:true,
# rate:Some(120)} and assert every field reads back (the port's serde analog: the
# field accessors are the wire surface, mirroring Rust's to_string/from_str
# equality on the same options).
# ==============================================================================
test_group("convert_options roundtrip");
var co_rt = shabda_convert_options_with_speaking_rate(
    shabda_convert_options_with_emphasis(shabda_convert_options_new(), 1), f64_from(120));
assert_eq(shabda_convert_options_emphasis(co_rt), 1, "co emphasis on");
assert_eq(shabda_convert_options_has_rate(co_rt), 1, "co has_rate on");
assert_eq(shabda_convert_options_rate_wpm(co_rt), f64_from(120), "co rate 120");
assert_eq(shabda_convert_options_timing(co_rt), 0, "co timing none");
# default options: all fields off/none (matches ConvertOptions::default()).
var co_def = shabda_convert_options_default();
assert_eq(shabda_convert_options_emphasis(co_def), 0, "co default emphasis off");
assert_eq(shabda_convert_options_has_rate(co_def), 0, "co default has_rate off");
assert_eq(shabda_convert_options_timing(co_def), 0, "co default timing none");

# ==============================================================================
# test_serde_roundtrip_error — a ShabdaError's stable code + diagnostic text
# survives (the port's serde analog: the code is the wire tag, err_name is
# Display). Mirrors Rust's err.to_string() == roundtripped.to_string().
# ==============================================================================
test_group("error roundtrip");
var err_uw = shabda_err_unknown_word();
assert_eq(shabda_is_err(err_uw), 1, "unknown_word is err");
assert_streq(shabda_err_name(err_uw), "unknown word", "unknown_word name");
assert_streq(shabda_err_name(shabda_err_invalid_input()), "invalid input", "invalid_input name");

