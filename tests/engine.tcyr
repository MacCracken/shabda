# ==============================================================================
# test_timing_profile — 2x vowel scale increases total duration
# ==============================================================================
test_group("timing profile");
var tp_normal = _conv(g_en, "hello");
var tp = shabda_timing_new(f64_from(2), f64_from(1), f64_from(1));
var tp_opts = shabda_convert_options_with_timing(shabda_convert_options_new(), tp);
var tp_stretched = _conv_opts(g_en, "hello", tp_opts);
assert_eq(f64_gt(_sum_dur(tp_stretched), _sum_dur(tp_normal)), 1, "2x vowel scale longer");

# TimingProfile fed to apply_timing directly lengthens vowel durations (offset check).
test_group("timing profile offsets");
var tp2 = shabda_timing_new(f64_from(2), f64_from(1), f64_from(1));
var vowel_ev = vec_new();
vec_push(vowel_ev, svara_phoneme_event_new(SVARA_PH_VOWEL_A, f64_from(1), SVARA_STRESS_PRIMARY));
var base_vd = SvPhonemeEvent_duration(vec_get(vowel_ev, 0));
var at_rc = shabda_apply_timing(vowel_ev, tp2);
var scaled_vd = SvPhonemeEvent_duration(vec_get(vowel_ev, 0));
assert_eq(f64_gt(scaled_vd, base_vd), 1, "vowel scale 2.0 lengthens");
assert_eq(shabda_timing_vowel_scale(tp2), f64_from(2), "vowel_scale accessor");

