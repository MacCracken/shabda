# engine.tcyr — tests for src/engine.cyr (ports rust-old/src/engine.rs +
# rust-old/tests/integration.rs, 55 #[test]s, plus the engine.rs doctests).
#
# The include chain: vendored dep bundles first (dependency order), then every
# shabda module deps-before-dependents. Modules never include each other.

include "lib/hisab.cyr"
include "lib/goonj.cyr"
include "lib/naad.cyr"
include "lib/svara.cyr"
include "lib/varna.cyr"
include "lib/shabdakosh.cyr"
include "src/error.cyr"
include "src/normalize.cyr"
include "src/syllable.cyr"
include "src/heteronym.cyr"
include "src/ssml.cyr"
include "src/rules.cyr"
include "src/prosody.cyr"
include "src/validate.cyr"
include "src/engine.cyr"

alloc_init();

# ---- out-param call wrappers -------------------------------------------------
# convert (default opts) -> events vec; asserts ok.
fn _conv(g, text): i64 {
    var slot = alloc(8);
    var err = shabda_convert(g, text, slot);
    assert_eq(shabda_is_err(err), 0, "convert ok");
    return load64(slot);
}
# convert_with(opts) -> events vec; asserts ok.
fn _conv_opts(g, text, opts): i64 {
    var slot = alloc(8);
    var err = shabda_convert_with(g, text, opts, slot);
    assert_eq(shabda_is_err(err), 0, "convert_with ok");
    return load64(slot);
}
# convert_ssml -> events vec; asserts ok.
fn _ssml(g, s): i64 {
    var slot = alloc(8);
    var err = shabda_convert_ssml(g, s, slot);
    assert_eq(shabda_is_err(err), 0, "convert_ssml ok");
    return load64(slot);
}
# speak -> samples vec; asserts ok.
fn _speak(g, text, voice, sr): i64 {
    var slot = alloc(8);
    var err = shabda_speak(g, text, voice, sr, slot);
    assert_eq(shabda_is_err(err), 0, "speak ok");
    return load64(slot);
}

# ---- helpers -----------------------------------------------------------------
# Sum every event's duration (f64 bits) in a vec.
fn _sum_dur(events): i64 {
    var total = f64_from(0);
    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        total = f64_add(total, SvPhonemeEvent_duration(vec_get(events, i)));
        i = i + 1;
    }
    return total;
}

# Count events whose stress == `stress`.
fn _count_stress(events, stress): i64 {
    var c = 0;
    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        if (SvPhonemeEvent_stress(vec_get(events, i)) == stress) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

# Count Silence events with duration > threshold (f64 bits).
fn _count_pauses_over(events, thresh): i64 {
    var c = 0;
    var n = vec_len(events);
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        if (SvPhonemeEvent_phoneme(e) == SVARA_PH_SILENCE) {
            if (f64_gt(SvPhonemeEvent_duration(e), thresh) == 1) { c = c + 1; }
        }
        i = i + 1;
    }
    return c;
}

# Are all samples finite AND is the max abs amplitude > 0.001? Returns 1/0.
fn _samples_audible(samples): i64 {
    var n = vec_len(samples);
    if (n == 0) { return 0; }
    var maxamp = f64_from(0);
    var i = 0;
    while (i < n) {
        var s = vec_get(samples, i);
        var a = f64_abs(s);
        if (f64_gt(a, maxamp) == 1) { maxamp = a; }
        i = i + 1;
    }
    if (f64_gt(maxamp, 0.001) == 1) { return 1; }
    return 0;
}

# All samples finite? (no NaN/Inf) Returns 1/0.
fn _samples_finite(samples): i64 {
    var n = vec_len(samples);
    var i = 0;
    while (i < n) {
        var s = vec_get(samples, i);
        # finite: s == s (NaN != NaN) and abs < a huge bound.
        if (f64_eq(s, s) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Streaming callback: record the word into a global vec; assert events non-empty.
var STREAM_WORDS = vec_new();
fn _stream_cb(word, events): i64 {
    assert_neq(vec_len(events), 0, "streaming events non-empty");
    vec_push(STREAM_WORDS, word);
    return 0;
}


# ==============================================================================
# test_hello_world
# ==============================================================================
test_group("hello world");
var g_en = shabda_g2p_new(SHABDA_LANG_ENGLISH);
var hw = _conv(g_en, "hello world");
assert_gt(vec_len(hw), 4, "hello world > 4 events");

# ==============================================================================
# test_empty_input_errors
# ==============================================================================
test_group("empty input errors");
var e_empty = alloc(8);
assert_eq(shabda_is_err(shabda_convert(g_en, "", e_empty)), 1, "empty -> err");
assert_eq(shabda_is_err(shabda_convert(g_en, "   ", e_empty)), 1, "whitespace -> err");

# ==============================================================================
# test_dictionary_lookup — "the" is in the dictionary
# ==============================================================================
test_group("dictionary lookup");
var the_ev = _conv(g_en, "the");
assert_neq(vec_len(the_ev), 0, "the non-empty");

# ==============================================================================
# test_rule_fallback — "flurb" not in dict, rules handle it
# ==============================================================================
test_group("rule fallback");
var flurb = _conv(g_en, "flurb");
assert_neq(vec_len(flurb), 0, "flurb non-empty");

# ==============================================================================
# test_speak_produces_audio
# ==============================================================================
test_group("speak produces audio");
var voice_m = svara_voice_new_male();
var samples = _speak(g_en, "hello", voice_m, f64_from(44100));
assert_neq(vec_len(samples), 0, "samples non-empty");
assert_eq(_samples_finite(samples), 1, "samples finite");
assert_eq(_samples_audible(samples), 1, "samples audible");

# ==============================================================================
# test_speak_sentence
# ==============================================================================
test_group("speak sentence");
var voice_f = svara_voice_new_female();
var samples2 = _speak(g_en, "hello world", voice_f, f64_from(44100));
assert_neq(vec_len(samples2), 0, "sentence samples non-empty");
assert_eq(_samples_finite(samples2), 1, "sentence samples finite");

# ==============================================================================
# test_question_intonation
# ==============================================================================
test_group("question intonation");
var samples3 = _speak(g_en, "hello?", voice_m, f64_from(44100));
assert_neq(vec_len(samples3), 0, "hello? samples non-empty");
assert_eq(shabda_detect_intonation("hello?"), SHABDA_STYPE_QUESTION, "? -> question");

# ==============================================================================
# test_custom_dictionary_entry
# ==============================================================================
test_group("custom dictionary entry");
var g_custom = shabda_g2p_new(SHABDA_LANG_ENGLISH);
var agnos_ph = vec_new();
vec_push(agnos_ph, SVARA_PH_VOWEL_ASH);
vec_push(agnos_ph, SVARA_PH_PLOSIVE_G);
vec_push(agnos_ph, SVARA_PH_NASAL_N);
vec_push(agnos_ph, SVARA_PH_VOWEL_O);
vec_push(agnos_ph, SVARA_PH_FRIC_S);
var ins = shbdk_dict_insert(shabda_g2p_dictionary_mut(g_custom), "agnos", agnos_ph);
var agnos_ev = _conv(g_custom, "agnos");
assert_gte(vec_len(agnos_ev), 5, "agnos >= 5 events");

