# ==============================================================================
# test_convert_with_speaking_rate — 75 WPM total > 1.5x baseline
# ==============================================================================
test_group("convert with speaking rate");
var normal_rate = _conv(g_en, "hello world");
var slow_opts = shabda_convert_options_with_speaking_rate(shabda_convert_options_new(), f64_from(75));
var slow_rate = _conv_opts(g_en, "hello world", slow_opts);
var normal_dur = _sum_dur(normal_rate);
var slow_dur = _sum_dur(slow_rate);
assert_eq(f64_gt(slow_dur, f64_mul(normal_dur, 1.5)), 1, "75 WPM > 1.5x baseline");

