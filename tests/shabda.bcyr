# shabda.bcyr — benchmarks (ports rust-old/benches/benchmarks.rs).
# Pattern: bench_new -> bench_batch_start -> tight loop -> bench_batch_stop -> bench_report.

include "lib/hisab.cyr"
include "lib/goonj.cyr"
include "lib/naad.cyr"
include "lib/svara.cyr"
include "lib/varna.cyr"
include "lib/shabdakosh.cyr"

include "src/error.cyr"
include "src/normalize.cyr"
include "src/syllable.cyr"
include "src/heteronym.cyr"
include "src/ssml.cyr"
include "src/rules.cyr"
include "src/prosody.cyr"
include "src/validate.cyr"
include "src/engine.cyr"

fn main(): i64 {
    alloc_init();

    var g = shabda_g2p_new(SHABDA_LANG_ENGLISH);
    var voice = svara_voice_new_male();
    var sr = f64_from(44100);
    var slot = alloc(8);
    var i = 0;
    var sink = 0;

    # convert "hello world"
    var b1 = bench_new("g2p_hello_world");
    bench_batch_start(b1);
    i = 0;
    while (i < 5000) { sink = shabda_convert(g, "hello world", slot); i = i + 1; }
    bench_batch_stop(b1, 5000);
    bench_report(b1);

    # convert a full sentence
    var b2 = bench_new("g2p_sentence");
    bench_batch_start(b2);
    i = 0;
    while (i < 2000) { sink = shabda_convert(g, "the cat sat on the mat and was not happy", slot); i = i + 1; }
    bench_batch_stop(b2, 2000);
    bench_report(b2);

    # speak "hello" -> audio samples
    var b3 = bench_new("speak_hello");
    bench_batch_start(b3);
    i = 0;
    while (i < 200) { sink = shabda_speak(g, "hello", voice, sr, slot); i = i + 1; }
    bench_batch_stop(b3, 200);
    bench_report(b3);

    # speak a sentence -> audio samples
    var b4 = bench_new("speak_sentence");
    bench_batch_start(b4);
    i = 0;
    while (i < 100) { sink = shabda_speak(g, "the cat sat on the mat", voice, sr, slot); i = i + 1; }
    bench_batch_stop(b4, 100);
    bench_report(b4);

    # English dictionary construction
    var b5 = bench_new("dict_english_construction");
    bench_batch_start(b5);
    i = 0;
    while (i < 50) { sink = shbdk_dict_english(); i = i + 1; }
    bench_batch_stop(b5, 50);
    bench_report(b5);

    # dictionary lookup hit
    var dict = shbdk_dict_english();
    var b6 = bench_new("dict_lookup_hit");
    bench_batch_start(b6);
    i = 0;
    while (i < 200000) { sink = shbdk_dict_lookup(dict, "the"); i = i + 1; }
    bench_batch_stop(b6, 200000);
    bench_report(b6);

    # dictionary lookup miss
    var b7 = bench_new("dict_lookup_miss");
    bench_batch_start(b7);
    i = 0;
    while (i < 200000) { sink = shbdk_dict_lookup(dict, "zxqvbnm"); i = i + 1; }
    bench_batch_stop(b7, 200000);
    bench_report(b7);

    return 0;
}

var r = main();
syscall(60, r);
