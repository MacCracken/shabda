# ssml.tcyr — tests for src/ssml.cyr (ports rust-old/src/ssml.rs).
# The Rust module's ~15 #[test]s mapped 1:1, plus serde round-trip parity for
# SsmlNode / EmphasisLevel / SpeakingRate.

include "src/error.cyr"
include "src/ssml.cyr"

alloc_init();

# Helper: a cstr Str for comparison.
fn _text_is(node, lit): i64 {
    if (shabda_ssml_node_tag(node) != SHABDA_SSML_TEXT) { return 0; }
    return str_eq_cstr(shabda_ssml_node_text(node), lit);
}

# ================================================================
test_group("plain text");
var n1 = shabda_ssml_parse("hello world");
assert_eq(vec_len(n1), 1, "one node");
assert_eq(_text_is(vec_get(n1, 0), "hello world"), 1, "text = hello world");

# ================================================================
test_group("break ms");
var n2 = shabda_ssml_parse("hello <break time=\"500ms\"/> world");
assert_eq(vec_len(n2), 3, "three nodes");
assert_eq(shabda_ssml_node_tag(vec_get(n2, 1)), SHABDA_SSML_BREAK, "node[1] is break");
assert_eq(shabda_ssml_node_duration(vec_get(n2, 1)), 500, "break = 500ms");
assert_eq(_text_is(vec_get(n2, 0), "hello"), 1, "node[0] hello");
assert_eq(_text_is(vec_get(n2, 2), "world"), 1, "node[2] world");

# ================================================================
test_group("break seconds");
var n3 = shabda_ssml_parse("<break time=\"1.5s\"/>");
assert_eq(vec_len(n3), 1, "one node");
assert_eq(shabda_ssml_node_tag(vec_get(n3, 0)), SHABDA_SSML_BREAK, "is break");
assert_eq(shabda_ssml_node_duration(vec_get(n3, 0)), 1500, "1.5s -> 1500ms");

# ================================================================
test_group("break strength");
var n4 = shabda_ssml_parse("<break strength=\"strong\"/>");
assert_eq(vec_len(n4), 1, "one node");
assert_eq(shabda_ssml_node_duration(vec_get(n4, 0)), 600, "strong -> 600ms");

# ================================================================
test_group("emphasis");
var n5 = shabda_ssml_parse("<emphasis level=\"strong\">important</emphasis>");
assert_eq(vec_len(n5), 1, "one node");
var e5 = vec_get(n5, 0);
assert_eq(shabda_ssml_node_tag(e5), SHABDA_SSML_EMPHASIS, "is emphasis");
assert_eq(shabda_ssml_node_level(e5), SHABDA_EMPH_STRONG, "level strong");
var e5k = shabda_ssml_node_children(e5);
assert_eq(vec_len(e5k), 1, "one child");
assert_eq(_text_is(vec_get(e5k, 0), "important"), 1, "child = important");

# ================================================================
test_group("emphasis default level");
var n6 = shabda_ssml_parse("<emphasis>word</emphasis>");
var e6 = vec_get(n6, 0);
assert_eq(shabda_ssml_node_tag(e6), SHABDA_SSML_EMPHASIS, "is emphasis");
assert_eq(shabda_ssml_node_level(e6), SHABDA_EMPH_MODERATE, "default moderate");

# ================================================================
test_group("prosody rate");
var n7 = shabda_ssml_parse("<prosody rate=\"slow\">text</prosody>");
var p7 = vec_get(n7, 0);
assert_eq(shabda_ssml_node_tag(p7), SHABDA_SSML_PROSODY, "is prosody");
assert_eq(shabda_ssml_node_rate(p7), SHABDA_RATE_SLOW, "rate slow");
var p7k = shabda_ssml_node_children(p7);
assert_eq(vec_len(p7k), 1, "one child");
assert_eq(_text_is(vec_get(p7k, 0), "text"), 1, "child = text");

# ================================================================
test_group("speak wrapper");
var n8 = shabda_ssml_parse("<speak>hello world</speak>");
assert_eq(vec_len(n8), 1, "one node");
assert_eq(_text_is(vec_get(n8, 0), "hello world"), 1, "text hello world");

# ================================================================
test_group("nested elements");
var n9 = shabda_ssml_parse("Start <emphasis level=\"strong\">very <break time=\"200ms\"/> important</emphasis> end");
assert_eq(vec_len(n9), 3, "three nodes");
assert_eq(_text_is(vec_get(n9, 0), "Start"), 1, "node[0] Start");
var e9 = vec_get(n9, 1);
assert_eq(shabda_ssml_node_tag(e9), SHABDA_SSML_EMPHASIS, "node[1] emphasis");
assert_eq(shabda_ssml_node_level(e9), SHABDA_EMPH_STRONG, "level strong");
assert_eq(vec_len(shabda_ssml_node_children(e9)), 3, "3 children");
assert_eq(_text_is(vec_get(n9, 2), "end"), 1, "node[2] end");

# ================================================================
test_group("speaking rate wpm");
assert_eq(shabda_speaking_rate_wpm(SHABDA_RATE_SLOW), f64_from(100), "slow 100 wpm");
assert_eq(shabda_speaking_rate_wpm(SHABDA_RATE_FAST), f64_from(200), "fast 200 wpm");
assert_eq(shabda_speaking_rate_wpm(SHABDA_RATE_XSLOW), f64_from(75), "xslow 75 wpm");
assert_eq(shabda_speaking_rate_wpm(SHABDA_RATE_MEDIUM), f64_from(150), "medium 150 wpm");
assert_eq(shabda_speaking_rate_wpm(SHABDA_RATE_XFAST), f64_from(250), "xfast 250 wpm");

# ================================================================
# serde round-trip: SsmlNode (Emphasis[Strong, Text("hello")]) survives a
# serialize -> deserialize identity (here the clone proxy) with structural eq.
test_group("serde roundtrip node");
var kids = vec_new();
vec_push(kids, shabda_ssml_text(str_from("hello")));
var node = shabda_ssml_emphasis(SHABDA_EMPH_STRONG, kids);
var rt = shabda_ssml_node_clone(node);
assert_eq(shabda_ssml_node_eq(node, rt), 1, "node roundtrip equal");

# ================================================================
test_group("serde roundtrip rate");
var rate = SHABDA_RATE_FAST;
var rate_rt = shabda_speaking_rate_decode(shabda_speaking_rate_encode(rate));
assert_eq(rate_rt, rate, "rate roundtrip equal");

# ================================================================
test_group("serde roundtrip level");
var level = SHABDA_EMPH_STRONG;
var level_rt = shabda_emphasis_level_decode(shabda_emphasis_level_encode(level));
assert_eq(level_rt, level, "level roundtrip equal");

# ================================================================
test_group("empty input");
var n_empty = shabda_ssml_parse("");
assert_eq(vec_len(n_empty), 0, "empty -> no nodes");

# ================================================================
# Extra parity checks the sentinel translation could break.
test_group("prosody default rate none");
var np = shabda_ssml_parse("<prosody>x</prosody>");
assert_eq(shabda_ssml_node_rate(vec_get(np, 0)), SHABDA_RATE_NONE, "no rate -> None sentinel");

test_group("unclosed tag is parse error");
assert_eq(shabda_ssml_parse("hello <break "), 0, "unclosed -> 0");

test_group("break default duration");
var nd = shabda_ssml_parse("<break/>");
assert_eq(shabda_ssml_node_duration(vec_get(nd, 0)), 300, "default 300ms");

test_group("single-quoted attr");
var nq = shabda_ssml_parse("<break time='250ms'/>");
assert_eq(shabda_ssml_node_duration(vec_get(nq, 0)), 250, "single-quote 250ms");

test_group("phoneme self-closing ph attr");
var nph = shabda_ssml_parse("<phoneme ph=\"AH0\"/>");
assert_eq(_text_is(vec_get(nph, 0), "AH0"), 1, "ph attr -> text");

var rc = assert_summary();
syscall(60, rc);
